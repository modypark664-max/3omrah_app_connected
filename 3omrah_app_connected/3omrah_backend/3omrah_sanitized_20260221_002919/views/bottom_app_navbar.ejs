<!-- Bottom Navigation Bar for Mobile -->
<%
// Server-side detection of pages that need reversed ordering
const currentPath = typeof currentRoute !== 'undefined' ? currentRoute : '';
const shouldReverse = currentPath === '/' || 
                     currentPath === '/partner';
%>

<nav class="bottom-navbar">
    <div class="bottom-nav-container">
        <a href="/bundles" class="nav-item <%= (typeof currentRoute !== 'undefined' && currentRoute === '/bundles') ? 'active' : '' %>" style="order: <%= shouldReverse ? '1' : '3' %> !important;">
            <div class="nav-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z" fill="currentColor"/>
                    <path d="M19 15L20.09 18.26L23 19L20.09 19.74L19 23L17.91 19.74L15 19L17.91 18.26L19 15Z" fill="currentColor"/>
                    <path d="M5 15L6.09 18.26L9 19L6.09 19.74L5 23L3.91 19.74L1 19L3.91 18.26L5 15Z" fill="currentColor"/>
                </svg>
            </div>
            <span class="nav-label">باقات العمرة</span>
        </a>

        <a href="/contact" class="nav-item <%= (typeof currentRoute !== 'undefined' && currentRoute === '/contact') ? 'active' : '' %>" style="order: 2 !important;">
            <div class="nav-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22 12C22 17.5228 17.5228 22 12 22C10.3596 22 8.77516 21.6039 7.35418 20.8583L2 22L3.14171 16.6458C2.39607 15.2248 2 13.6404 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" stroke="currentColor" stroke-width="2" fill="none"/>
                    <path d="M8 12H16M8 8H16M8 16H12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>
            <span class="nav-label">اتصل بنا</span>
        </a>

        <% if (typeof user !== 'undefined' && user) { %>
        <a href="/profile" class="nav-item <%= (typeof currentRoute !== 'undefined' && currentRoute === '/profile') ? 'active' : '' %>" style="order: <%= shouldReverse ? '3' : '1' %> !important;">
            <div class="nav-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 12C14.7614 12 17 9.76142 17 7C17 4.23858 14.7614 2 12 2C9.23858 2 7 4.23858 7 7C7 9.76142 9.23858 12 12 12Z" fill="currentColor"/>
                    <path d="M12 14C7.58172 14 4 17.5817 4 22H20C20 17.5817 16.4183 14 12 14Z" fill="currentColor"/>
                </svg>
            </div>
            <span class="nav-label">الملف الشخصي</span>
        </a>
        <% } else { %>
        <a href="/login" class="nav-item <%= (typeof currentRoute !== 'undefined' && currentRoute === '/login') ? 'active' : '' %>" style="order: <%= shouldReverse ? '3' : '1' %> !important;">
            <div class="nav-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M15 3H19C19.5304 3 20.0391 3.21071 20.4142 3.58579C20.7893 3.96086 21 4.46957 21 5V19C21 19.5304 20.7893 20.0391 20.4142 20.4142C20.0391 20.7893 19.5304 21 19 21H15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M10 17L15 12L10 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M15 12H3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <span class="nav-label">تسجيل الدخول</span>
        </a>
        <% } %>
    </div>
</nav>

<style>
    .bottom-navbar {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: white;
        border-top: 1px solid #e2e8f0;
        box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.1);
        z-index: 1000;
        padding: 10px 0 max(10px, env(safe-area-inset-bottom));
        display: none;
    }

    .bottom-nav-container {
        display: flex;
        justify-content: space-around;
        align-items: center;
        max-width: 500px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .nav-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        text-decoration: none;
        color: #64748b;
        transition: all 0.3s ease;
        padding: 8px 12px;
        border-radius: 12px;
        min-width: 60px;
    }

    .nav-item.active {
        color: #1E5470;
        background: rgba(30, 84, 112, 0.1);
    }

    .nav-item:hover {
        color: #1E5470;
        background: rgba(30, 84, 112, 0.05);
    }

    .nav-icon {
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .nav-label {
        font-size: 11px;
        font-weight: 500;
        text-align: center;
        line-height: 1.2;
        font-family: var(--font-tajawal), sans-serif;
    }

    /* Show bottom navbar only on mobile devices */
    @media (max-width: 768px) {
        .bottom-navbar {
            display: block;
        }
        
        /* Add padding to body to prevent content from being hidden behind navbar */
        body {
            padding-bottom: 90px;
        }
    }

    /* Hide on very small screens to prevent overcrowding */
    @media (max-width: 320px) {
        .nav-label {
            font-size: 10px;
        }
        
        .nav-item {
            min-width: 50px;
            padding: 6px 8px;
        }
    }
</style>