<script>
// Calculate total price when room type or people count changes
function calculateTotal() {
  const roomSelect = document.getElementById('roomType');
  const peopleInput = document.getElementById('peopleCount');
  const priceDisplay = document.getElementById('priceAmount');
  const totalPriceSection = document.getElementById('totalPrice');
  
  console.log('Calculating total...'); // Debug log
  
  if (roomSelect && peopleInput && priceDisplay) {
    const selectedOption = roomSelect.options[roomSelect.selectedIndex];
    const roomPrice = selectedOption ? parseFloat(selectedOption.getAttribute('data-price')) || 0 : 0;
    const peopleCount = parseInt(peopleInput.value) || 0;
    
    console.log('Room price:', roomPrice, 'People count:', peopleCount); // Debug log
    
    // Show room price even if people count is 0, or total if people count > 0
    const displayPrice = peopleCount > 0 ? roomPrice * peopleCount : roomPrice;
    
    console.log('Display price:', displayPrice); // Debug log
    
    // Add animation effect
    if (displayPrice > 0) {
      priceDisplay.style.transform = 'scale(1.1)';
      setTimeout(() => {
        priceDisplay.style.transform = 'scale(1)';
      }, 200);
      
      totalPriceSection.style.opacity = '1';
      totalPriceSection.style.transform = 'translateY(0)';
      
      // Update the text based on whether we're showing per person or total
      const priceText = totalPriceSection.querySelector('span:not(#priceAmount)') || 
                       totalPriceSection.childNodes[0];
      if (peopleCount > 0) {
        // Show total price
        if (priceText) {
          priceText.textContent = 'إجمالي التكلفة: ';
        }
      } else {
        // Show per person price
        if (priceText) {
          priceText.textContent = 'سعر الفرد: ';
        }
      }
    } else {
      totalPriceSection.style.opacity = '0.6';
      totalPriceSection.style.transform = 'translateY(5px)';
    }
    
    priceDisplay.textContent = displayPrice.toLocaleString();
    
    // Update the form submit button state
    const submitButton = document.querySelector('.submit-btn');
    if (submitButton) {
      if (roomPrice > 0 && peopleCount > 0 && roomSelect.value) {
        submitButton.style.backgroundColor = '#1E5470';
        submitButton.style.cursor = 'pointer';
        submitButton.disabled = false;
      } else {
        submitButton.style.backgroundColor = '#94a3b8';
        submitButton.style.cursor = 'not-allowed';
        submitButton.disabled = true;
      }
    }
  }
}

// Add visual feedback for dropdown selection
function handleDropdownChange() {
  const roomSelect = document.getElementById('roomType');
  const selectWrapper = roomSelect.closest('.custom-select-wrapper');
  
  console.log('Dropdown changed to:', roomSelect.value); // Debug log
  
  if (roomSelect.value) {
    selectWrapper.classList.add('selected');
    roomSelect.style.color = '#1E5470';
    roomSelect.style.fontWeight = '600';
  } else {
    selectWrapper.classList.remove('selected');
    roomSelect.style.color = '#64748b';
    roomSelect.style.fontWeight = '500';
  }
  
  calculateTotal();
}

// Add event listeners when page loads
document.addEventListener('DOMContentLoaded', function() {
  const roomSelect = document.getElementById('roomType');
  const peopleInput = document.getElementById('peopleCount');
  const totalPriceSection = document.getElementById('totalPrice');
  
  console.log('DOM loaded, setting up event listeners...'); // Debug log
  
  // Add transition effects
  if (totalPriceSection) {
    totalPriceSection.style.transition = 'all 0.3s ease';
  }
  
  if (roomSelect) {
    // Use both 'change' and 'input' events for better compatibility
    roomSelect.addEventListener('change', handleDropdownChange);
    roomSelect.addEventListener('input', handleDropdownChange);
    roomSelect.addEventListener('focus', function() {
      this.closest('.custom-select-wrapper').classList.add('focused');
    });
    roomSelect.addEventListener('blur', function() {
      this.closest('.custom-select-wrapper').classList.remove('focused');
    });
    
    console.log('Room select event listeners added'); // Debug log
  }
  
  if (peopleInput) {
    peopleInput.addEventListener('input', calculateTotal);
    peopleInput.addEventListener('change', calculateTotal);
    console.log('People input event listeners added'); // Debug log
  }
  
  // Add price display transition
  const priceAmount = document.getElementById('priceAmount');
  if (priceAmount) {
    priceAmount.style.transition = 'transform 0.2s ease';
  }
  
  // Initialize the form state
  calculateTotal();
  
  // --- Begin thumbnail swap logic ---
  const mainImage = document.getElementById('mainImage');
  const thumbnailGrid = document.getElementById('thumbnailGrid');
  if (mainImage && thumbnailGrid) {
    thumbnailGrid.addEventListener('click', function(e) {
      if (e.target && e.target.classList.contains('thumbnail-image')) {
        // Swap src and alt between main image and clicked thumbnail
        const tempSrc = mainImage.src;
        const tempAlt = mainImage.alt;
        mainImage.src = e.target.src;
        mainImage.alt = e.target.alt;
        e.target.src = tempSrc;
        e.target.alt = tempAlt;
      }
    });
  }
  // --- End thumbnail swap logic ---
  
  console.log('Initial setup complete'); // Debug log
});
</script>

