}

/* Expired Offer Styling */
.expired-offer {
  text-align: center;
  padding: 40px 20px;
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
  border: 2px solid #fca5a5;
  border-radius: 16px;
  margin: 20px 0;
}

.expired-icon {
  margin-bottom: 20px;
  display: flex;
  justify-content: center;
}

.expired-offer h4 {
  color: #dc2626;
  font-size: 24px;
  font-weight: 700;
  margin-bottom: 15px;
  font-family: var(--font-tajawal);
}

.expired-offer p {
  color: #7f1d1d;
  font-size: 16px;
  line-height: 1.6;
  margin-bottom: 15px;
  font-weight: 500;
}

.expired-offer .btn {
  transition: all 0.3s ease;
}

.expired-offer .btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
}

.btn-secondary {
