/* Modern Offer Details Section */
.offer-details-section {
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
  padding: 48px 0;
  position: relative;
}

.offer-details-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(circle at 20% 30%, rgba(30, 84, 112, 0.03) 0%, transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(92, 131, 151, 0.03) 0%, transparent 50%);
  pointer-events: none;
}

.section-header {
  text-align: center;
  margin-bottom: 40px;
  position: relative;
}

.section-title {
  font-size: 32px;
  font-weight: 800;
  color: #1e5470;
  font-family: var(--font-tajawal);
  margin: 0 0 12px 0;
  position: relative;
  display: inline-block;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: -8px;
  left: 50%;
  transform: translateX(-50%);
  width: 80px;
  height: 4px;
  background: linear-gradient(135deg, #1e5470 0%, #34729c 100%);
  border-radius: 2px;
}

.section-subtitle {
  font-size: 16px;
  color: #64748b;
  font-weight: 500;
  margin: 0;
}

.details-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
  gap: 24px;
  max-width: 1200px;
  margin: 0 auto;
}

.detail-card {
  background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
  border: 1px solid #e2e8f0;
  border-radius: 16px;
  padding: 24px;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  direction: rtl;
  text-align: right;
}

.detail-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  transition: all 0.3s ease;
}

.detail-card.included::before {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
}

.detail-card.excluded::before {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
}

.detail-card.notes::before {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
}

.detail-card.cancellation::before {
  background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
}

.detail-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
  border-color: #1e5470;
}

.detail-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 20px;
  direction: rtl;
  text-align: right;
}

.detail-icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.included-icon {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  color: #059669;
}

.excluded-icon {
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
  color: #dc2626;
}

.notes-icon {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  color: #d97706;
}

.cancellation-icon {
  background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 100%);
  color: #7c3aed;
}

.detail-card:hover .detail-icon {
  transform: scale(1.1) rotate(5deg);
}

.detail-header h3 {
  font-size: 20px;
  font-weight: 700;
  color: #1e5470;
  margin: 0;
  font-family: var(--font-tajawal);
  text-align: right;
  flex: 1;
}

.detail-content {
  direction: rtl;
  text-align: right;
}

.service-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 12px;
  padding: 8px 0;
  transition: all 0.3s ease;
  border-radius: 8px;
}

.service-item:hover {
  background: rgba(30, 84, 112, 0.05);
  padding-right: 12px;
  padding-left: 12px;
}

.service-bullet {
  color: #1e5470;
  font-weight: 900;
  font-size: 16px;
  flex-shrink: 0;
  margin-top: 2px;
}

.service-text {
  flex: 1;
  color: #475569;
  font-weight: 500;
  line-height: 1.6;
  font-size: 15px;
}

/* Modern Itinerary Section */
.itinerary-pricing-section {
  background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
  padding: 48px 0;
  position: relative;
}

.itinerary-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
  gap: 32px;
  max-width: 1200px;
  margin: 0 auto;
}

.itinerary-card {
  background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
  border: 1px solid #e2e8f0;
  border-radius: 20px;
  padding: 28px;
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  direction: rtl;
  text-align: right;
}

.itinerary-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(135deg, #1e5470 0%, #34729c 100%);
}

.itinerary-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 16px 40px rgba(0, 0, 0, 0.12);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 24px;
  padding-bottom: 20px;
  border-bottom: 1px solid #e2e8f0;
  direction: rtl;
  text-align: right;
}

.card-icon {
  width: 56px;
  height: 56px;
  background: linear-gradient(135deg, #1e5470 0%, #34729c 100%);
  color: white;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4px 15px rgba(30, 84, 112, 0.3);
}

.card-title h3 {
  font-size: 22px;
  font-weight: 800;
  color: #1e5470;
  margin: 0 0 4px 0;
  font-family: var(--font-tajawal);
  text-align: right;
  flex: 1;
}

.card-title p {
  font-size: 14px;
  color: #64748b;
  margin: 0;
  font-weight: 500;
  text-align: right;
}

/* Accommodation Styles */
.accommodation-list {
  direction: rtl;
  text-align: right;
}

.hotel-item {
