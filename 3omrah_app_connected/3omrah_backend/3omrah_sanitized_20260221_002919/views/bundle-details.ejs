  color: var(--color-white);
  border-radius: 8px;
}

.btn-secondary:hover {
  background-color: #475569;
}

.custom-select {
  width: 100%;
  padding: 16px 50px 16px 20px;
  font-size: 16px;
  font-weight: 500;
  color: #1E5470;
  background-color: #ffffff;
  border: 2px solid #e2e8f0;
  border-radius: 12px;
  outline: none;
  cursor: pointer;
  transition: all 0.3s ease;
  appearance: none;
  -webkit-appearance: none;
  -moz-appearance: none;
  direction: rtl;
  text-align: right;
  font-family: var(--font-tajawal), sans-serif;
}

.custom-select:focus {
  border-color: #1E5470;
  box-shadow: 0 0 0 3px rgba(30, 84, 112, 0.1);
  background-color: #f8fafc;
}

.custom-select:hover {
  border-color: #34729C;
  background-color: #f8fafc;
}

.custom-select option {
  padding: 12px;
  font-size: 15px;
  font-weight: 500;
  color: #1E5470;
  background-color: #ffffff;
  direction: rtl;
  text-align: right;
}

.custom-select option:hover,
.custom-select option:checked {
  background-color: #1E5470;
  color: #ffffff;
}

.select-arrow {
  position: absolute;
  left: 15px;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
  color: #64748b;
  transition: all 0.3s ease;
}

.custom-select:focus + .select-arrow {
  color: #1E5470;
