<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Alexandria:wght@100..900&family=Cairo:wght@200..1000&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Tajawal:wght@200;300;400;500;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/bundle-details.css">
    <link rel="stylesheet" href="/home.css">
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/imgs/logo.png">
    <link rel="shortcut icon" type="image/png" href="/imgs/logo.png">
    <link rel="apple-touch-icon" href="/imgs/logo.png">
    
    <title><%= title || 'تفاصيل الباقة' %></title>
</head>
<body>
    <header class="simple-header">
        <%- include('navbar') %>
    </header>
<section id="package-details" class="package-details-section">
  <div class="container">
    <div class="content-card">
      <h2 class="package-title">
        <% if (card.type === 'omrah') { %>
          برامج عُمرة <%= new Date(card.travel_date).getFullYear() %> م - <%= card.days %> أيام / <%= card.nights %> ليالي
        <% } else if (card.type === 'internal_tour') { %>
          رحلة داخلية - <%= card.code %> - <%= card.days %> أيام / <%= card.nights %> ليالي
        <% } else { %>
          رحلة خارجية - <%= card.code %> - <%= card.days %> أيام / <%= card.nights %> ليالي
        <% } %>
      </h2>
      <hr class="title-divider" />
      <div class="gallery">
        <img src="<%= card.thumbnail %>" alt="<%= card.code %>" class="main-image" loading="lazy" id="mainImage">
        <div class="thumbnail-grid" id="thumbnailGrid">
          <% if (card.images && card.images.length > 0) { %>
            <% card.images.slice(0, 4).forEach((image, index) => { %>
              <img src="<%= image %>" alt="<%= card.code %> - صورة <%= index + 1 %>" class="thumbnail-image" loading="lazy">
            <% }) %>
          <% } else { %>
            <img src="/imgs/Rectangle 10 (1).png" alt="Thumbnail 1" class="thumbnail-image">
            <img src="/imgs/Rectangle 17.png" alt="Thumbnail 2" class="thumbnail-image">
            <img src="/imgs/Rectangle 18.png" alt="Thumbnail 3" class="thumbnail-image">
            <img src="/imgs/Rectangle 19.png" alt="Thumbnail 4" class="thumbnail-image">
          <% } %>
        </div>
      </div>
      <div class="package-info-wrapper">
        <div class="package-title-card">
          <h1 class="package-title"><%= card.name %></h1>
          <div class="package-code">كود العرض: <span><%= card.code %></span></div>
        </div>

        <div class="package-info-grid">
          <div class="info-card">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 2v3m8-3v3m-9 8h10M5 21h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 1-2 2v12a2 2 0 0 0 2 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="info-content">
              <span class="info-label">تاريخ السفر</span>
              <span class="info-value"><%= new Date(card.travel_date).toLocaleDateString('ar-EG') %></span>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 2v3m8-3v3m-9 8h10M5 21h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 1-2 2v12a2 2 0 0 0 2 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="info-content">
              <span class="info-label">مدة العرض</span>
              <span class="info-value"><%= card.days %> أيام - <%= card.nights %> ليالي</span>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 7v5l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="info-content">
              <span class="info-label">انتهاء العرض</span>
              <span class="info-value <%= card.offer_expiry_date && new Date() > new Date(card.offer_expiry_date) ? 'text-danger' : '' %>">
                <%= card.offer_expiry_date ? new Date(card.offer_expiry_date).toLocaleDateString('ar-EG') : 'غير محدد' %>
              </span>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z" fill="currentColor" opacity="0.1"/>
                <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="info-content">
              <span class="info-label">خط سير الذهاب</span>
              <span class="info-value"><%= card.going_route %></span>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z" fill="currentColor" opacity="0.1"/>
                <path d="M12 18v-6l-4-2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="info-content">
              <span class="info-label">خط سير العودة</span>
              <span class="info-value"><%= card.returning_route %></span>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M7.5 4.21l4.5 2.6 4.5-2.6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M7.5 19.79V14.6L3 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M21 12l-4.5 2.6v5.19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M3.27 6.96L12 12.01l8.73-5.05" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M12 22.08V12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="info-content">
              <span class="info-label">شركة الطيران</span>
              <span class="info-value"><%= card.plane_company %></span>
            </div>
          </div>

          <% if (card.company && card.company.trim()) { %>
          <div class="info-card">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M22 21v-2a4 4 0 0 0-3-3.87" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="info-content">
              <span class="info-label">الشركة المنظمة</span>
              <span class="info-value"><%= card.company %></span>
            </div>
          </div>
          <% } %>
        </div>

        <div class="package-price-card">
          <div class="price-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="price-content">
            <span class="price-label">السعر يبدأ من</span>
            <div class="price-amount-wrapper">
              <span class="price-amount"><%= card.lowest_price %></span>
              <span class="price-currency">جنيه مصري</span>
            </div>
          </div>
        </div>
      </div>
<section id="offer-details" class="offer-details-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">تفاصيل العرض</h2>
      <div class="section-subtitle">كل ما تحتاج معرفته عن هذا العرض</div>
    </div>
    <div class="details-grid">
      <% if (card.included_services && card.included_services.length > 0) { %>
        <div class="detail-card included">
          <div class="detail-header">
            <div class="detail-icon included-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>يشمل البرنامج</h3>
          </div>
          <div class="detail-content">
            <% card.included_services.forEach(service => { %>
              <div class="service-item">
                <span class="service-bullet">•</span>
                <span class="service-text"><%= service %></span>
              </div>
            <% }) %>
          </div>
        </div>
      <% } else { %>
        <div class="detail-card included">
          <div class="detail-header">
            <div class="detail-icon included-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>يشمل البرنامج</h3>
          </div>
          <div class="detail-content">
            <div class="service-item">
              <span class="service-bullet">•</span>
              <span class="service-text">استخراج التأشيرة + الباركود</span>
            </div>
            <div class="service-item">
              <span class="service-bullet">•</span>
              <span class="service-text">الإقامة بالفنادق المذكورة</span>
            </div>
            <div class="service-item">
              <span class="service-bullet">•</span>
              <span class="service-text">الانتقالات الداخلية بين مكة والمدينة</span>
            </div>
            <div class="service-item">
              <span class="service-bullet">•</span>
              <span class="service-text">الانتقالات من وإلى المطار</span>
            </div>
            <div class="service-item">
              <span class="service-bullet">•</span>
              <span class="service-text">إشراف إداري وديني طوال الرحلة</span>
            </div>
          </div>
        </div>
      <% } %>

      <% if (card.not_included_services && card.not_included_services.length > 0) { %>
        <div class="detail-card excluded">
          <div class="detail-header">
            <div class="detail-icon excluded-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                <path d="m15 9-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="m9 9 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>لا يشمل البرنامج</h3>
          </div>
          <div class="detail-content">
            <% card.not_included_services.forEach(service => { %>
              <div class="service-item">
                <span class="service-bullet">•</span>
                <span class="service-text"><%= service %></span>
              </div>
            <% }) %>
          </div>
        </div>
      <% } else { %>
        <div class="detail-card excluded">
          <div class="detail-header">
            <div class="detail-icon excluded-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                <path d="m15 9-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="m9 9 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>لا يشمل البرنامج</h3>
          </div>
          <div class="detail-content">
            <div class="service-item">
              <span class="service-bullet">•</span>
              <span class="service-text">أسعار البرنامج لا تشمل تذاكر الطيران</span>
            </div>
          </div>
        </div>
      <% } %>

      <% if (card.notes && card.notes.length > 0) { %>
        <div class="detail-card notes">
          <div class="detail-header">
            <div class="detail-icon notes-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>ملاحظات هامة</h3>
          </div>
          <div class="detail-content">
            <% card.notes.forEach(note => { %>
              <div class="service-item">
                <span class="service-bullet">•</span>
                <span class="service-text"><%= note %></span>
              </div>
            <% }) %>
          </div>
        </div>
      <% } else { %>
        <div class="detail-card notes">
          <div class="detail-header">
            <div class="detail-icon notes-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>ملاحظات هامة</h3>
          </div>
          <div class="detail-content">
            <div class="service-item">
              <span class="service-bullet">•</span>
              <span class="service-text">يتم سداد 50% من قيمة الرحلة عند التعاقد</span>
            </div>
            <div class="service-item">
              <span class="service-bullet">•</span>
              <span class="service-text">أي تغيير في سعر الصرف يُضاف على المبلغ المتبقي</span>
            </div>
            <div class="service-item">
              <span class="service-bullet">•</span>
              <span class="service-text">خصم 9,000 جنيه لحاملي تأشيرة دخول المملكة أو تأشيرات (أمريكا/شينجن) الصالحة والمستخدمة سابقًا</span>
            </div>
            <div class="service-item">
              <span class="service-bullet">•</span>
              <span class="service-text">لا يتم استرداد المبلغ في حالة رفض التأشيرة لأسباب شخصية (تجنيد – بصمة – تصريح سفر)</span>
            </div>
          </div>
        </div>
      <% } %>

      <% if (card.cancelling_rules && card.cancelling_rules.length > 0) { %>
        <div class="detail-card cancellation">
          <div class="detail-header">
            <div class="detail-icon cancellation-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 6h18l-2 13H5L3 6z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10 11v6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M14 11v6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>سياسة الإلغاء</h3>
          </div>
          <div class="detail-content">
            <% card.cancelling_rules.forEach(rule => { %>
              <div class="service-item">
                <span class="service-bullet">•</span>
                <span class="service-text"><%= rule %></span>
              </div>
            <% }) %>
          </div>
        </div>
      <% } else { %>
        <div class="detail-card cancellation">
          <div class="detail-header">
            <div class="detail-icon cancellation-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 6h18l-2 13H5L3 6z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10 11v6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M14 11v6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>سياسة الإلغاء</h3>
          </div>
          <div class="detail-content">
            <div class="service-item">
              <span class="service-bullet">•</span>
              <span class="service-text">قبل موعد السفر بأكثر من 30 يوم → استرداد 100% من المبلغ المدفوع</span>
            </div>
            <div class="service-item">
              <span class="service-bullet">•</span>
              <span class="service-text">قبل أقل من 30 يوم → تطبق غرامات حسب سياسة الشركة</span>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>
<section id="itinerary-pricing" class="itinerary-pricing-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">خط سير الرحلة المفصل</h2>
      <div class="section-subtitle">تفاصيل الإقامة والأسعار</div>
    </div>
    
    <div class="itinerary-grid">
      <!-- Accommodation Details -->
      <div class="itinerary-card accommodation-card">
        <div class="card-header">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <polyline points="9,22 9,12 15,12 15,22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="card-title">
            <h3>خطة الإقامة</h3>
            <p>تفاصيل الفنادق والمبيت</p>
          </div>
        </div>
        
        <div class="accommodation-list">
          <% if (card.plane && card.plane.hotel && card.plane.hotel.length > 0) { %>
            <% card.plane.hotel.forEach((hotel, index) => { %>
              <div class="hotel-item">
                <div class="hotel-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M2 17h20v2H2zm1.15-4.05L4 11l.85 1.95L7 13l-1.85.95L4 17l-.85-1.95L1 15l1.15-.05zm6.7-.95L8 9l1.85 3.95L14 13l-4.15.95L8 18l-1.85-3.95L2 14l6.7-.95zM19 9v6h3l-2-3 2-3h-3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <div class="hotel-details">
                  <div class="hotel-name">فندق <%= hotel.hotel %></div>
                  <div class="hotel-info">
                    <span class="nights"><%= hotel.nights %> ليالي</span>
                    <span class="location"><%= hotel.location %></span>
                    <span class="rating">(<%= hotel.hotel_type %>)</span>
                  </div>
                  <div class="meal-info <%= hotel.comes_with_food ? 'with-meals' : 'without-meals' %>">
                    <% if (hotel.comes_with_food) { %>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      مع وجبات
                    <% } else { %>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                        <path d="m15 9-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="m9 9 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      بدون وجبات
                    <% } %>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="hotel-item">
              <div class="hotel-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M2 17h20v2H2zm1.15-4.05L4 11l.85 1.95L7 13l-1.85.95L4 17l-.85-1.95L1 15l1.15-.05zm6.7-.95L8 9l1.85 3.95L14 13l-4.15.95L8 18l-1.85-3.95L2 14l6.7-.95zM19 9v6h3l-2-3 2-3h-3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="hotel-details">
                <div class="hotel-name">فندق مكة المكرمة</div>
                <div class="hotel-info">
                  <span class="nights"><%= Math.floor(card.nights / 2) %> ليالي</span>
                  <span class="location">مكة المكرمة</span>
                  <span class="rating">(4 نجوم)</span>
                </div>
                <div class="meal-info without-meals">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                    <path d="m15 9-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="m9 9 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  بدون وجبات
                </div>
              </div>
            </div>
            <div class="hotel-item">
              <div class="hotel-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M2 17h20v2H2zm1.15-4.05L4 11l.85 1.95L7 13l-1.85.95L4 17l-.85-1.95L1 15l1.15-.05zm6.7-.95L8 9l1.85 3.95L14 13l-4.15.95L8 18l-1.85-3.95L2 14l6.7-.95zM19 9v6h3l-2-3 2-3h-3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="hotel-details">
                <div class="hotel-name">فندق المدينة المنورة</div>
                <div class="hotel-info">
                  <span class="nights"><%= Math.ceil(card.nights / 2) %> ليالي</span>
                  <span class="location">المدينة المنورة</span>
                  <span class="rating">(3 نجوم)</span>
                </div>
                <div class="meal-info without-meals">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                    <path d="m15 9-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="m9 9 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  بدون وجبات
                </div>
              </div>
            </div>
          <% } %>
        </div>
      </div>
      
      <!-- Pricing Details -->
      <div class="itinerary-card pricing-card">
        <div class="card-header">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="card-title">
            <h3>أسعار الباقة</h3>
            <p>تفاصيل الأسعار حسب نوع الغرفة</p>
          </div>
        </div>
        
        <div class="trip-info">
          <div class="trip-date">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="2"/>
              <line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2"/>
              <line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2"/>
              <line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2"/>
            </svg>
            <span>تاريخ الرحلة: <%= new Date(card.travel_date).toLocaleDateString('ar-EG') %></span>
          </div>
          <div class="trip-duration">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
              <polyline points="12,6 12,12 16,14" stroke="currentColor" stroke-width="2"/>
            </svg>
            <span>مدة الرحلة: <%= card.days %> أيام / <%= card.nights %> ليالي</span>
          </div>
        </div>
        
        <div class="price-list">
          <% if (card.plane && card.plane.housingOptions && card.plane.housingOptions.length > 0) { %>
            <% card.plane.housingOptions.forEach(option => { %>
              <div class="price-item">
                <div class="room-info">
                  <div class="room-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      <polyline points="9,22 9,12 15,12 15,22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <span class="room-type"><%= option.roomType %></span>
                </div>
                <div class="price-info">
                  <span class="price-amount"><%= option.price %></span>
                  <span class="currency">جنيه</span>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="price-item">
              <div class="room-info">
                <div class="room-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <polyline points="9,22 9,12 15,12 15,22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <span class="room-type">غرفة مزدوجة</span>
              </div>
              <div class="price-info">
                <span class="price-amount"><%= card.lowest_price %></span>
                <span class="currency">جنيه</span>
              </div>
            </div>
            <div class="price-item">
              <div class="room-info">
                <div class="room-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <polyline points="9,22 9,12 15,12 15,22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <span class="room-type">غرفة ثلاثية</span>
              </div>
              <div class="price-info">
                <span class="price-amount"><%= Math.floor(card.lowest_price * 0.9) %></span>
                <span class="currency">جنيه</span>
              </div>
            </div>
            <div class="price-item">
              <div class="room-info">
                <div class="room-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <polyline points="9,22 9,12 15,12 15,22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <span class="room-type">غرفة رباعية</span>
              </div>
              <div class="price-info">
                <span class="price-amount"><%= Math.floor(card.lowest_price * 0.8) %></span>
                <span class="currency">جنيه</span>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>
<section id="booking" class="booking-section">
  <div class="container">
    <div class="booking-card">
      <h3>احجز رحلتك الآن</h3>
      <button
        type="button"
        class="ask-chat-btn"
        onclick="window.CardChatWidget && window.CardChatWidget.open('<%= card._id %>')"
      >
        💬 اسأل عن هذه الباقة الآن
      </button>
      <% 
        const now = new Date();
        const expiryDate = card.offer_expiry_date ? new Date(card.offer_expiry_date) : null;
        const isExpired = expiryDate && now > expiryDate;
      %>
      <% if (isExpired) { %>
        <div class="expired-offer">
          <div class="expired-icon">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="#ef4444"/>
            </svg>
          </div>
          <h4>انتهت صلاحية العرض</h4>
          <p>عذراً، لقد انتهت صلاحية هذا العرض في تاريخ <%= expiryDate.toLocaleDateString('ar-EG') %></p>
          <p>يرجى تصفح العروض الأخرى المتاحة أو التواصل معنا للاستفسار عن عروض مشابهة.</p>
          <% 
            const rawWa = (contactSettings && contactSettings.whatsappNumber) ? contactSettings.whatsappNumber : '01225993443';
            const cleaned = (rawWa || '').toString().replace(/\D/g, '');
            const hasCountry = cleaned.startsWith('00') || cleaned.startsWith('2') || cleaned.startsWith('20');
            const waNumber = hasCountry ? cleaned.replace(/^00/, '') : ('2' + cleaned);
            const msg = encodeURIComponent(`مرحبا، أود الاستفسار عن عروض مشابهة للعرض ${card.code} الذي انتهت صلاحيته`);
            const waHref = `https://wa.me/${waNumber}?text=${msg}`;
          %>
          <div style="display:flex; justify-content:center; gap:15px; flex-wrap:wrap; margin-top:20px;">
            <a href="<%= waHref %>" target="_blank" rel="noopener" class="btn" style="background-color:#25D366;color:#fff;display:inline-flex;align-items:center;gap:8px;padding:12px 20px;border-radius:8px;text-decoration:none;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.52 3.48A11.86 11.86 0 0 0 12.06 0C5.49 0 .13 5.36.13 11.93c0 2.1.55 4.16 1.6 5.97L0 24l6.29-1.66a11.86 11.86 0 0 0 5.77 1.49h.01c6.57 0 11.93-5.36 11.93-11.93 0-3.19-1.24-6.2-3.48-8.42ZM12.07 21.3h-.01a9.35 9.35 0 0 1-4.77-1.31l-.34-.2-3.73.99.99-3.64-.22-.37a9.35 9.35 0 0 1-1.42-4.97c0-5.16 4.2-9.36 9.36-9.36 2.5 0 4.85.97 6.62 2.74a9.3 9.3 0 0 1 2.74 6.62c0 5.16-4.2 9.36-9.36 9.36Zm5.15-7.03c-.28-.14-1.66-.82-1.91-.92-.26-.1-.44-.14-.63.14-.18.28-.73.91-.89 1.1-.17.2-.33.21-.61.07-.28-.14-1.19-.44-2.27-1.41-.84-.75-1.41-1.68-1.58-1.96-.16-.28-.02-.43.12-.57.12-.12.28-.33.42-.49.14-.16.19-.28.28-.46.09-.18.05-.35-.02-.49-.07-.14-.63-1.52-.86-2.08-.23-.55-.46-.48-.63-.49-.16-.01-.35-.01-.54-.01s-.49.07-.75.35c-.26.28-1 1-1 2.44 0 1.43 1.02 2.81 1.16 3 .14.19 2 3.06 4.86 4.29.68.29 1.22.46 1.64.59.69.22 1.32.19 1.82.11.56-.08 1.66-.68 1.89-1.33.23-.65.23-1.21.16-1.33-.07-.12-.25-.19-.53-.33Z"/></svg>
              <span>تواصل معنا</span>
            </a>
            <a href="/" class="btn btn-secondary" style="padding:12px 20px;border-radius:8px;text-decoration:none;">تصفح العروض الأخرى</a>
          </div>
        </div>
      <% } else if (user) { %>
        <form class="booking-form" action="/reserve" method="POST">
          <input type="hidden" name="cardId" value="<%= card._id %>">
          <div class="form-grid">
            <div class="form-group">
              <input type="text" id="username" name="username" placeholder="الاسم بالكامل" required value="<%= user.username %>">
            </div>
            <div class="form-group">
              <input type="tel" id="phoneNumber" name="phoneNumber" placeholder="رقم الهاتف" required value="<%= user.phoneNumber %>">
            </div>
            <div class="form-group">
              <input type="number" id="peopleCount" name="peopleCount" placeholder="عدد الأفراد" required min="1">
            </div>
            <div class="form-group">
              <div class="custom-select-wrapper">
                <select id="roomType" name="roomType" required class="custom-select">
                  <option value="">اختر نوع الغرفة</option>
                  <% if (card.plane && card.plane.housingOptions && card.plane.housingOptions.length > 0) { %>
                    <% card.plane.housingOptions.forEach(option => { %>
                      <option value="<%= option.roomType %>" data-price="<%= option.price %>">
                        <%= option.roomType %> - <%= option.price %> 
                        <% if (card.type === 'omrah') { %>جنيه <% } else { %>جنيه مصري<% } %>
                      </option>
                    <% }) %>
                  <% } else { %>
                    <option value="غرفة مزدوجة" data-price="<%= card.lowest_price %>">غرفة مزدوجة - <%= card.lowest_price %> <% if (card.type === 'omrah') { %> جنيه<% } else { %>جنيه مصري<% } %></option>
                    <option value="غرفة ثلاثية" data-price="<%= Math.floor(card.lowest_price * 0.9) %>">غرفة ثلاثية - <%= Math.floor(card.lowest_price * 0.9) %> <% if (card.type === 'omrah') { %>جنيه <% } else { %>جنيه مصري<% } %></option>
                    <option value="غرفة رباعية" data-price="<%= Math.floor(card.lowest_price * 0.8) %>">غرفة رباعية - <%= Math.floor(card.lowest_price * 0.8) %> <% if (card.type === 'omrah') { %>جنيه <% } else { %>جنيه مصري<% } %></option>
                  <% } %>
                </select>
                <div class="select-arrow">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M7 10L12 15L17 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>
            </div>
            <div class="form-group form-group-full">
              <textarea id="note" name="note" placeholder="الملاحظات :"></textarea>
            </div>
            <div class="form-group form-group-full">
              <div class="total-price" id="totalPrice">
                إجمالي التكلفة: <span id="priceAmount">0</span> 
                <% if (card.type === 'omrah') { %>جنيه <% } else { %>جنيه مصري<% } %>
              </div>
            </div>
          </div>
          <div style="display:flex; justify-content:flex-end; gap:20px; align-items:center; flex-wrap:wrap;">
             <% 
              const rawWa = (contactSettings && contactSettings.whatsappNumber) ? contactSettings.whatsappNumber : '01225993443';
              const cleaned = (rawWa || '').toString().replace(/\D/g, '');
              const hasCountry = cleaned.startsWith('00') || cleaned.startsWith('2') || cleaned.startsWith('20');
              const waNumber = hasCountry ? cleaned.replace(/^00/, '') : ('2' + cleaned);
              const msg = encodeURIComponent(`مرحبا، أود الاستفسار عن العرض ${card.code} هل ما زال متاحاً؟`);
              const waHref = `https://wa.me/${waNumber}?text=${msg}`;
            %>
                      <a href="<%= waHref %>" target="_blank" rel="noopener" class="btn " style="background-color:#25D366;color:#fff;display:inline-flex;align-items:center;gap:8px;padding:10px 14px;border-radius:8px;margin:0;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.52 3.48A11.86 11.86 0 0 0 12.06 0C5.49 0 .13 5.36.13 11.93c0 2.1.55 4.16 1.6 5.97L0 24l6.29-1.66a11.86 11.86 0 0 0 5.77 1.49h.01c6.57 0 11.93-5.36 11.93-11.93 0-3.19-1.24-6.2-3.48-8.42ZM12.07 21.3h-.01a9.35 9.35 0 0 1-4.77-1.31l-.34-.2-3.73.99.99-3.64-.22-.37a9.35 9.35 0 0 1-1.42-4.97c0-5.16 4.2-9.36 9.36-9.36 2.5 0 4.85.97 6.62 2.74a9.3 9.3 0 0 1 2.74 6.62c0 5.16-4.2 9.36-9.36 9.36Zm5.15-7.03c-.28-.14-1.66-.82-1.91-.92-.26-.1-.44-.14-.63.14-.18.28-.73.91-.89 1.1-.17.2-.33.21-.61.07-.28-.14-1.19-.44-2.27-1.41-.84-.75-1.41-1.68-1.58-1.96-.16-.28-.02-.43.12-.57.12-.12.28-.33.42-.49.14-.16.19-.28.28-.46.09-.18.05-.35-.02-.49-.07-.14-.63-1.52-.86-2.08-.23-.55-.46-.48-.63-.49-.16-.01-.35-.01-.54-.01s-.49.07-.75.35c-.26.28-1 1-1 2.44 0 1.43 1.02 2.81 1.16 3 .14.19 2 3.06 4.86 4.29.68.29 1.22.46 1.64.59.69.22 1.32.19 1.82.11.56-.08 1.66-.68 1.89-1.33.23-.65.23-1.21.16-1.33-.07-.12-.25-.19-.53-.33Z"/></svg>
              <span>تواصل عبر واتساب</span>
            </a>
            <button type="submit" class="btn submit-btn" style="margin:0;">احجز الان</button>
           
  
          </div>
        </form>
      <% } else { %>
        <div class="login-prompt">
          <p>يجب تسجيل الدخول أولاً لإتمام عملية الحجز</p>
          <a href="/login" class="btn btn-primary">تسجيل الدخول</a>
          <a href="/signup" class="btn btn-secondary">إنشاء حساب جديد</a>
        </div>
      <% } %>
    </div>
  </div>
</section>

<style>
.header-section {
  background: linear-gradient(180deg, #1e5470 29.81%, #5c8397 60.1%, #d3f0f7 100%);
  padding: 20px 0;
  min-height: 120px;
}

.package-details-section {
  padding-top: 40px;
  margin-top: 20px;
}

.package-title {
  font-size: 28px;
  font-weight: 800;
  color: #1e5470;
  margin: 20px 0 12px 0;
  line-height: 1.2;
  font-family: var(--font-tajawal);
}

.gallery {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 15px;
  margin-bottom: 80px;
  position: relative;
  z-index: 5;
}

.main-image {
  width: 100%;
  height: 400px;
  object-fit: cover;
  border-radius: 12px;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
}
@media (max-width:768px) {
  .main-image {
    height: 100% !important;
  }
}
.thumbnail-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.thumbnail-image {
  width: 100%;
  height: 95px;
  object-fit: cover;
  border-radius: 8px;
  cursor: pointer;
  transition: transform 0.3s ease;
}

.thumbnail-image:hover {
  transform: scale(1.05);
}

@media (max-width: 768px) {
  .gallery {
    grid-template-columns: 1fr;
    margin-bottom: 60px;
  }
  
  .main-image {
    height: 250px;
  }
  
  .thumbnail-grid {
    grid-template-columns: repeat(4, 1fr);
  }
  
  .thumbnail-image {
    height: 60px;
  }
  
  .package-info-wrapper {
    margin-top: 40px;
  }
  
  .package-title-card {
    margin-top: 40px;
    padding: 20px;
  }
}

.package-info-wrapper {
  direction: rtl;
  text-align: right;
  margin-bottom: 40px;
  margin-top: 30px;
  position: relative;
  z-index: 1;
  clear: both;
}

.package-title-card {
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
  border: 1px solid #cbd5e1;
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 24px;
  margin-top: 40px;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
  z-index: 1;
}

.package-title-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(135deg, #1e5470 0%, #34729c 100%);
}

.package-title {
  font-size: 28px;
  font-weight: 800;
  color: #1e5470;
  margin: 20px 0 12px 0;
  line-height: 1.2;
  font-family: var(--font-tajawal);
}

.package-code {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 16px;
  color: #64748b;
  font-weight: 500;
}

.package-code span {
  background: linear-gradient(135deg, #1e5470 0%, #34729c 100%);
  color: white;
  padding: 4px 12px;
  border-radius: 6px;
  font-weight: 700;
  font-family: 'Courier New', monospace;
}

.package-info-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 16px;
  margin-bottom: 24px;
}

.info-card {
  background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  padding: 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.info-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(135deg, #5c8397 0%, #34729c 100%);
  opacity: 0;
  transition: all 0.3s ease;
}

.info-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
  border-color: #1e5470;
}

.info-card:hover::before {
  opacity: 1;
}

.info-icon {
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  color: #1e5470;
  padding: 12px;
  border-radius: 10px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.info-card:hover .info-icon {
  background: linear-gradient(135deg, #1e5470 0%, #34729c 100%);
  color: white;
  transform: scale(1.1);
}

.info-content {
  flex: 1;
  min-width: 0;
}

.info-label {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #64748b;
  margin-bottom: 4px;
}

.info-value {
  display: block;
  font-size: 16px;
  font-weight: 700;
  color: #1e5470;
  word-wrap: break-word;
}

.text-danger {
  color: #dc2626 !important;
}

.package-price-card {
  background: linear-gradient(135deg, #1e5470 0%, #34729c 100%);
  color: white;
  border-radius: 16px;
  padding: 24px;
  display: flex;
  align-items: center;
  gap: 20px;
  box-shadow: 0 8px 25px rgba(30, 84, 112, 0.3);
  position: relative;
  overflow: hidden;
}

.package-price-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  transition: all 0.3s ease;
  transform: scale(0);
}

.package-price-card:hover::before {
  transform: scale(1);
}

.price-icon {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12px;
  padding: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.price-content {
  flex: 1;
}

.price-label {
  display: block;
  font-size: 16px;
  font-weight: 500;
  opacity: 0.9;
  margin-bottom: 8px;
}

.price-amount-wrapper {
  display: flex;
  align-items: baseline;
  gap: 8px;
  flex-wrap: wrap;
}

.price-amount {
  font-size: 32px;
  font-weight: 900;
  color: #ffd700;
  font-family: var(--font-tajawal);
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
}

.price-currency {
  font-size: 18px;
  font-weight: 600;
  opacity: 0.9;
}

/* Responsive Design */
@media (max-width: 1024px) {
  .package-info-grid {
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 12px;
  }
  
  .package-title-card {
    padding: 20px;
  }
  
  .package-price-card {
    padding: 20px;
    gap: 16px;
  }
}

@media (max-width: 768px) {
