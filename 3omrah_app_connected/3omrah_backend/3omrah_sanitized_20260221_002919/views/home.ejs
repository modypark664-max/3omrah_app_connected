<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Alexandria:wght@100..900&family=Cairo:wght@200..1000&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Tajawal:wght@200;300;400;500;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="home.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/imgs/logo.png">
    <link rel="shortcut icon" type="image/png" href="/imgs/logo.png">
    <link rel="apple-touch-icon" href="/imgs/logo.png">
    
    <title>رحلة العمره</title>
</head>
<body>

  <%-include("navbar")%>
    <div class="hero-content dynamic-hero">
      <div class="hero-text">
        <h1><%= pageContents.hero_title || 'دعنا نصحبك في رحلة إلى مكة المكرمة، واستمتع بتجربة عمرة مريحة مع باقاتنا المتنوعة وعروضنا المميزة.' %></h1>
        <% 
          const heroDescriptionDefault = 'ابدأ رحلتك إلى مكة المكرمة معنا. استمتع بأفضل الباقات والخدمات المتكاملة التي تجعل رحلتك مريحة وسهلة من البداية وحتى العودة.';
          const heroDescriptionSource = pageContents.hero_description || heroDescriptionDefault;
          const heroDescriptionLines = heroDescriptionSource
            .split(/\r?\n/)
            .map(line => line.trim())
            .filter(line => line.length > 0);
        %>
        <% if (heroDescriptionLines.length > 0) { %>
          <p>
            <% heroDescriptionLines.forEach(function(line, idx) { %>
              <span class="hero-description-line"><%= line %></span><% if (idx !== heroDescriptionLines.length - 1) { %><br><% } %>
            <% }) %>
          </p>
        <% } else { %>
          <p><%= heroDescriptionDefault %></p>
        <% } %>
        <a href="/contact" class="btn btn-primary contact-btn"><%= pageContents.hero_button_text || 'تواصل معنا' %></a>
      </div>
      <% 
        const activeHero = (heroMedia || []).filter(m => m.isActive);
        const mainHero = activeHero.length ? activeHero[0] : null;
        const overlayMedia = activeHero.slice(1); // all remaining media for overlays
      %>
      <div class="hero-visual-wrapper">
        <div class="hero-main-container">
          <% if (mainHero) { %>
            <% if (mainHero.type === 'video') { %>
              <video class="hero-main-video" src="<%= mainHero.url %>" autoplay muted playsinline loop></video>
            <% } else { %>
              <img class="hero-main-image" src="<%= mainHero.url %>" alt="Hero Main"/>
            <% } %>
          <% } else { %>
            <img class="hero-main-image" src="/imgs/Image_Hero.png" alt="Hero Default" />
          <% } %>
          
          <!-- Overlay media items positioned at corners/sides -->
          <% if (overlayMedia && overlayMedia.length) { overlayMedia.forEach((media, idx) => { 
            const positions = ['top-left', 'top-right', 'bottom-left', 'bottom-right', 'center-left', 'center-right'];
            const position = positions[idx] || 'top-left';
          %>
            <div class="hero-overlay-media hero-overlay-<%= position %> hero-overlay-<%= idx+1 %>">
              <% if (media.type === 'video') { %>
                <video class="overlay-video" src="<%= media.url %>" autoplay muted playsinline loop></video>
              <% } else { %>
                <img class="overlay-image" src="<%= media.url %>" alt="Hero Overlay <%= idx+1 %>"/>
              <% } %>
            </div>
          <% }) } %>
          
          <div class="hero-gradient-overlay"></div>
        </div>
      </div>
    </div>
  </div>
<section id="umrah-packages" class="packages-section" style="margin-top: 100px;">
  <div class="container">
    <div class="packages-header">
      <div class="packages-header-text">
        <h2 class="section-title"><%= (sectionContents && sectionContents.omrah ? sectionContents.omrah.title : (pageContents.omrah_title || 'باقات العمرة')) %></h2>
        <p class="section-subtitle"><%= (sectionContents && sectionContents.omrah ? sectionContents.omrah.description : (pageContents.omrah_description || 'معنا رحلة العمرة أصبحت أسهل وأكثر راحة، حيث نوفر لك باقات متنوعة تناسب جميع الاحتياجات والميزانيات')) %></p>
      </div>
      <a href="/bundles" class="btn-outline"><%= pageContents.omrah_button_text || pageContents.view_more_text || 'عرض المزيد' %></a>
    </div>
    <div class="packages-grid">
      <% if (omrahCards && omrahCards.length > 0) { %>
        <% omrahCards.forEach(card => { %>
          <%- include('partials/package-card', { card: card, user: user }) %>
        <% }) %>
      <% } else { %>
        <article class="package-card">
          <img src="/imgs/Rectangle 33.png" alt="Package Image" class="package-image">
          <div class="package-content">
            <div class="package-info-header">
              <div class="package-duration">
                <img src="/imgs/calendar.svg" alt="calendar icon">
                <span><%= pageContents.coming_soon_text || 'قريباً' %></span>
              </div>
            </div>
            <h3><%= pageContents.omrah_no_packages_title || 'لا توجد باقات عمرة متاحة حالياً' %></h3>
            <p><%= pageContents.omrah_no_packages_description || 'نحن نعمل على إضافة باقات عمرة مميزة قريباً. تابعونا للحصول على أفضل العروض والباقات المتاحة.' %></p>
            <div class="package-price">
              <span><%= pageContents.coming_soon_text || 'قريباً' %></span>
            </div>
            <div class="package-actions">
              <a href="/contact" class="package-details-link">
                <span><%= pageContents.contact_us_text || 'تواصل معنا' %></span>
                <div class="arrow-circle">
                  <img src="/imgs/Frame 94.png" alt="arrow icon">
                </div>
              </a>
            </div>
          </div>
        </article>
      <% } %>
    </div>
  </div>
</section>
<section id="partner-banner" class="partner-banner-section" <% if (partnerBanner && partnerBanner.backgroundImage) { %>style="background-image: url('<%= partnerBanner.backgroundImage %>'); background-size: cover; background-position: center; background-repeat: no-repeat;"<% } %>>
