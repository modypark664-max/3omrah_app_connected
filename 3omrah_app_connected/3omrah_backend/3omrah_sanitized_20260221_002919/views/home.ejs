<section id="testimonials" class="testimonials-section">
  <div class="container">
    <!-- Testimonials Header -->
    <div class="testimonials-header">
      <h2><%= pageContents.testimonials_title || 'آراء العملاء عن <br>تجربتهم معنا' %></h2>
      <p><%= pageContents.testimonials_description || 'استمع إلى قصص معتمرينا وحجاجنا الكرام، وتعرّف كيف ساعدتهم خدماتنا المتميزة في عيش تجربة روحية مريحة ومتكاملة، من التخطيط وحتى أداء المناسك بكل طمأنينة.' %></p>
    </div>
    
    <!-- Testimonials Carousel -->
    <div class="testimonials-carousel-wrapper">
      <% if (testimonialsReviews && testimonialsReviews.length > 0) { %>
        <div class="testimonials-carousel" id="testimonials-carousel">
          <div class="testimonials-track" id="testimonials-track">
            <% testimonialsReviews.forEach(function(review, index) { %>
              <div class="testimonial-slide">
                <div class="testimonial-card">
                  <div class="testimonial-card-bg"></div>
                  <div class="testimonial-content">
                    <div class="testimonial-user">
                      <h4><%= review.name %></h4>
                      <div class="testimonial-stars">
                        <% for(let i = 1; i <= 5; i++) { %>
                          <% if(i <= review.rating) { %>
                            <img src="/imgs/star.png" alt="star">
                          <% } else { %>
                            <img src="/imgs/star.png" alt="star" style="opacity: 0.3;">
                          <% } %>
                        <% } %>
                      </div>
                    </div>
                    <p>"<%= review.text %>"</p>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
        
        <!-- Carousel Navigation -->
        <div class="testimonials-navigation">
          <button class="carousel-btn prev-btn" id="prev-testimonial" aria-label="Previous testimonial">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="15,18 9,12 15,6"></polyline>
            </svg>
          </button>
          
          <div class="carousel-dots" id="testimonials-dots">
            <% for(let i = 0; i < testimonialsReviews.length; i++) { %>
              <button class="dot <%= i === 0 ? 'active' : '' %>" data-slide="<%= i %>"></button>
            <% } %>
          </div>
          
          <button class="carousel-btn next-btn" id="next-testimonial" aria-label="Next testimonial">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9,18 15,12 9,6"></polyline>
            </svg>
          </button>
        </div>
      <% } else { %>
        <!-- Fallback testimonial when no reviews exist -->
        <div class="testimonials-carousel">
          <div class="testimonials-track">
            <div class="testimonial-slide">
              <div class="testimonial-card">
                <div class="testimonial-card-bg"></div>
                <div class="testimonial-content">
                  <div class="testimonial-user">
                    <h4><%= pageContents.testimonial_user_name || 'مصطفى حامد' %></h4>
                    <div class="testimonial-stars">
                      <img src="/imgs/star.png" alt="star">
                      <img src="/imgs/star.png" alt="star">
                      <img src="/imgs/star.png" alt="star">
                      <img src="/imgs/star.png" alt="star">
                      <img src="/imgs/star.png" alt="star">
                    </div>
                  </div>
                  <p>"<%= pageContents.testimonial_text || 'أكثر ما أعجبني هو اهتمامهم بأدق التفاصيل، حتى الاستقبال في المطار كان بابتسامة. شعرت أنني مع عائلتي طوال الرحلة.' %>"</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>




<section id="about" class="about-section">
  <div class="container about-container">
    <div class="about-text">
      <h2><%= pageContents.about_title || 'من نحن ؟' %></h2>
      <p><%= pageContents.about_description || 'منصة متخصصة في تقديم باقات العمرة الشاملة، تغطي جميع تفاصيل الرحلة — من ترتيبات السفر وحتى الإقامة في أفخم فنادق مكة المكرمة والمدينة المنورة — لضمان راحة ورضا كل معتمر. مهمتنا تتجاوز الباقات التقليدية، فنحن نصنع تجارب روحانية شخصية تبقى خالدة في الذاكرة، وبأسعار تناسب الجميع. وبالاعتماد على أحدث الحلول الرقمية، نجعل رحلتك أكثر سلاسة وراحة واتصالًا، منذ لحظة الحجز وحتى العودة. "رحلتعمرة" – دعنا نأخذك هناك، ونحوّل كل خطوة إلى ذكرى مضيئة ترافقك مدى الحياة.' %></p>
      <a href="#" class="btn-read-more"><%= pageContents.about_button_text || 'اقرأ المزيد' %></a>
    </div>
    <!--merged image-->
    <div class="about-image-wrapper">
      <img src="<%= (typeof aboutImageUrl !== 'undefined' && aboutImageUrl) ? aboutImageUrl : '/imgs/Image_1.png' %>" alt="Airplane in the sky" class="about-main-image">
    </div>
  </div>
</section>
<%-include("footer")%>

<%- include('bottom_app_navbar') %>

<script src="/js/card-interactions.js"></script>
<script>
  // Define user variable for card-interactions.js
  const user = <%- JSON.stringify(user) %>
  
  // Simple testimonials carousel with dots
  (function(){
    var track = document.getElementById('testimonials-track');
    if (!track) return;
    
    var slides = track.querySelectorAll('.testimonial-slide');
    var total = slides.length;
    if (total <= 1) return; // No need for carousel with single slide
    
    var index = 0;
    var dots = document.querySelectorAll('#testimonials-dots .dot');
    var prevBtn = document.getElementById('prev-testimonial');
    var nextBtn = document.getElementById('next-testimonial');
    
    function updateCarousel(){
      // Move track
      track.style.transform = 'translateX(' + (-index * 100) + '%)';
      
      // Update dots
      dots.forEach(function(dot, i) {
        dot.classList.toggle('active', i === index);
      });
    }
    
    function goToSlide(slideIndex) {
      index = slideIndex;
      updateCarousel();
    }
    
    function nextSlide() {
      index = (index + 1) % total;
      updateCarousel();
    }
    
    function prevSlide() {
      index = (index - 1 + total) % total;
      updateCarousel();
    }
    
    // Event listeners
    if (prevBtn) prevBtn.addEventListener('click', prevSlide);
    if (nextBtn) nextBtn.addEventListener('click', nextSlide);
    
    // Dot navigation
    dots.forEach(function(dot, i) {
      dot.addEventListener('click', function() {
        goToSlide(i);
      });
    });
    
    // Auto-advance every 5 seconds
    setInterval(nextSlide, 5000);
    
    // Touch/swipe support for mobile
    var startX = 0;
    var currentX = 0;
    var isDragging = false;
    
    track.addEventListener('touchstart', function(e) {
      startX = e.touches[0].clientX;
      isDragging = true;
    });
    
    track.addEventListener('touchmove', function(e) {
      if (!isDragging) return;
      currentX = e.touches[0].clientX;
      var diffX = startX - currentX;
      
      // Add some resistance
      if (Math.abs(diffX) > 50) {
        if (diffX > 0) {
          nextSlide();
        } else {
          prevSlide();
        }
        isDragging = false;
      }
    });
    
    track.addEventListener('touchend', function() {
      isDragging = false;
    });
    
    // Initialize
    updateCarousel();
  })();
</script>

</body>
</html>