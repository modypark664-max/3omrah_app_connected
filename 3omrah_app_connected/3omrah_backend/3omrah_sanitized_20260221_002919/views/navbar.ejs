<%
  const currentUser = typeof user !== 'undefined' ? user : null;
  const adminPermissions = currentUser && Array.isArray(currentUser.permissions) ? currentUser.permissions : [];
  const normalizedRole = currentUser && typeof currentUser.role === 'string' ? currentUser.role.toLowerCase() : '';
  const hasExplicitFullAdminAccess = adminPermissions.includes('full_admin_access');
  const hasImplicitFullAdminAccess = normalizedRole === 'admin' && adminPermissions.length === 0;
  const adminHasFullAccess = hasExplicitFullAdminAccess || hasImplicitFullAdminAccess;
  const hasDelegatedAdminPermissions = adminPermissions.length > 0;
  const canSeeFullAdminDashboard = Boolean(currentUser && adminHasFullAccess);
  const canSeeSimplifiedAdminDashboard = Boolean(currentUser && (adminHasFullAccess || hasDelegatedAdminPermissions || normalizedRole === 'admin'));
  const showLimitedAdminShortcuts = normalizedRole === 'admin' && !adminHasFullAccess && hasDelegatedAdminPermissions;
%>
<section id="header-hero" class="header-hero-section" data-current-user='<%- JSON.stringify(user || null).replace(/"/g, '&quot;') %>'>
  <div class="nav-container">
    <header class="main-header">
      <div class="logo">
        <a href="/">
          <img src="/imgs/logo.png" alt="">
        </a>
      </div>
      
      <!-- Hamburger Menu Button -->
      <button class="hamburger-menu" aria-label="Toggle navigation" aria-expanded="false">
      <svg fill="gold" width="64px" height="64px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke="gold"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"><path d="M2,4A1,1,0,0,1,3,3H21a1,1,0,0,1,0,2H3A1,1,0,0,1,2,4Zm1,9H21a1,1,0,0,0,0-2H3a1,1,0,0,0,0,2Zm0,8H21a1,1,0,0,0,0-2H3a1,1,0,0,0,0,2Z"></path></g></svg>
      </button>
      
      <nav class="main-nav">
        <ul>
          <li><a href="/" class="<%= (typeof currentRoute !== 'undefined' && currentRoute === '/') ? 'active' : '' %>">الرئيسية</a></li>
          <li><a href="/bundles" class="<%= (typeof currentRoute !== 'undefined' && currentRoute === '/bundles') ? 'active' : '' %>">باقات العمرة</a></li>
          <li><a href="/7ag-tours" class="<%= (typeof currentRoute !== 'undefined' && currentRoute === '/7ag-tours') ? 'active' : '' %>">رحلات الحج</a></li>
          <li><a href="/ramadan-tours" class="<%= (typeof currentRoute !== 'undefined' && currentRoute === '/ramadan-tours') ? 'active' : '' %>">رحلات رمضان</a></li>
          <li><a href="/inner-tours" class="<%= (typeof currentRoute !== 'undefined' && currentRoute === '/inner-tours') ? 'active' : '' %>">رحلات داخلية</a></li>
          <li><a href="/external-tours" class="<%= (typeof currentRoute !== 'undefined' && currentRoute === '/external-tours') ? 'active' : '' %>">رحلات خارجية</a></li>
          <li><a href="/contact" class="<%= (typeof currentRoute !== 'undefined' && currentRoute === '/contact') ? 'active' : '' %>">تواصل</a></li>
          <li><a href="<%= privacyPolicyUrl || '/privacy' %>" class="<%= (typeof currentRoute !== 'undefined' && currentRoute === '/privacy') ? 'active' : '' %>">سياسة الخصوصية</a></li>
          <% if (!user) { %>
          <li><a href="/partner" class="<%= (typeof currentRoute !== 'undefined' && currentRoute === '/partner') ? 'active' : '' %>">شريك سياحي</a></li>
          <% } %>
          <% if (typeof user !== 'undefined' && user) { %>
          <li><a href="/profile" class="<%= (typeof currentRoute !== 'undefined' && currentRoute === '/profile') ? 'active' : '' %>">الملف الشخصي</a></li>
          <% } %>
          <!-- Login/Profile button for mobile -->
          <% if (typeof user !== 'undefined' && user) { %>
          <li class="mobile-only"><a href="/logout" class="logout-link">تسجيل الخروج</a></li>
          <% } else { %>
          <li class="mobile-only"><a href="/login" class="btn btn-primary login-btn-mobile">تسجيل الدخول</a></li>
          <% } %>
        </ul>
      </nav>
      
      <% if (user) { %>
      <div class="user-menu">
        <div class="user-info">
          <span class="username">مرحباً، <%= user.username %></span>
          <div class="user-dropdown">
            <a href="/profile">الملف الشخصي</a>
            <% if (normalizedRole === 'partner') { %>
            <a href="/partner-dashboard">لوحة تحكم الشريك</a>
            <% } %>
            <% if (canSeeFullAdminDashboard) { %>
            <a href="/admin/dashboard">لوحة التحكم الكاملة</a>
            <% } %>
            <% if (canSeeSimplifiedAdminDashboard) { %>
            <a href="/admin/access">لوحة التحكم المبسطة</a>
            <% } %>
            <% if (showLimitedAdminShortcuts) { %>
                <% if (adminPermissions.some(p => ['add_card', 'edit_card', 'delete_card', 'approve_card', 'view_all_cards'].includes(p))) { %>
                <a href="/admin/access#cards">إدارة البطاقات</a>
                <% } %>
                <% if (adminPermissions.some(p => ['view_users', 'edit_users', 'delete_users', 'manage_user_permissions'].includes(p))) { %>
                <a href="/admin/access#users">إدارة المستخدمين</a>
                <% } %>
                <% if (adminPermissions.some(p => ['view_partners', 'verify_partners', 'suspend_partners'].includes(p))) { %>
                <a href="/admin/access#partners">إدارة الشركاء</a>
                <% } %>
                <% if (adminPermissions.some(p => ['view_reservations', 'verify_payments', 'cancel_payments'].includes(p))) { %>
                <a href="/admin/access#reservations">إدارة الحجوزات</a>
                <% } %>
                <% if (adminPermissions.some(p => ['manage_banners', 'manage_hero_media', 'manage_section_content', 'manage_page_content'].includes(p))) { %>
                <a href="/admin/access#content">إدارة المحتوى</a>
                <% } %>
            <% } %>
            <a href="/logout">تسجيل الخروج</a>
          </div>
        </div>
      </div>
      <% } else { %>
      <a href="/login" class="btn btn-primary login-btn">تسجيل الدخول</a>
      <% } %>
    </header>

<script>
  (function hydrateAppUser(){
    if (typeof window === 'undefined') return;
    if (window.__appUser) return;
    var headerEl = document.querySelector('[data-current-user]');
    if (!headerEl) return;
    var payload = headerEl.getAttribute('data-current-user');
    if (!payload) {
      window.__appUser = null;
      return;
    }
    try {
  window.__appUser = JSON.parse(payload.replace(/&quot;/g, '"'));
    } catch (err) {
      window.__appUser = null;
    }
  })();
</script>

