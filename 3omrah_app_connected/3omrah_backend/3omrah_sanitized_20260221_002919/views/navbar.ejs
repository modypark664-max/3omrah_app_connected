<script>
// Hamburger menu functionality
document.addEventListener('DOMContentLoaded', function() {
  const hamburger = document.querySelector('.hamburger-menu');
  const nav = document.querySelector('.main-nav');
  
  // Fix navbar link ordering based on current page
  const navUl = document.querySelector('.main-nav ul');
  const currentPath = window.location.pathname;
  
  if (navUl) {
    // Check if we're on mobile (window width <= 768px)
    const isMobile = window.innerWidth <= 768;
    
    if (isMobile) {
      // On mobile, keep the column direction set by CSS
      navUl.style.removeProperty('flex-direction');
    } else {
      // On desktop, force row direction
      navUl.style.setProperty('flex-direction', 'row', 'important');
    }
    
    // If we're on specific pages, reverse the order to counteract the CSS
    if (currentPath === '/' || currentPath === '/profile' || currentPath === "/partner" || currentPath === "/partner-dashboard"||currentPath.startsWith('/card/') ) {
      const listItems = Array.from(navUl.children);
      // Filter out mobile-only items for desktop ordering calculation
      const mainNavItems = listItems.filter(item => !item.classList.contains('mobile-only'));
      
      if (isMobile) {
        // On mobile for reversed pages, use normal order (1, 2, 3, 4, 5, 6, 7)
        // This creates a reversed column effect when combined with flex-direction: column
        listItems.forEach((item, index) => {
          item.style.setProperty('order', (index + 1).toString(), 'important');
        });
      } else {
        // On desktop for reversed pages, use reversed order
        // Reset all items first
        listItems.forEach(item => {
          item.style.removeProperty('order');
        });
        
        // Apply reverse order to main navigation items only
        mainNavItems.forEach((item, index) => {
          item.style.setProperty('order', (mainNavItems.length - index).toString(), 'important');
        });
        
        // Keep mobile-only items at the end with high order values
        listItems.filter(item => item.classList.contains('mobile-only')).forEach((item, index) => {
          item.style.setProperty('order', (mainNavItems.length + index + 1).toString(), 'important');
        });
      }
    } else {
      // For all other pages, use normal order (both desktop and mobile)
      const listItems = Array.from(navUl.children);
      listItems.forEach((item, index) => {
        item.style.setProperty('order', (index + 1).toString(), 'important');
      });
    }
  }
  
  if (hamburger) {
    hamburger.addEventListener('click', function() {
      const isExpanded = hamburger.getAttribute('aria-expanded') === 'true';
      
      hamburger.setAttribute('aria-expanded', !isExpanded);
      hamburger.classList.toggle('active');
      nav.classList.toggle('active');
    });
  }
  
  // Close menu when clicking on nav links
  const navLinks = document.querySelectorAll('.main-nav a');
  navLinks.forEach(link => {
    link.addEventListener('click', function() {
      if (hamburger) {
        hamburger.classList.remove('active');
        nav.classList.remove('active');
        hamburger.setAttribute('aria-expanded', 'false');
      }
    });
  });
  
  // Close menu when clicking outside
  document.addEventListener('click', function(e) {
    if (hamburger && nav && !hamburger.contains(e.target) && !nav.contains(e.target)) {
      hamburger.classList.remove('active');
      nav.classList.remove('active');
      hamburger.setAttribute('aria-expanded', 'false');
    }
  });

  // Handle window resize to adjust navbar layout
  window.addEventListener('resize', function() {
    if (navUl) {
      const isMobile = window.innerWidth <= 768;
      
      if (isMobile) {
        // On mobile, remove the forced row direction to allow CSS column
        navUl.style.removeProperty('flex-direction');
      } else {
        // On desktop, force row direction
        navUl.style.setProperty('flex-direction', 'row', 'important');
        
        // Close mobile menu if it's open
        if (hamburger && nav) {
          hamburger.classList.remove('active');
          nav.classList.remove('active');
          hamburger.setAttribute('aria-expanded', 'false');
        }
      }
      
      // Reapply ordering logic after resize
      if (currentPath === '/' || currentPath === '/profile' || currentPath.startsWith('/card/') || currentPath === '/7ag-tours' || currentPath === '/ramadan-tours' || currentPath === '/bundles' || currentPath === "/partner") {
        const listItems = Array.from(navUl.children);
        const mainNavItems = listItems.filter(item => !item.classList.contains('mobile-only'));
        
        if (isMobile) {
          // On mobile for reversed pages, use normal order
          listItems.forEach((item, index) => {
            item.style.setProperty('order', (index + 1).toString(), 'important');
          });
        } else {
          // On desktop for reversed pages, use reversed order
          // Reset all items first
          listItems.forEach(item => {
            item.style.removeProperty('order');
          });
          
          // Apply reverse order to main navigation items only
          mainNavItems.forEach((item, index) => {
            item.style.setProperty('order', (mainNavItems.length - index).toString(), 'important');
          });
          
          // Keep mobile-only items at the end with high order values
          listItems.filter(item => item.classList.contains('mobile-only')).forEach((item, index) => {
            item.style.setProperty('order', (mainNavItems.length + index + 1).toString(), 'important');
          });
        }
      } else {
        // For all other pages, use normal order
        const listItems = Array.from(navUl.children);
        listItems.forEach((item, index) => {
          item.style.setProperty('order', (index + 1).toString(), 'important');
        });
      }
    }
  });
});

// Sticky navbar scroll handling (adjusted for dynamic spacer)
document.addEventListener('DOMContentLoaded', function(){
  const header = document.querySelector('.main-header');
  if(!header) return;
  let spacer = document.getElementById('header-spacer');
  if(!spacer){
    spacer = document.createElement('div');
    spacer.id = 'header-spacer';
    document.body.classList.add('has-sticky-nav');
    document.body.prepend(spacer);
  }
  function setSpacer(){
    const h = header.offsetHeight;
    spacer.style.height = h + 'px';
    document.documentElement.style.setProperty('--header-height', h + 'px');
  }
  const resizeObserver = new ResizeObserver(setSpacer);
  resizeObserver.observe(header);
  window.addEventListener('resize', setSpacer);
  setSpacer();
  const toggleScrolled = () => {
    if(window.scrollY > 20){
      if(!header.classList.contains('nav-scrolled')){ header.classList.add('nav-scrolled'); setSpacer(); }
    } else {
      if(header.classList.contains('nav-scrolled')){ header.classList.remove('nav-scrolled'); setSpacer(); }
    }
  };
  toggleScrolled();
  window.addEventListener('scroll', toggleScrolled, { passive: true });
});
</script>