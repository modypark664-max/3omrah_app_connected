<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/imgs/logo.png">
    <link rel="shortcut icon" type="image/png" href="/imgs/logo.png">
    <link rel="apple-touch-icon" href="/imgs/logo.png">
    
    <title>إنشاء حساب جديد - منصة العمرة</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #34729C 0%, #1E5470 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        
        .signup-container {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            padding: 40px;
            width: 100%;
            max-width: 500px;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        
        .logo-section {
            text-align: center;
            margin-bottom: 30px;
        }
        
        .logo {
            font-size: 2.5rem;
            color: #1E5470;
            font-weight: bold;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
        }
        
        .subtitle {
            color: #34729C;
            font-size: 1.1rem;
            margin-bottom: 30px;
        }
        
        h1 {
            text-align: center;
            color: #1E5470;
            margin-bottom: 30px;
            font-size: 1.8rem;
            font-weight: 600;
        }
        
        .form-group {
            margin-bottom: 25px;
            position: relative;
        }
        
        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #1E5470;
            font-size: 1rem;
        }
        
        input[type="text"], input[type="tel"], input[type="password"] {
            width: 100%;
            padding: 15px 20px;
            border: 2px solid #e1e8ed;
            border-radius: 12px;
            font-size: 16px;
            transition: all 0.3s ease;
            background: #f8f9fa;
            direction: ltr;
            text-align: right;
        }
        
        input[type="text"] {
            direction: rtl;
        }
        
        input:focus {
            outline: none;
            border-color: #34729C;
            background: white;
            box-shadow: 0 0 0 3px rgba(52, 114, 156, 0.1);
            transform: translateY(-2px);
        }
        
        input::placeholder {
            color: #9ca3af;
            text-align: right;
        }
        
        .btn-signup {
            background: linear-gradient(135deg, #34729C 0%, #1E5470 100%);
            color: white;
            padding: 15px 30px;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            width: 100%;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(52, 114, 156, 0.3);
        }
        
        .btn-signup:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(52, 114, 156, 0.4);
        }
        
        .btn-signup:active {
            transform: translateY(-1px);
        }
        
        .link-section {
            text-align: center;
            margin-top: 25px;
            padding-top: 20px;
            border-top: 1px solid #e1e8ed;
        }
        
        .link-section a {
            color: #34729C;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s ease;
        }
        
        .link-section a:hover {
            color: #1E5470;
            text-decoration: underline;
        }
        
        .alert {
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 20px;
            font-weight: 500;
        }
        
        .alert-error {
            background: #fee2e2;
            border: 1px solid #fecaca;
            color: #dc2626;
        }
        
        .alert-success {
            background: #d1fae5;
            border: 1px solid #a7f3d0;
            color: #059669;
        }
        
        .help-text {
            font-size: 12px;
            color: #6b7280;
            margin-top: 5px;
            line-height: 1.4;
        }
        
        .input-icon {
            position: absolute;
            left: 15px;
            top: 56px;
            color: #9ca3af;
            font-size: 1.2rem;
            pointer-events: none;
        }
        
        .form-group.has-icon input {
            padding-left: 50px;
        }
        
        @media (max-width: 480px) {
            .signup-container {
                padding: 30px 20px;
                margin: 10px;
            }
            
            .logo {
                font-size: 2rem;
            }
            
            h1 {
                font-size: 1.5rem;
            }
        }
        
        .decorative-element {
            position: absolute;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: linear-gradient(135deg, #34729C, #1E5470);
            opacity: 0.1;
        }
        
        .decorative-element:first-child {
            top: -50px;
            right: -50px;
        }
        
        .decorative-element:last-child {
            bottom: -50px;
            left: -50px;
        }
        
        /* Password Strength Indicator Styles */
        .password-strength {
            margin-top: 10px;
            padding: 15px;
            background: #f8f9fa;
            border-radius: 8px;
            border: 1px solid #e1e8ed;
        }
        
        .strength-bar {
            width: 100%;
            height: 6px;
            background: #e1e8ed;
            border-radius: 3px;
            overflow: hidden;
            margin-bottom: 8px;
        }
        
        .strength-progress {
            height: 100%;
            width: 0%;
            transition: all 0.3s ease;
            border-radius: 3px;
        }
        
        .strength-progress.weak {
            width: 25%;
            background: #ef4444;
        }
        
        .strength-progress.fair {
            width: 50%;
            background: #f59e0b;
        }
        
        .strength-progress.good {
            width: 75%;
            background: #3b82f6;
        }
        
        .strength-progress.strong {
            width: 100%;
            background: #10b981;
        }
        
        .strength-text {
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 8px;
            text-align: center;
        }
        
        .strength-text.weak {
            color: #ef4444;
        }
        
        .strength-text.fair {
            color: #f59e0b;
        }
        
        .strength-text.good {
            color: #3b82f6;
        }
        
        .strength-text.strong {
            color: #10b981;
        }
        
        .strength-requirements {
            display: grid;
            gap: 4px;
        }
        
        .requirement {
            font-size: 12px;
            color: #6b7280;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        
        .requirement.met {
            color: #10b981;
        }
        
        .requirement.met::before {
            content: "✓";
            color: #10b981;
        }
        
        .requirement:not(.met)::before {
            content: "✗";
            color: #ef4444;
        }
    </style>
</head>
<body>
    <div class="decorative-element"></div>
    <div class="decorative-element"></div>
    
    <div class="signup-container">
        <div class="logo-section">
            <div class="logo">🕋</div>
            <div class="subtitle">منصة العمرة والسياحة</div>
        </div>
        
        <h1>إنشاء حساب جديد</h1>
        
        <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
            <div class="alert alert-error"><%= error_msg %></div>
        <% } %>
        
        <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success"><%= success_msg %></div>
        <% } %>
        
        <form action="/signup" method="POST">
            <div class="form-group has-icon">
                <label for="username">اسم المستخدم:</label>
                <input type="text" name="username" id="username" required placeholder="أدخل اسم المستخدم">
                <span class="input-icon">👤</span>
                <div class="help-text">يجب أن يكون 3-30 حرف، يمكن أن يحتوي على العربية والإنجليزية والأرقام</div>
            </div>

            <div class="form-group has-icon">
                <label for="phoneNumber">رقم الهاتف:</label>
                <input type="tel" name="phoneNumber" id="phoneNumber" required placeholder="رقم الهاتف" dir="ltr">
                <span class="input-icon">📱</span>
            </div>

            <div class="form-group has-icon">
                <label for="password">كلمة المرور:</label>
                <input type="password" name="password" id="password" required placeholder="••••••••" minlength="8">
                <span class="input-icon">🔒</span>
                <div id="passwordStrengthSignup" class="password-strength" style="display: none;">
                    <div class="strength-bar">
                        <div class="strength-progress" id="strengthProgressSignup"></div>
                    </div>
                    <div class="strength-text" id="strengthTextSignup">ضعيف</div>
                    <div class="strength-requirements">
                        <div class="requirement" id="lengthReqSignup">✗ 8 أحرف على الأقل</div>
                        <div class="requirement" id="upperReqSignup">✗ حرف كبير واحد على الأقل</div>
                        <div class="requirement" id="lowerReqSignup">✗ حرف صغير واحد على الأقل</div>
                        <div class="requirement" id="numberReqSignup">✗ رقم واحد على الأقل</div>
                        <div class="requirement" id="specialReqSignup">✗ رمز خاص واحد على الأقل (!@#$%^&*)</div>
                    </div>
                </div>
                <div class="help-text">يجب أن تكون كلمة مرور قوية وآمنة</div>
            </div>

            <div class="form-group has-icon">
                <label for="confirmPassword">تأكيد كلمة المرور:</label>
                <input type="password" name="confirmPassword" id="confirmPassword" required placeholder="••••••••" minlength="8">
                <span class="input-icon">🔓</span>
                <div class="help-text">أدخل كلمة المرور مرة أخرى للتأكيد</div>
            </div>

            <button type="submit" class="btn-signup">إنشاء الحساب</button>
        </form>
        
        <div class="link-section">
            <a href="/login">لديك حساب؟ سجل الدخول</a>
            <br><br>
            <a href="/partner">هل أنت شركة سياحة؟ انضم كشريك سياحي</a>
        </div>
    </div>

    <script>
        // Wait for DOM to be fully loaded
        document.addEventListener('DOMContentLoaded', function() {
            // Password strength checking function
            function checkPasswordStrength(password) {
                let score = 0;
                const requirements = {
                    length: password.length >= 8,
                    upper: /[A-Z]/.test(password),
                    lower: /[a-z]/.test(password),
                    number: /[0-9]/.test(password),
                    special: /[!@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]/.test(password)
                };
                
                // Calculate score
                Object.values(requirements).forEach(met => {
                    if (met) score++;
                });
                
                // Determine strength level
                let strength = 'weak';
                if (score >= 5) strength = 'strong';
                else if (score >= 4) strength = 'good';
                else if (score >= 2) strength = 'fair';
                
                return { score, strength, requirements };
            }
            
            // Update password strength UI
            function updatePasswordStrengthUI(password) {
                const strengthContainer = document.getElementById('passwordStrengthSignup');
                const strengthProgress = document.getElementById('strengthProgressSignup');
                const strengthText = document.getElementById('strengthTextSignup');
                
                if (password.length === 0) {
                    strengthContainer.style.display = 'none';
                    return;
                }
                
                strengthContainer.style.display = 'block';
                const { strength, requirements } = checkPasswordStrength(password);
                
                // Update progress bar
                strengthProgress.className = `strength-progress ${strength}`;
                
                // Update strength text
                const strengthTexts = {
                    weak: 'ضعيف',
                    fair: 'مقبول',
                    good: 'جيد',
                    strong: 'قوي'
                };
                strengthText.textContent = strengthTexts[strength];
                strengthText.className = `strength-text ${strength}`;
                
                // Update requirements
                const reqElements = {
                    length: document.getElementById('lengthReqSignup'),
                    upper: document.getElementById('upperReqSignup'),
                    lower: document.getElementById('lowerReqSignup'),
                    number: document.getElementById('numberReqSignup'),
                    special: document.getElementById('specialReqSignup')
                };
                
                Object.keys(requirements).forEach(key => {
                    const element = reqElements[key];
                    if (element) {
                        element.className = requirements[key] ? 'requirement met' : 'requirement';
                        // Update text content to remove the ✗ or ✓ prefix since CSS handles it
                        const texts = {
                            length: '8 أحرف على الأقل',
                            upper: 'حرف كبير واحد على الأقل',
                            lower: 'حرف صغير واحد على الأقل',
                            number: 'رقم واحد على الأقل',
                            special: 'رمز خاص واحد على الأقل (!@#$%^&*)'
                        };
                        element.textContent = texts[key];
                    }
                });
            }
            
            // Password strength checking
            const passwordInput = document.getElementById('password');
            passwordInput.addEventListener('input', function() {
                updatePasswordStrengthUI(this.value);
            });
            
            // Password confirmation validation
            const confirmPasswordInput = document.getElementById('confirmPassword');
            
            function validatePasswordMatch() {
                const password = passwordInput.value;
                const confirmPassword = confirmPasswordInput.value;
                
                if (confirmPassword.length === 0) {
                    confirmPasswordInput.setCustomValidity('');
                    confirmPasswordInput.style.borderColor = '#e1e8ed';
                    return;
                }
                
                if (password !== confirmPassword) {
                    confirmPasswordInput.setCustomValidity('كلمات المرور غير متطابقة');
                    confirmPasswordInput.style.borderColor = '#ef4444';
                } else {
                    confirmPasswordInput.setCustomValidity('');
                    confirmPasswordInput.style.borderColor = '#10b981';
                }
            }
            
            confirmPasswordInput.addEventListener('input', validatePasswordMatch);
            passwordInput.addEventListener('input', validatePasswordMatch);
        
        // Enhanced phone number formatting
        const phoneInput = document.getElementById('phoneNumber');
        
        phoneInput.addEventListener('input', function() {
            let value = this.value.replace(/\D/g, '');
            
            // Remove country code if present
            if (value.startsWith('966')) {
                value = value.substring(3);
            }
            
            // Limit to exactly 11 digits
            if (value.length > 11) {
                value = value.substring(0, 11);
            }
            
            this.value = value;
            
            // Validate phone number format (must be exactly 11 digits)
            if (value.length === 11) {
                this.style.borderColor = '#10b981';
            } else if (value.length > 0) {
                this.style.borderColor = '#ef4444';
            } else {
                this.style.borderColor = '#e1e8ed';
            }
        });
        
                // Enhanced form submission validation
        document.querySelector('form').addEventListener('submit', function(e) {
            const password = passwordInput.value;
            const confirmPassword = confirmPasswordInput.value;
            
            // Check password match
            if (password !== confirmPassword) {
                e.preventDefault();
                alert('كلمات المرور غير متطابقة.');
                confirmPasswordInput.focus();
                return false;
            }
            
            // Check password strength requirements
            const { requirements, score } = checkPasswordStrength(password);
            
            if (password.length < 8) {
                e.preventDefault();
                alert('كلمة المرور يجب أن تكون 8 أحرف على الأقل.');
                passwordInput.focus();
                return false;
            }
            
            if (score < 3) {
                e.preventDefault();
                alert('كلمة المرور ضعيفة جداً. يرجى استخدام كلمة مرور أقوى تحتوي على مزيج من الأحرف الكبيرة والصغيرة والأرقام والرموز الخاصة.');
                passwordInput.focus();
                return false;
            }
            
            // Check phone number
            const phonePattern = /^[0-9]{11}$/;
            if (!phonePattern.test(phoneInput.value)) {
                e.preventDefault();
                alert('يرجى إدخال رقم هاتف صحيح (11 رقم بالضبط).');
                phoneInput.focus();
                return false;
            }
            
            // Check username length
            const username = document.getElementById('username').value;
            if (username.length < 3 || username.length > 30) {
                e.preventDefault();
                alert('اسم المستخدم يجب أن يكون بين 3-30 حرف.');
                document.getElementById('username').focus();
                return false;
            }
        });
        
        }); // End DOMContentLoaded
    </script>

    <%- include('bottom_app_navbar') %>
</body>
</html>
