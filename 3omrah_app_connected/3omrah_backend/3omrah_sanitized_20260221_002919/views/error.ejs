<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>خطأ - <%= title || 'منصة العمرة' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@200;300;400;500;700;800;900&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Tajawal', sans-serif;
            background: linear-gradient(135deg, #1e5470 0%, #5c8397 50%, #d3f0f7 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            direction: rtl;
        }
        
        .error-container {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            padding: 60px 40px;
            width: 100%;
            max-width: 600px;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        
        .error-icon {
            font-size: 6rem;
            margin-bottom: 30px;
            display: block;
        }
        
        .error-code {
            font-size: 4rem;
            font-weight: 900;
            color: #1e5470;
            margin-bottom: 20px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
        }
        
        .error-title {
            font-size: 2rem;
            font-weight: 700;
            color: #1e5470;
            margin-bottom: 20px;
        }
        
        .error-message {
            font-size: 1.2rem;
            color: #5c8397;
            margin-bottom: 40px;
            line-height: 1.6;
        }
        
        .error-actions {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
        }
        
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 15px 30px;
            border-radius: 12px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            font-size: 16px;
            border: none;
            cursor: pointer;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #5ec1d1 0%, #1e5470 100%);
            color: white;
            box-shadow: 0 4px 15px rgba(52, 114, 156, 0.3);
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(52, 114, 156, 0.4);
        }
        
        .btn-secondary {
            background: transparent;
            color: #1e5470;
            border: 2px solid #1e5470;
        }
        
        .btn-secondary:hover {
            background: #1e5470;
            color: white;
            transform: translateY(-2px);
        }
        
        .error-details {
            margin-top: 30px;
            padding: 20px;
            background: rgba(30, 84, 112, 0.05);
            border-radius: 10px;
            text-align: right;
        }
        
        .error-details h3 {
            color: #1e5470;
            margin-bottom: 10px;
            font-size: 1.1rem;
        }
        
        .error-details p {
            color: #5c8397;
            font-size: 0.9rem;
            line-height: 1.5;
        }
        
        @media (max-width: 768px) {
            .error-container {
                padding: 40px 20px;
                margin: 10px;
            }
            
            .error-icon {
                font-size: 4rem;
            }
            
            .error-code {
                font-size: 3rem;
            }
            
            .error-title {
                font-size: 1.5rem;
            }
            
            .error-message {
                font-size: 1rem;
            }
            
            .error-actions {
                flex-direction: column;
                align-items: center;
            }
            
            .btn {
                width: 100%;
                max-width: 300px;
            }
        }
        
        @media (max-width: 480px) {
            .error-container {
                padding: 30px 15px;
            }
            
            .error-icon {
                font-size: 3rem;
            }
            
            .error-code {
                font-size: 2.5rem;
            }
            
            .error-title {
                font-size: 1.3rem;
            }
            
            .error-message {
                font-size: 0.9rem;
            }
        }
        
        .decorative-element {
            position: absolute;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: linear-gradient(135deg, #5ec1d1, #1e5470);
            opacity: 0.1;
        }
        
        .decorative-element:first-child {
            top: -50px;
            right: -50px;
        }
        
        .decorative-element:last-child {
            bottom: -50px;
            left: -50px;
        }
    </style>
</head>
<body>
    <div class="decorative-element"></div>
    <div class="decorative-element"></div>
    
    <div class="error-container">
        <div class="error-icon">
            <% if (errorCode == 404) { %>
                🔍
            <% } else if (errorCode == 403) { %>
                🔒
            <% } else if (errorCode == 500) { %>
                ⚠️
            <% } else { %>
                ❌
            <% } %>
        </div>
        
        <div class="error-code"><%= errorCode || '404' %></div>
        
        <h1 class="error-title">
            <% if (errorCode == 404) { %>
                الصفحة غير موجودة
            <% } else if (errorCode == 403) { %>
                غير مسموح بالوصول
            <% } else if (errorCode == 500) { %>
                خطأ في الخادم
            <% } else { %>
                حدث خطأ غير متوقع
            <% } %>
        </h1>
        
        <p class="error-message">
            <%= message || 'عذراً، الصفحة التي تبحث عنها غير موجودة أو تم نقلها إلى مكان آخر.' %>
        </p>
        
        <div class="error-actions">
            <a href="/" class="btn btn-primary">
                🏠 العودة للرئيسية
            </a>
            
            <button onclick="history.back()" class="btn btn-secondary">
                ↩️ الصفحة السابقة
            </button>
            
            <% if (errorCode == 404) { %>
                <a href="/bundles" class="btn btn-secondary">
                    📦 تصفح الباقات
                </a>
            <% } %>
        </div>
        
        <% if (typeof error !== 'undefined' && error && process.env.NODE_ENV === 'development') { %>
            <div class="error-details">
                <h3>تفاصيل الخطأ (وضع التطوير):</h3>
                <p><%= error.message %></p>
                <% if (error.stack) { %>
                    <pre style="text-align: left; font-size: 0.8rem; margin-top: 10px; overflow-x: auto;"><%= error.stack %></pre>
                <% } %>
            </div>
        <% } %>
    </div>
    
    <script>
        // Auto-redirect to home page after 30 seconds for 404 errors
        <% if (errorCode == 404) { %>
            setTimeout(() => {
                if (confirm('هل تريد العودة إلى الصفحة الرئيسية؟')) {
                    window.location.href = '/';
                }
            }, 30000);
        <% } %>
        
        // Add some interactive feedback
        document.addEventListener('DOMContentLoaded', function() {
            const buttons = document.querySelectorAll('.btn');
            buttons.forEach(button => {
                button.addEventListener('mouseenter', function() {
                    this.style.transform = 'translateY(-2px) scale(1.02)';
                });
                
                button.addEventListener('mouseleave', function() {
                    this.style.transform = 'translateY(0) scale(1)';
                });
            });
        });
    </script>
</body>
</html>
