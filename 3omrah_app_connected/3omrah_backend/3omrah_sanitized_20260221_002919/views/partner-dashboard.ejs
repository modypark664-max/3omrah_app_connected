        }
        
        function updateRecentActivity(activities) {
            const container = document.getElementById('recentActivity');
            
            if (activities.length === 0) {
                container.innerHTML = '<div class="loading">لا يوجد نشاط حديث</div>';
                return;
            }
            
            const statusLabels = {
                'pending': 'في الانتظار',
                'confirmed': 'مؤكد',
                'rejected': 'مرفوض'
            };
            
            container.innerHTML = activities.map(activity => `
                <div class="activity-item">
                    <div class="activity-info">
                        <h5>حجز جديد - ${activity.card.code}</h5>
                        <p>العميل: ${activity.user.username} | التاريخ: ${new Date(activity.currentDate).toLocaleDateString('ar-EG')}</p>
                    </div>
                    <span class="activity-status ${activity.partnerStatus}">
                        ${statusLabels[activity.partnerStatus] || activity.partnerStatus}
                    </span>
                </div>
            `).join('');
        }

        // Partner reservation management functions
        async function confirmReservation(reservationId) {
            const notesTextarea = document.getElementById(`notes-${reservationId}`);
            const notes = notesTextarea ? notesTextarea.value.trim() : '';
            
            if (!confirm('هل أنت متأكد من تأكيد هذا الحجز؟')) {
                return;
            }

            try {
                const response = await fetch(`/partner/reservation/${reservationId}/confirm`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ notes })
                });

                const result = await response.json();

                if (result.success) {
                    alert('تم تأكيد الحجز بنجاح');
                    location.reload(); // Refresh to show updated status
                } else {
                    alert('خطأ: ' + result.message);
                }
            } catch (error) {
                console.error('Error confirming reservation:', error);
                alert('حدث خطأ أثناء تأكيد الحجز');
            }
        }

        async function rejectReservation(reservationId) {
            const notesTextarea = document.getElementById(`notes-${reservationId}`);
            const notes = notesTextarea ? notesTextarea.value.trim() : '';
            
            if (!notes) {
                alert('يرجى إضافة سبب الرفض في الملاحظات');
                return;
            }
            
            if (!confirm('هل أنت متأكد من رفض هذا الحجز؟')) {
                return;
            }

            try {
                const response = await fetch(`/partner/reservation/${reservationId}/reject`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ notes })
                });

                const result = await response.json();

                if (result.success) {
                    alert('تم رفض الحجز');
                    location.reload(); // Refresh to show updated status
                } else {
                    alert('خطأ: ' + result.message);
                }
            } catch (error) {
                console.error('Error rejecting reservation:', error);
                alert('حدث خطأ أثناء رفض الحجز');
            }
        }

        // ...existing functions...
    </script>
    <script src="/socket.io/socket.io.js" defer></script>
    <script src="/js/chat-inbox.js" defer></script>
</body>
</html>
