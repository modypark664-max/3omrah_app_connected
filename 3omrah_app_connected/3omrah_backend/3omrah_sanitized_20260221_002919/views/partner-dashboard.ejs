        function updateRevenueOverview(monthlyData) {
            // Calculate total revenue
            const totalRevenue = monthlyData.reduce((sum, item) => sum + item.revenue, 0);
            document.getElementById('totalRevenueAmount').textContent = totalRevenue.toLocaleString() + ' ج.م';
            
            // Create simple revenue chart
            const chartContainer = document.getElementById('revenueChartSimple');
            
            const months = ['يناير', 'فبراير', 'مارس', 'أبريل', 'مايو', 'يونيو', 
                           'يوليو', 'أغسطس', 'سبتمبر', 'أكتوبر', 'نوفمبر', 'ديسمبر'];
            
            if (monthlyData.length === 0) {
                chartContainer.innerHTML = '<div class="loading">لا توجد بيانات للإيرادات</div>';
                return;
            }
            
            chartContainer.innerHTML = monthlyData.map(item => {
                const monthName = `${months[item._id.month - 1]} ${item._id.year}`;
                return `
                    <div class="revenue-month">
                        <span class="revenue-month-name">${monthName}</span>
                        <span class="revenue-month-amount">${item.revenue.toLocaleString()} ج.م</span>
                    </div>
                `;
            }).join('');
        }
        
        function updatePerformanceMetrics(topTrips) {
            const topTrip = topTrips.length > 0 ? topTrips[0] : null;
            const topTripEl = document.getElementById('topTrip');
            const conversionRateEl = document.getElementById('conversionRate');
            const avgBookingValueEl = document.getElementById('avgBookingValue');
            
            if (topTrip) {
                topTripEl.textContent = topTrip.cardDetails.code || 'لا توجد بيانات';
                
                // Calculate conversion rate (confirmed bookings / total bookings)
                const totalBookings = topTrips.reduce((sum, trip) => sum + trip.bookings, 0);
                const conversionRate = totalBookings > 0 ? ((topTrip.bookings / totalBookings) * 100).toFixed(1) : 0;
                conversionRateEl.textContent = conversionRate + '%';
                
                // Calculate average booking value
                const totalRevenue = topTrips.reduce((sum, trip) => sum + trip.revenue, 0);
                const avgValue = totalBookings > 0 ? (totalRevenue / totalBookings).toFixed(0) : 0;
                avgBookingValueEl.textContent = avgValue + ' ج.م';
            } else {
                topTripEl.textContent = 'لا توجد بيانات';
                conversionRateEl.textContent = '0%';
                avgBookingValueEl.textContent = '0 ج.م';
            }
        }
        
        function updateBookingStatusOverview(statusData) {
            const statusMap = {
                'pending': { element: 'pendingCount', progress: 'pendingProgress' },
                'confirmed': { element: 'confirmedCount', progress: 'confirmedProgress' },
                'rejected': { element: 'rejectedCount', progress: 'rejectedProgress' }
            };
            
            // Calculate total for percentage
            const total = statusData.reduce((sum, item) => sum + item.count, 0);
            
            // Reset all counts
            Object.values(statusMap).forEach(status => {
                const countEl = document.getElementById(status.element);
                const progressEl = document.getElementById(status.progress);
                if (countEl) countEl.textContent = '0';
                if (progressEl) progressEl.style.width = '0%';
            });
            
            // Update with actual data
            statusData.forEach(item => {
                const status = statusMap[item._id];
                if (status) {
                    const countEl = document.getElementById(status.element);
                    const progressEl = document.getElementById(status.progress);
                    
                    if (countEl) countEl.textContent = item.count;
                    if (progressEl) {
                        const percentage = total > 0 ? (item.count / total) * 100 : 0;
                        progressEl.style.width = percentage + '%';
                    }
                }
            });
        }
        
