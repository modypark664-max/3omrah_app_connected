<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Alexandria:wght@100..900&family=Cairo:wght@200..1000&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Tajawal:wght@200;300;400;500;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/home.css">
    <link rel="stylesheet" href="/chat-inbox.css">
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/imgs/logo.png">
    <link rel="shortcut icon" type="image/png" href="/imgs/logo.png">
    <link rel="apple-touch-icon" href="/imgs/logo.png">
    
    <title>لوحة تحكم الشريك - <%= title || 'منصة رحلة عمرة' %></title>
</head>
<body>
    <section id="header-hero" class="header-hero-section">
        <%- include('navbar') %>
    </section>

    <section class="partner-dashboard">
        <div class="container">
            <div class="dashboard-header">
                <h1>مرحباً بك، <%= user.companyName %></h1>
                <p class="company-rep">ممثل الشركة: <%= user.companyRepresentative %></p>
            </div>

            <% if (!user.isVerified) { %>
            <div class="verification-alert">
                <div class="alert-content">
                    <div class="alert-icon">⚠️</div>
                    <div class="alert-text">
                        <h3>حسابك في انتظار التحقق</h3>
                        <p>يرجى التواصل مع الرقم التالي لإكمال عملية التحقق من حسابك:</p>
                        <div class="contact-number">📞 01234567890</div>
                        <p class="small-text">بعد التحقق ستتمكن من إضافة الرحلات والاستفادة من جميع المميزات</p>
                    </div>
                </div>
            </div>
            <% } %>

            <div class="dashboard-stats">
                <div class="stat-card">
                    <div class="stat-icon">📋</div>
                    <div class="stat-info">
                        <h3>إجمالي الرحلات</h3>
                        <p id="totalTrips"><%= stats.totalTrips %> رحلة</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">👥</div>
                    <div class="stat-info">
                        <h3>إجمالي الحجوزات</h3>
                        <p id="totalBookings"><%= stats.totalBookings %> حجز</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">💰</div>
                    <div class="stat-info">
                        <h3>الإيرادات</h3>
                        <p id="totalRevenue"><%= stats.totalRevenue.toLocaleString() %> جنيه</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">⏳</div>
                    <div class="stat-info">
                        <h3>في انتظار المراجعة</h3>
                        <p id="pendingTrips"><%= stats.pendingTrips %> رحلة</p>
                    </div>
                </div>
            </div>

            <div class="dashboard-content">
                <div class="dashboard-sidebar">
                    <div class="sidebar-menu">
                        <a href="#trips" class="menu-item active" onclick="showSection('trips')">
                            <span class="menu-icon">🗺️</span>
                            <span>إدارة الرحلات</span>
                        </a>
                        <a href="#bookings" class="menu-item" onclick="showSection('bookings')">
                            <span class="menu-icon">📋</span>
                            <span>الحجوزات</span>
                        </a>
                        <a href="#chat" class="menu-item" onclick="showSection('chat')">
                            <span class="menu-icon">💬</span>
                            <span>محادثات العملاء</span>
                        </a>
                        <a href="#reports" class="menu-item" onclick="showSection('reports')">
                            <span class="menu-icon">📊</span>
                            <span>التقارير</span>
                        </a>
                        <a href="#settings" class="menu-item" onclick="showSection('settings')">
                            <span class="menu-icon">⚙️</span>
                            <span>الإعدادات</span>
                        </a>
                    </div>
                </div>

                <div class="dashboard-main">
                    <!-- Trips Section -->
                    <div id="trips-section" class="section active">
                        <div class="section-header">
                            <h2>إدارة الرحلات</h2>
                            <div class="trip-actions">
                                <% if (user.isVerified) { %>
                                <button class="btn-primary" onclick="showAddTripForm()">إضافة رحلة جديدة</button>
                                <% } else { %>
                                <button class="btn-disabled" disabled>إضافة رحلة جديدة (يتطلب التحقق)</button>
                                <% } %>
                                <button class="btn-secondary" onclick="refreshStats()">تحديث الإحصائيات</button>
                            </div>
                        </div>
                        
                        <!-- Package Limits Info -->
                        <div class="package-info">
                            <div class="limit-display">
                                <span class="label">الحد الأقصى للرحلات:</span>
                                <span class="limit-value">
                                    <% 
                                    let displayLimit;
                                    if (user.partnerPackage === 'premium') {
                                        displayLimit = tierLimits.premium === -1 ? 'غير محدود' : tierLimits.premium + ' رحلة';
                                    } else if (user.partnerPackage === 'professional') {
                                        displayLimit = tierLimits.professional + ' رحلة';
                                    } else {
                                        displayLimit = tierLimits.basic + ' رحلات';
                                    }
                                    %>
                                    <%= displayLimit %>
                                </span>
                                <span class="current-count">
                                    (الحالي: <span id="currentTripCount"><%= stats.totalTrips %></span>)
                                </span>
                            </div>
                        </div>
                        
                                                <!-- Add Trip Form (Modern Modal) -->
                                                <div id="add-trip-form" class="add-trip-modal">
                                                    <div class="modal-overlay" onclick="hideAddTripForm()"></div>
                                                    <div class="modal-card">
                                                        <div class="modal-header">
                                                            <h3>إضافة رحلة جديدة</h3>
                                                            <button class="modal-close" type="button" onclick="hideAddTripForm()">×</button>
                                                        </div>
                                                        <form id="partnerCardForm" enctype="multipart/form-data">
                                                            <div class="modal-body">
                                                                <!-- Basic Info -->
                                                                <div class="form-section modern">
                                                                    <h4>معلومات أساسية</h4>
                                                                    <div class="form-grid three">
                                                                        <div class="form-group with-icon">
                                                                            <label>نوع الرحلة</label>
                                                                            <div class="input-wrap">
                                                                                <span class="input-icon">🗺️</span>
                                                                                <select name="type" required>
                                                                                    <option value="">اختر النوع</option>
                                                                                    <option value="omrah">عمرة</option>
                                                                                    <option value="internal_tour">رحلة داخلية</option>
                                                                                    <option value="external_tour">رحلة خارجية</option>
                                                                                    <option value="7ag">رحلة حج</option>
                                                                                    <option value="ramadan">رحلة رمضان</option>
                                                                                </select>
                                                                            </div>
                                                                        </div>
                                                                        <div class="form-group with-icon">
                                                                            <label>كود الرحلة</label>
                                                                            <div class="input-wrap">
                                                                                <span class="input-icon">#</span>
                                                                                <input type="text" name="code" placeholder="مثل: PRT-001" required>
                                                                            </div>
                                                                        </div>
                                                                        <div class="form-group with-icon">
                                                                            <label>عنوان الرحلة</label>
                                                                            <div class="input-wrap">
                                                                                <span class="input-icon">📝</span>
                                                                                <input type="text" name="title" placeholder="أدخل عنوان جذاب للرحلة" required>
                                                                            </div>
                                                                        </div>
                                                                        <div class="form-group with-icon">
                                                                            <label>نوع العرض</label>
                                                                            <div class="input-wrap">
                                                                                <span class="input-icon">🏷️</span>
                                                                                <select name="offer_type" id="partner_offer_type">
                                                                                    <option value="">اختر نوع العرض</option>
                                                                                </select>
                                                                            </div>
                                                                        </div>
                                                                        <div class="form-group with-icon">
                                                                            <label>عدد الأيام</label>
                                                                            <div class="input-wrap">
                                                                                <span class="input-icon">📅</span>
                                                                                <input type="number" name="days" min="1" required>
                                                                            </div>
                                                                        </div>
                                                                        <div class="form-group with-icon">
                                                                            <label>عدد الليالي</label>
                                                                            <div class="input-wrap">
                                                                                <span class="input-icon">🌙</span>
                                                                                <input type="number" name="nights" min="0" required>
                                                                            </div>
                                                                        </div>
                                                                        <div class="form-group with-icon">
                                                                            <label>تاريخ السفر</label>
                                                                            <div class="input-wrap">
                                                                                <span class="input-icon">🗓️</span>
                                                                                <input type="date" name="travel_date" required>
                                                                            </div>
                                                                        </div>
                                                                        <div class="form-group with-icon">
                                                                            <label>تاريخ انتهاء العرض</label>
                                                                            <div class="input-wrap">
                                                                                <span class="input-icon">⏰</span>
                                                                                <input type="date" name="offer_expiry_date" required>
                                                                            </div>
                                                                            <small style="color: #6b7280; font-size: 12px; margin-top: 5px; display: block;">
                                                                                يجب أن يكون تاريخ انتهاء العرض قبل تاريخ السفر
                                                                            </small>
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                                <!-- Travel Details -->
                                                                <div class="form-section modern">
                                                                    <h4>تفاصيل السفر</h4>
                                                                    <div class="form-grid two">
                                                                        <div class="form-group with-icon">
                                                                            <label>مسار الذهاب</label>
                                                                            <div class="input-wrap">
                                                                                <span class="input-icon">➡️</span>
                                                                                <input type="text" name="going_route" placeholder="مثل: الرياض - مكة المكرمة" required>
                                                                            </div>
                                                                        </div>
                                                                        <div class="form-group with-icon">
                                                                            <label>مسار العودة</label>
                                                                            <div class="input-wrap">
                                                                                <span class="input-icon">↩️</span>
                                                                                <input type="text" name="returning_route" placeholder="مثل: المدينة المنورة - الرياض" required>
                                                                            </div>
                                                                        </div>
                                                                        <div class="form-group with-icon full-width">
                                                                            <label>شركة الطيران</label>
                                                                            <div class="input-wrap">
                                                                                <span class="input-icon">✈️</span>
                                                                                <input type="text" name="plane_company" placeholder="مثل: الخطوط السعودية" required>
                                                                            </div>
                                                                        </div>
                                                                        <div class="form-group with-icon full-width">
                                                                            <label>الشركة المنظمة</label>
                                                                            <div class="input-wrap">
                                                                                <span class="input-icon">🏢</span>
                                                                                <input type="text" name="company" placeholder="اسم شركتك أو الشركة المنظمة (اختياري)" maxlength="100">
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                                <!-- Media Uploads -->
                                                                <div class="form-section modern">
                                                                    <h4>الصور</h4>
                                                                    <div class="form-grid two">
                                                                        <div class="form-group full-width">
                                                                            <label>الصورة الرئيسية</label>
                                                                            <div id="thumbnailDropzone" class="dropzone" onclick="document.getElementById('thumbnailInput').click()">
                                                                                <input id="thumbnailInput" type="file" name="thumbnail" accept="image/*" required hidden>
                                                                                <div class="dz-placeholder">
                                                                                    <span class="dz-icon">🖼️</span>
                                                                                    <p>اسحب وأفلت الصورة هنا أو انقر للاختيار</p>
                                                                                </div>
                                                                                <img id="thumbnailPreview" class="dz-preview" alt="thumbnail preview" />
                                                                            </div>
                                                                        </div>
                                                                        <div class="form-group full-width">
                                                                            <label>صور إضافية</label>
                                                                            <div id="imagesDropzone" class="dropzone" onclick="document.getElementById('imagesInput').click()">
                                                                                <input id="imagesInput" type="file" name="images" accept="image/*" multiple hidden>
                                                                                <div class="dz-placeholder">
                                                                                    <span class="dz-icon">🖼️🖼️</span>
                                                                                    <p>اسحب وأفلت الصور هنا أو انقر للاختيار</p>
                                                                                </div>
                                                                                <div id="imagesPreview" class="dz-multi-preview"></div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                                <!-- Hotels -->
                                                                <div class="form-section modern">
                                                                    <div class="section-head-row">
                                                                        <h4>معلومات الفنادق</h4>
                                                                        <button type="button" class="add-btn ghost" onclick="addHotel()">+ إضافة فندق</button>
                                                                    </div>
                                                                    <div id="partner-hotels-container" class="cards-list">
                                                                        <div class="hotel-item card">
                                                                            <div class="hotel-grid">
                                                                                <div class="form-group">
                                                                                    <label>عدد الليالي</label>
                                                                                    <input type="number" class="hotel-nights" min="1" required>
                                                                                </div>
                                                                                <div class="form-group">
                                                                                    <label>اسم الفندق</label>
                                                                                    <input type="text" class="hotel-name" required>
                                                                                </div>
                                                                                <div class="form-group">
                                                                                    <label>نوع الفندق</label>
                                                                                    <select class="hotel-type" required>
                                                                                        <option value="">اختر النوع</option>
                                                                                        <option value="اقتصادي">اقتصادي</option>
                                                                                        <option value="سياحي">سياحي</option>
                                                                                        <option value="VIP">VIP</option>
                                                                                    </select>
                                                                                </div>
                                                                                <div class="form-group">
                                                                                    <label>الموقع</label>
                                                                                    <input type="text" class="hotel-location" required>
                                                                                </div>
                                                                                <div class="form-group">
                                                                                    <label>يشمل الطعام</label>
                                                                                    <select class="hotel-food" required>
                                                                                        <option value="">اختر</option>
                                                                                        <option value="true">نعم</option>
                                                                                        <option value="false">لا</option>
                                                                                    </select>
                                                                                </div>
                                                                            </div>
                                                                            <button type="button" class="remove-btn ghost" onclick="removeHotel(this)">حذف الفندق</button>
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                                <!-- Housing -->
                                                                <div class="form-section modern">
                                                                    <div class="section-head-row">
                                                                        <h4>خيارات الغرف والأسعار</h4>
                                                                        <button type="button" class="add-btn ghost" onclick="addHousing()">+ إضافة خيار</button>
                                                                    </div>
                                                                    <div id="partner-housing-container" class="cards-list">
                                                                        <div class="housing-item card">
                                                                            <div class="housing-grid">
                                                                                <div class="form-group">
                                                                                    <label>نوع الغرفة</label>
                                                                                    <input type="text" class="room-type" placeholder="مثل: غرفة مزدوجة" required>
                                                                                </div>
                                                                                <div class="form-group">
                                                                                    <label>السعر (ج.م)</label>
                                                                                    <input type="number" class="room-price" min="0" required>
                                                                                </div>
                                                                            </div>
                                                                            <button type="button" class="remove-btn ghost" onclick="removeHousing(this)">حذف</button>
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                                <!-- Services Included -->
                                                                <div class="form-section modern">
                                                                    <h4>الخدمات المشمولة</h4>
                                                                    <div id="included-services-container" class="services-container">
                                                                        <div class="service-item">
                                                                            <input type="text" name="included_services[]" placeholder="أدخل خدمة مشمولة" class="service-input">
                                                                            <button type="button" class="remove-service-btn" onclick="removeServiceInput(this)">×</button>
                                                                        </div>
                                                                    </div>
                                                                    <button type="button" class="add-service-btn" onclick="addServiceInput('included-services-container', 'included_services[]', 'أدخل خدمة مشمولة')">+ إضافة خدمة</button>
                                                                </div>

                                                                <!-- Services Not Included -->
                                                                <div class="form-section modern">
                                                                    <h4>الخدمات غير المشمولة</h4>
                                                                    <div id="not-included-services-container" class="services-container">
                                                                        <div class="service-item">
                                                                            <input type="text" name="not_included_services[]" placeholder="أدخل خدمة غير مشمولة" class="service-input">
                                                                            <button type="button" class="remove-service-btn" onclick="removeServiceInput(this)">×</button>
                                                                        </div>
                                                                    </div>
                                                                    <button type="button" class="add-service-btn" onclick="addServiceInput('not-included-services-container', 'not_included_services[]', 'أدخل خدمة غير مشمولة')">+ إضافة خدمة</button>
                                                                </div>

                                                                <!-- Notes -->
                                                                <div class="form-section modern">
                                                                    <h4>ملاحظات مهمة</h4>
                                                                    <div id="notes-container" class="services-container">
                                                                        <div class="service-item">
                                                                            <input type="text" name="notes[]" placeholder="أدخل ملاحظة مهمة" class="service-input">
                                                                            <button type="button" class="remove-service-btn" onclick="removeServiceInput(this)">×</button>
                                                                        </div>
                                                                    </div>
                                                                    <button type="button" class="add-service-btn" onclick="addServiceInput('notes-container', 'notes[]', 'أدخل ملاحظة مهمة')">+ إضافة ملاحظة</button>
                                                                </div>

                                                                <!-- Cancelling Rules -->
                                                                <div class="form-section modern">
                                                                    <h4>قواعد الإلغاء</h4>
                                                                    <div id="rules-container" class="services-container">
                                                                        <div class="service-item">
                                                                            <input type="text" name="cancelling_rules[]" placeholder="أدخل قاعدة إلغاء" class="service-input">
                                                                            <button type="button" class="remove-service-btn" onclick="removeServiceInput(this)">×</button>
                                                                        </div>
                                                                    </div>
                                                                    <button type="button" class="add-service-btn" onclick="addServiceInput('rules-container', 'cancelling_rules[]', 'أدخل قاعدة إلغاء')">+ إضافة قاعدة</button>
                                                                </div>
                                                            </div>

                                                            <div class="modal-footer">
                                                                <button type="submit" class="btn-primary" id="submit-card-btn">إرسال الرحلة للمراجعة</button>
                                                                <button type="button" class="btn-secondary" onclick="hideAddTripForm()">إلغاء</button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                        
                        <!-- Partner's Cards List -->
                        <div class="trips-grid" id="tripsGrid">
                            <% if (partnerCards && partnerCards.length > 0) { %>
                                <% partnerCards.forEach(card => { %>
                                    <div class="trip-card">
                                        <div class="trip-header">
                                            <h4><%= card.code %></h4>
                                            <span class="status-badge <%= card.isApproved ? 'approved' : 'pending' %>">
                                                <%= card.isApproved ? 'معتمد' : 'في انتظار المراجعة' %>
                                            </span>
                                        </div>
                                        <div class="trip-info">
                                            <p><strong>النوع:</strong> 
                                                <%= card.type === 'omrah' ? 'عمرة' : 
                                                    card.type === 'internal_tour' ? 'رحلة داخلية' : 
                                                    card.type === 'external_tour' ? 'رحلة خارجية' : 
                                                    card.type === '7ag' ? 'حج' : 'رمضان' %>
                                            </p>
                                            <p><strong>المدة:</strong> <%= card.days %> أيام / <%= card.nights %> ليالي</p>
                                            <p><strong>تاريخ السفر:</strong> <%= new Date(card.travel_date).toLocaleDateString('ar-SA') %></p>
                                            <p><strong>انتهاء العرض:</strong> <%= card.offer_expiry_date ? new Date(card.offer_expiry_date).toLocaleDateString('ar-SA') : 'غير محدد' %></p>
                                            <p><strong>أقل سعر:</strong> <%= card.lowest_price %> ج.م</p>
                                        </div>
                                        <div class="trip-actions">
                                            <% if (card.isApproved) { %>
                                                <a href="/card/<%= card._id %>" class="btn-view" target="_blank">عرض</a>
                                            <% } %>
                                            <button class="btn-delete" onclick="deletePartnerCard('<%= card._id %>', '<%= card.code %>')">حذف</button>
                                        </div>
                                    </div>
                                <% }); %>
                            <% } else { %>
                                <div class="empty-state">
                                    <div class="empty-icon">🗺️</div>
                                    <h3>لا توجد رحلات بعد</h3>
                                    <p>ابدأ بإضافة رحلتك الأولى</p>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Bookings Section -->
                    <div id="bookings-section" class="section">
                        <div class="section-header">
                            <h2>الحجوزات</h2>
                        </div>
                        
                        <div class="bookings-list" id="bookingsList">
                            <% if (partnerReservations && partnerReservations.length > 0) { %>
                                <% partnerReservations.forEach(reservation => { %>
                                    <div class="booking-card" data-reservation-id="<%= reservation._id %>">
                                        <div class="booking-header">
                                            <div class="booking-info">
                                                <h4><%= reservation.card.title %></h4>
                                                <p class="reservation-number">رقم الحجز: <%= reservation.reservationNumber %></p>
                                                <p class="booking-date">تاريخ الحجز: <%= new Date(reservation.currentDate).toLocaleDateString('ar-EG') %></p>
                                            </div>
                                            <div class="booking-status">
                                                <span class="status-badge status-<%= reservation.partnerStatus %>">
                                                    <% if (reservation.partnerStatus === 'pending') { %>
                                                        في انتظار المراجعة
                                                    <% } else if (reservation.partnerStatus === 'confirmed') { %>
                                                        مؤكد
                                                    <% } else if (reservation.partnerStatus === 'rejected') { %>
                                                        مرفوض
                                                    <% } %>
                                                </span>
                                                <span class="payment-badge payment-<%= reservation.paymentStatus %>">
                                                    <% if (reservation.paymentStatus === 'pending') { %>
                                                        لم يتم الدفع
                                                    <% } else if (reservation.paymentStatus === 'paid') { %>
                                                        تم الدفع
                                                    <% } else if (reservation.paymentStatus === 'cancelled') { %>
                                                        ملغى
                                                    <% } %>
                                                </span>
                                            </div>
                                        </div>
                                        
                                        <div class="booking-details">
                                            <div class="customer-info">
                                                <h5>معلومات العميل:</h5>
                                                <p><strong>الاسم:</strong> <%= reservation.user.username %></p>
                                                <p><strong>البريد الإلكتروني:</strong> <%= reservation.user.email %></p>
                                                <% if (reservation.user.phone) { %>
                                                    <p><strong>الهاتف:</strong> <%= reservation.user.phone %></p>
                                                <% } %>
                                            </div>
                                            
                                            <div class="trip-details">
                                                <p><strong>عدد الأشخاص:</strong> <%= reservation.people_count %></p>
                                                <p><strong>المبلغ الإجمالي:</strong> <%= reservation.totalAmount %> ر.س</p>
                                                <p><strong>طريقة الدفع:</strong> 
                                                    <% if (reservation.paymentMethod === 'vodafone_cash') { %>
                                                        فودافون كاش
                                                    <% } else if (reservation.paymentMethod === 'bank_transfer') { %>
                                                        تحويل بنكي
                                                    <% } else if (reservation.paymentMethod === 'cash') { %>
                                                        نقداً
                                                    <% } %>
                                                </p>
                                                <% if (reservation.note) { %>
                                                    <p><strong>ملاحظات العميل:</strong> <%= reservation.note %></p>
                                                <% } %>
                                            </div>
                                        </div>
                                        
                                        <% if (reservation.partnerStatus === 'pending') { %>
                                            <div class="booking-actions">
                                                <div class="partner-notes">
                                                    <label for="notes-<%= reservation._id %>">ملاحظات (اختياري):</label>
                                                    <textarea id="notes-<%= reservation._id %>" placeholder="أضف ملاحظات للعميل..."></textarea>
                                                </div>
                                                <div class="action-buttons">
                                                    <button class="btn-confirm" onclick="confirmReservation('<%= reservation._id %>')">
                                                        ✓ تأكيد الحجز
                                                    </button>
                                                    <button class="btn-reject" onclick="rejectReservation('<%= reservation._id %>')">
                                                        ✗ رفض الحجز
                                                    </button>
                                                </div>
                                            </div>
                                        <% } else { %>
                                            <% if (reservation.partnerNotes) { %>
                                                <div class="partner-notes-display">
                                                    <strong>ملاحظات الشريك:</strong> <%= reservation.partnerNotes %>
                                                </div>
                                            <% } %>
                                        <% } %>
                                    </div>
                                <% }); %>
                            <% } else { %>
                                <div class="empty-state">
                                    <div class="empty-icon">📋</div>
                                    <h3>لا توجد حجوزات بعد</h3>
                                    <p>عندما يقوم العملاء بحجز رحلاتك ستظهر هنا</p>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Chat Section -->
                    <div id="chat-section" class="section">
                        <section class="chat-inbox-card" data-chat-inbox data-scope="owner">
                            <div class="chat-inbox-header">
                                <div>
                                    <h2>محادثات العملاء</h2>
                                    <p>تابع استفسارات المهتمين بعروضك وتواصل معهم فوراً.</p>
                                </div>
                                <div class="chat-inbox-actions">
                                    <button type="button" data-action="refreshThreads">تحديث</button>
                                </div>
                            </div>
                            <div class="chat-inbox-body">
                                <aside class="chat-thread-panel">
                                    <div class="chat-search">
                                        <input type="search" placeholder="ابحث باسم العميل أو كود العرض" data-thread-search>
                                    </div>
                                    <div class="chat-thread-scroll">
                                        <ul class="chat-thread-list" data-thread-list></ul>
                                        <div class="chat-thread-empty" data-thread-empty>لا توجد محادثات بعد</div>
                                    </div>
                                </aside>
                                <div class="chat-conversation-panel">
                                    <div class="chat-conversation-placeholder" data-conversation-placeholder>
                                        <h3>اختر محادثة لعرض التفاصيل</h3>
                                        <p>عندما يراسلك العملاء حول بطاقة معينة ستظهر هنا.</p>
                                    </div>
                                    <div class="chat-conversation" data-conversation hidden>
                                        <div class="chat-conversation-header">
                                            <div>
                                                <p class="chat-card-label" data-active-card-code>—</p>
                                                <p class="chat-card-meta" data-active-card-route></p>
                                                <p class="chat-viewer-meta" data-active-viewer></p>
                                            </div>
                                            <div class="chat-header-actions">
                                                <a href="#" class="chat-open-card" data-open-card target="_blank" rel="noopener" hidden>عرض البطاقة</a>
                                            </div>
                                        </div>
                                        <div class="chat-messages" data-messages></div>
                                        <form class="chat-composer" data-message-form>
                                            <textarea data-message-input rows="2" placeholder="اكتب ردك هنا..." maxlength="2000"></textarea>
                                            <div class="chat-composer-footer">
                                                <small>اضغط Enter للإرسال وShift+Enter لسطر جديد</small>
                                                <button type="submit" data-send-button>إرسال</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                            <div class="chat-inbox-toast" data-chat-toast hidden></div>
                            <div class="chat-inbox-loader" data-inbox-loader hidden>جاري التحميل...</div>
                        </section>
                    </div>

                    <!-- Reports Section -->
                    <div id="reports-section" class="section">
                        <div class="section-header">
                            <h2>التقارير</h2>
                            <button class="btn-secondary" onclick="loadReportsData()">تحديث التقارير</button>
                        </div>
                        
                        <div class="reports-grid">
                            <!-- Revenue Overview -->
                            <div class="report-card">
                                <h3>📊 الإيرادات الشهرية</h3>
                                <div class="revenue-overview" id="revenueOverview">
                                    <div class="revenue-total">
                                        <span class="revenue-amount" id="totalRevenueAmount">0 ج.م</span>
                                        <span class="revenue-label">إجمالي الإيرادات</span>
                                    </div>
                                    <div class="revenue-chart-simple" id="revenueChartSimple">
                                        <div class="loading">جاري التحميل...</div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Performance Metrics -->
                            <div class="report-card">
                                <h3>🎯 أداء الرحلات</h3>
                                <div class="performance-metrics" id="performanceMetrics">
                                    <div class="metric">
                                        <span class="metric-icon">🏆</span>
                                        <div class="metric-info">
                                            <span class="metric-label">أكثر الرحلات طلباً</span>
                                            <span class="metric-value" id="topTrip">جاري التحميل...</span>
                                        </div>
                                    </div>
                                    <div class="metric">
                                        <span class="metric-icon">📈</span>
                                        <div class="metric-info">
                                            <span class="metric-label">معدل التحويل</span>
                                            <span class="metric-value" id="conversionRate">0%</span>
                                        </div>
                                    </div>
                                    <div class="metric">
                                        <span class="metric-icon">💰</span>
                                        <div class="metric-info">
                                            <span class="metric-label">متوسط قيمة الحجز</span>
                                            <span class="metric-value" id="avgBookingValue">0 ج.م</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Booking Status -->
                            <div class="report-card">
                                <h3>📋 حالة الحجوزات</h3>
                                <div class="status-overview" id="bookingStatusOverview">
                                    <div class="status-item status-pending">
                                        <div class="status-icon">⏳</div>
                                        <div class="status-info">
                                            <span class="status-count" id="pendingCount">0</span>
                                            <span class="status-label">في الانتظار</span>
                                        </div>
                                        <div class="status-bar">
                                            <div class="status-progress" id="pendingProgress"></div>
                                        </div>
                                    </div>
                                    <div class="status-item status-confirmed">
                                        <div class="status-icon">✅</div>
                                        <div class="status-info">
                                            <span class="status-count" id="confirmedCount">0</span>
                                            <span class="status-label">مؤكد</span>
                                        </div>
                                        <div class="status-bar">
                                            <div class="status-progress" id="confirmedProgress"></div>
                                        </div>
                                    </div>
                                    <div class="status-item status-rejected">
                                        <div class="status-icon">❌</div>
                                        <div class="status-info">
                                            <span class="status-count" id="rejectedCount">0</span>
                                            <span class="status-label">مرفوض</span>
                                        </div>
                                        <div class="status-bar">
                                            <div class="status-progress" id="rejectedProgress"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Payment Status -->
                            <div class="report-card">
                                <h3>💳 حالة المدفوعات</h3>
                                <div class="payment-overview" id="paymentStatusOverview">
                                    <div class="payment-item payment-paid">
                                        <div class="payment-icon">💚</div>
                                        <div class="payment-info">
                                            <span class="payment-count" id="paidCount">0</span>
                                            <span class="payment-label">مدفوع</span>
                                        </div>
                                        <div class="payment-bar">
                                            <div class="payment-progress" id="paidProgress"></div>
                                        </div>
                                    </div>
                                    <div class="payment-item payment-pending">
                                        <div class="payment-icon">🟡</div>
                                        <div class="payment-info">
                                            <span class="payment-count" id="paymentPendingCount">0</span>
                                            <span class="payment-label">في انتظار الدفع</span>
                                        </div>
                                        <div class="payment-bar">
                                            <div class="payment-progress" id="paymentPendingProgress"></div>
                                        </div>
                                    </div>
                                    <div class="payment-item payment-cancelled">
                                        <div class="payment-icon">🔴</div>
                                        <div class="payment-info">
                                            <span class="payment-count" id="cancelledCount">0</span>
                                            <span class="payment-label">ملغي</span>
                                        </div>
                                        <div class="payment-bar">
                                            <div class="payment-progress" id="cancelledProgress"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Trip Types Stats -->
                            <div class="report-card full-width">
                                <h3>🗺️ أداء أنواع الرحلات</h3>
                                <div class="trip-types-stats" id="tripTypesStats">
                                    <div class="loading">جاري تحميل البيانات...</div>
                                </div>
                            </div>
                            
                            <!-- Recent Activity -->
                            <div class="report-card full-width">
                                <h3>🕒 النشاط الأخير</h3>
                                <div class="recent-activity" id="recentActivity">
                                    <div class="loading">جاري تحميل النشاط الأخير...</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Settings Section -->
                    <div id="settings-section" class="section">
                        <div class="section-header">
                            <h2>إعدادات الحساب</h2>
                        </div>
                        
                        <div class="settings-grid">
                            <div class="settings-card">
                                <h3>معلومات الشركة</h3>
                                <div class="info-list">
                                    <div class="info-item">
                                        <span class="label">اسم الشركة:</span>
                                        <span class="value"><%= user.companyName %></span>
                                    </div>
                                    <div class="info-item">
                                        <span class="label">ممثل الشركة:</span>
                                        <span class="value"><%= user.companyRepresentative %></span>
                                    </div>
                                    <div class="info-item">
                                        <span class="label">رقم الهاتف:</span>
                                        <span class="value"><%= user.phoneNumber %></span>
                                    </div>
                                    <div class="info-item">
                                        <span class="label">حالة التحقق:</span>
                                        <span class="value <%= user.isVerified ? 'verified' : 'unverified' %>">
                                            <%= user.isVerified ? 'محقق ✅' : 'غير محقق ⏳' %>
                                        </span>
                                    </div>
                                </div>
                                <button class="btn-secondary" onclick="editCompanyInfo()">تعديل المعلومات</button>
                            </div>

                            <div class="settings-card">
                                <h3>الباقة الحالية</h3>
                                <div class="package-details">
                                    <div class="package-name-large">
                                        <% if (user.partnerPackage === 'basic') { %>
                                            باقة أساسية
                                        <% } else if (user.partnerPackage === 'professional') { %>
                                            باقة احترافية
                                        <% } else if (user.partnerPackage === 'premium') { %>
                                            باقة مميزة
                                        <% } %>
                                    </div>
                                    <div class="package-features">
                                        <% if (user.partnerPackage === 'basic') { %>
                                            <p>✅ عرض <%= tierLimits.basic %> رحلات</p>
                                            <p>✅ صفحة تعريف بالشركة</p>
                                            <p>✅ دعم فني</p>
                                        <% } else if (user.partnerPackage === 'professional') { %>
                                            <p>✅ عرض <%= tierLimits.professional %> رحلة</p>
                                            <p>✅ تقارير أداء تفصيلية</p>
                                            <p>✅ شعار مميز</p>
                                            <p>✅ دعم مباشر</p>
                                        <% } else if (user.partnerPackage === 'premium') { %>
                                            <p>✅ <%= tierLimits.premium === -1 ? 'عدد غير محدود من الرحلات' : 'عرض ' + tierLimits.premium + ' رحلة' %></p>
                                            <p>✅ ظهور في الصفحة الرئيسية</p>
                                            <p>✅ حملات ترويجية مشتركة</p>
                                            <p>✅ دعم مخصص 24/7</p>
                                        <% } %>
                                    </div>
                                </div>
                                <button class="btn-primary" onclick="upgradePackage()">ترقية الباقة</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('bottom_app_navbar') %>

