        // Form submission
        document.getElementById('partnerCardForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const submitBtn = document.getElementById('submit-card-btn');
            const originalText = submitBtn.textContent;
            submitBtn.disabled = true;
            submitBtn.textContent = 'جاري الإرسال...';
            
            try {
                // Validate required fields first
                const requiredFields = [
                    { name: 'type', label: 'نوع الرحلة' },
                    { name: 'code', label: 'كود الرحلة' },
                    { name: 'title', label: 'عنوان الرحلة' },
                    { name: 'days', label: 'عدد الأيام' },
                    { name: 'nights', label: 'عدد الليالي' },
                    { name: 'travel_date', label: 'تاريخ السفر' },
                    { name: 'offer_expiry_date', label: 'تاريخ انتهاء العرض' },
                    { name: 'going_route', label: 'مسار الذهاب' },
                    { name: 'returning_route', label: 'مسار العودة' },
                    { name: 'plane_company', label: 'شركة الطيران' }
                ];
                
                let hasErrors = false;
                requiredFields.forEach(field => {
                    const input = document.querySelector(`[name="${field.name}"]`);
                    if (input && !input.value.trim()) {
                        const formGroup = input.closest('.form-group');
                        const inputWrap = input.closest('.input-wrap');
                        if (formGroup) formGroup.classList.add('error');
                        if (inputWrap) inputWrap.classList.add('error');
                        hasErrors = true;
                    }
                });

                // Date validation - ensure expiry is before travel date
                const travelDateInput = document.querySelector('[name="travel_date"]');
                const offerExpiryInput = document.querySelector('[name="offer_expiry_date"]');
                
                if (travelDateInput && offerExpiryInput && travelDateInput.value && offerExpiryInput.value) {
                    const travelDate = new Date(travelDateInput.value);
                    const expiryDate = new Date(offerExpiryInput.value);
                    
                    if (expiryDate >= travelDate) {
                        const formGroup = offerExpiryInput.closest('.form-group');
                        const inputWrap = offerExpiryInput.closest('.input-wrap');
                        if (formGroup) formGroup.classList.add('error');
                        if (inputWrap) inputWrap.classList.add('error');
                        hasErrors = true;
                        throw new Error('تاريخ انتهاء العرض يجب أن يكون قبل تاريخ السفر');
                    }
                }

                if (hasErrors) {
                    throw new Error('يرجى ملء جميع الحقول المطلوبة');
                }                // Collect form data
                const formData = new FormData(this);
                // chips are initialized on DOMContentLoaded; gather from DOM
                
                // Collect hotels data
                const hotels = [];
                document.querySelectorAll('#partner-hotels-container .hotel-item').forEach(item => {
                    const hotel = {
                        nights: parseInt(item.querySelector('.hotel-nights').value),
                        hotel: item.querySelector('.hotel-name').value,
                        hotel_type: item.querySelector('.hotel-type').value,
                        location: item.querySelector('.hotel-location').value,
                        comes_with_food: item.querySelector('.hotel-food').value === 'true'
                    };
                    hotels.push(hotel);
                });
                
                // Collect housing options
                const housingOptions = [];
                document.querySelectorAll('#partner-housing-container .housing-item').forEach(item => {
                    const housing = {
                        roomType: item.querySelector('.room-type').value,
                        price: parseInt(item.querySelector('.room-price').value)
                    };
                    housingOptions.push(housing);
                });
                
                // Validate minimum hotels and housing options
                if (hotels.length === 0) {
                    throw new Error('يجب إضافة فندق واحد على الأقل');
                }
                
                if (housingOptions.length === 0) {
                    throw new Error('يجب إضافة خيار إقامة واحد على الأقل');
                }
                
                // Create plane object structure that backend expects
                // We need to construct the plane object and send it as individual fields
                // The backend expects plane.hotel and plane.housingOptions structure
                formData.append('hotels', JSON.stringify(hotels));
                formData.append('housingOptions', JSON.stringify(housingOptions));
                
                // Also send the plane object structure for validation
                const planeData = {
                    hotel: hotels,
                    housingOptions: housingOptions
                };
                
                // Send each plane property individually for form parsing
                hotels.forEach((hotel, index) => {
                    formData.append(`plane[hotel][${index}][nights]`, hotel.nights);
                    formData.append(`plane[hotel][${index}][hotel]`, hotel.hotel);
                    formData.append(`plane[hotel][${index}][hotel_type]`, hotel.hotel_type);
                    formData.append(`plane[hotel][${index}][location]`, hotel.location);
                    formData.append(`plane[hotel][${index}][comes_with_food]`, hotel.comes_with_food);
                });
                
                housingOptions.forEach((option, index) => {
                    formData.append(`plane[housingOptions][${index}][roomType]`, option.roomType);
                    formData.append(`plane[housingOptions][${index}][price]`, option.price);
                });
                
                // Calculate and add lowest price (minimum from housing options)
                if (housingOptions.length > 0) {
                    const lowest_price = Math.min(...housingOptions.map(option => option.price));
                    formData.append('lowest_price', lowest_price);
                }
                
                // Collect services, notes, and rules from simple inputs
                const includedServices = Array.from(document.querySelectorAll('input[name="included_services[]"]'))
                    .map(input => input.value.trim())
                    .filter(value => value !== '');
                
                const notIncludedServices = Array.from(document.querySelectorAll('input[name="not_included_services[]"]'))
                    .map(input => input.value.trim())
                    .filter(value => value !== '');
                
                const notes = Array.from(document.querySelectorAll('input[name="notes[]"]'))
                    .map(input => input.value.trim())
                    .filter(value => value !== '');
                
                const cancellingRules = Array.from(document.querySelectorAll('input[name="cancelling_rules[]"]'))
                    .map(input => input.value.trim())
                    .filter(value => value !== '');
                
                formData.append('included_services', JSON.stringify(includedServices));
                formData.append('not_included_services', JSON.stringify(notIncludedServices));
                formData.append('notes', JSON.stringify(notes));
                formData.append('cancelling_rules', JSON.stringify(cancellingRules));
                
                const response = await fetch('/partner/add-card', {
                    method: 'POST',
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.success) {
                    alert(result.message);
                    hideAddTripForm();
                    this.reset();
                    refreshStats();
                    location.reload(); // Refresh to show the new card
                } else {
                    alert('خطأ: ' + result.message);
                }
                
            } catch (error) {
                console.error('Error submitting form:', error);
                alert('حدث خطأ أثناء إرسال النموذج');
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = originalText;
            }
        });
        
