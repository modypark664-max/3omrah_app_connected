            <div class="card-header">
                <span class="card-icon">📄</span>
                <h2 class="card-title">إدارة نصوص الصفحة الرئيسية</h2>
            </div>
            
            <% if (pageContents && pageContents.length > 0) { %>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 20px;">
                    <% 
                        // Group content by sections (excluding package pages)
                        const sections = {
                            hero: pageContents.filter(c => c.contentType.startsWith('hero_')),
                            omrah: pageContents.filter(c => c.contentType.startsWith('omrah_')),
                            internal: pageContents.filter(c => c.contentType.startsWith('internal_tours_')),
                            external: pageContents.filter(c => c.contentType.startsWith('external_tours_')),
                            partners: pageContents.filter(c => c.contentType.startsWith('partners_')),
                            gallery: pageContents.filter(c => c.contentType.startsWith('gallery_')),
                            testimonials: pageContents.filter(c => c.contentType.startsWith('testimonial')),
                            about: pageContents.filter(c => c.contentType.startsWith('about_')),
                            common: pageContents.filter(c => ['view_more_text', 'contact_us_text', 'coming_soon_text'].includes(c.contentType))
                        };
                        
                        const sectionNames = {
                            hero: 'القسم الرئيسي (Hero)',
                            omrah: 'قسم العمرة',
                            internal: 'الرحلات الداخلية',
                            external: 'الرحلات الخارجية',
                            partners: 'قسم الشركاء',
                            gallery: 'قسم المعرض',
                            testimonials: 'قسم آراء العملاء',
                            about: 'قسم من نحن',
                            common: 'العناصر المشتركة'
                        };
                    %>
                    
                    <% Object.keys(sections).forEach(sectionKey => { %>
                        <% if (sections[sectionKey].length > 0) { %>
                            <div class="content-section-card" style="background: white; border: 2px solid #e2e8f0; border-radius: 12px; padding: 20px;">
                                <h3 style="color: #1E5470; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid #f1f5f9; font-size: 1.1rem;">
                                    <%= sectionNames[sectionKey] %>
                                </h3>
                                
                                <% sections[sectionKey].forEach(content => { %>
                                    <form action="/admin/page-content/<%= content._id %>" method="POST" style="margin-bottom: 20px; padding: 15px; background: #f8fafc; border-radius: 8px; border-left: 4px solid #34729C;">
                                        <div class="form-group" style="margin-bottom: 15px;">
                                            <label style="font-weight: 600; color: #1E5470; margin-bottom: 8px; display: block;">
                                                <% 
                                                    let labelText = content.contentType;
                                                    if (content.contentType.includes('title')) labelText = 'العنوان';
                                                    else if (content.contentType.includes('description')) labelText = 'الوصف';
                                                    else if (content.contentType.includes('button')) labelText = 'نص الزر';
                                                    else if (content.contentType === 'testimonial_user_name') labelText = 'اسم العميل';
                                                    else if (content.contentType === 'testimonial_text') labelText = 'نص الشهادة';
                                                    
                                                    // Handle package-specific labels
                                                    if (content.contentType === 'bundles_page_title') labelText = 'عنوان صفحة باقات العمرة';
                                                    else if (content.contentType === 'bundles_page_description') labelText = 'وصف صفحة باقات العمرة';
                                                    else if (content.contentType === 'inner_tours_page_title') labelText = 'عنوان صفحة الرحلات الداخلية';
                                                    else if (content.contentType === 'inner_tours_page_description') labelText = 'وصف صفحة الرحلات الداخلية';
                                                    else if (content.contentType === 'external_tours_page_title') labelText = 'عنوان صفحة الرحلات الخارجية';
                                                    else if (content.contentType === 'external_tours_page_description') labelText = 'وصف صفحة الرحلات الخارجية';
                                                    else if (content.contentType === 'haj_tours_page_title') labelText = 'عنوان صفحة رحلات الحج';
                                                    else if (content.contentType === 'haj_tours_page_description') labelText = 'وصف صفحة رحلات الحج';
                                                    else if (content.contentType === 'ramadan_tours_page_title') labelText = 'عنوان صفحة رحلات رمضان';
                                                    else if (content.contentType === 'ramadan_tours_page_description') labelText = 'وصف صفحة رحلات رمضان';
                                                    else if (content.contentType === 'all_packages_page_title') labelText = 'عنوان صفحة جميع الباقات';
                                                    else if (content.contentType === 'all_packages_page_description') labelText = 'وصف صفحة جميع الباقات';
                                                %>
                                                <%= labelText %>:
                                            </label>
                                            
                                            <% if (content.contentType.includes('description') || content.contentType === 'testimonial_text' || content.contentType === 'about_description') { %>
                                                <textarea name="content" rows="3" maxlength="1000" required style="width: 100%; padding: 10px; border: 1px solid #e2e8f0; border-radius: 6px; font-family: inherit; resize: vertical;"><%= content.content %></textarea>
                                            <% } else { %>
                                                <input type="text" name="content" value="<%= content.content %>" maxlength="200" required style="width: 100%; padding: 10px; border: 1px solid #e2e8f0; border-radius: 6px;">
                                            <% } %>
                                        </div>
                                        
                                        <div style="display: flex; justify-content: space-between; align-items: center;">
                                            <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 14px;">
                                                <input type="checkbox" name="isActive" value="true" <%= content.isActive ? 'checked' : '' %> style="width: auto;">
                                                تفعيل المحتوى
                                            </label>
                                            
                                            <button type="submit" class="btn-add-card" style="padding: 8px 16px; font-size: 13px; border-radius: 6px;">
                                                حفظ
                                            </button>
                                        </div>
                                    </form>
                                <% }) %>
                            </div>
                        <% } %>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <p>لا توجد محتويات محفوظة بعد</p>
                    <p style="font-size: 14px; margin-top: 10px;">سيتم إنشاء المحتوى الافتراضي تلقائياً عند تشغيل الخادم</p>
                </div>
            <% } %>
        </div>
        
        <!-- Partner Tier Limits Management -->
        <div class="form-section">
            <div class="card-header">
                <div class="card-icon">📊</div>
                <div class="card-title">إدارة حدود باقات الشركاء</div>
            </div>
            
            <div style="background: #f0f9ff; border: 1px solid #0ea5e9; border-radius: 8px; padding: 15px; margin-bottom: 20px;">
                <p style="margin: 0; color: #0c4a6e; font-weight: 500;">⚙️ تحديد الحد الأقصى للباقات المسموح بها لكل مستوى شريك. استخدم -1 للحصول على عدد غير محدود.</p>
            </div>

            <form action="/admin/partner-tier-limits" method="POST">
                <div class="form-grid">
                    <div class="form-group">
                        <label for="basic">الباقة الأساسية (Basic):</label>
                        <input type="number" 
                               id="basic" 
                               name="basic" 
                               value="<%= partnerTierLimits.basic %>" 
                               min="0" 
                               required
                               style="width: 100%;">
                        <small style="color: #64748b; font-size: 12px;">الحد الأقصى للباقات للشركاء الأساسيين</small>
                    </div>
                    
                    <div class="form-group">
                        <label for="professional">الباقة الاحترافية (Professional):</label>
                        <input type="number" 
                               id="professional" 
                               name="professional" 
                               value="<%= partnerTierLimits.professional %>" 
                               min="0" 
                               required
                               style="width: 100%;">
                        <small style="color: #64748b; font-size: 12px;">الحد الأقصى للباقات للشركاء الاحترافيين</small>
                    </div>
                    
                    <div class="form-group">
                        <label for="premium">الباقة المميزة (Premium):</label>
                        <input type="number" 
                               id="premium" 
                               name="premium" 
                               value="<%= partnerTierLimits.premium %>" 
                               min="-1" 
                               required
                               style="width: 100%;">
                        <small style="color: #64748b; font-size: 12px;">الحد الأقصى للباقات للشركاء المميزين (-1 = غير محدود)</small>
                    </div>
                </div>
                
                <div style="margin-top: 20px; padding-top: 15px; border-top: 1px solid #e2e8f0;">
                    <div style="background: #fef3c7; border: 1px solid #f59e0b; border-radius: 8px; padding: 12px; margin-bottom: 15px;">
                        <p style="margin: 0; color: #92400e; font-size: 14px;">
                            <strong>تنبيه:</strong> تغيير هذه القيم سيؤثر على قدرة الشركاء الحاليين والجدد على إضافة باقات جديدة فوراً.
                        </p>
                    </div>
                    <button type="submit" class="btn-add-card">حفظ حدود الباقات</button>
                </div>
            </form>
        </div>
        <% } %>
        
        <!-- Partner Logos Management -->
        <% if (!user.permissions || user.permissions.length === 0 || user.permissions.includes('full_admin_access') || user.permissions.includes('manage_partner_logos')) { %>
        <div class="form-section">
            <div class="card-header">
                <div class="card-icon">🏢</div>
                <div class="card-title">إدارة شعارات الشركاء</div>
            </div>
            
            <div style="background: #f0f9ff; border: 1px solid #0ea5e9; border-radius: 8px; padding: 15px; margin-bottom: 20px;">
                <p style="margin: 0; color: #0c4a6e; font-weight: 500;">📋 يمكنك إضافة شعارات شركاء بدون حد أقصى. اختر عدة شعارات لإضافتها دفعة واحدة.</p>
            </div>
            
            <!-- Add New Logos Form -->
            <form action="/admin/partner-logos" method="POST" enctype="multipart/form-data" style="margin-bottom: 30px;">
                <input type="hidden" name="operation" value="add">
                <div class="form-group">
                    <label>إضافة شعارات جديدة:</label>
                    <input type="file" name="images" accept="image/*" multiple style="padding: 15px; border: 2px dashed #34729C; border-radius: 8px;">
                    <small style="color: #64748b; font-size: 12px; display: block; margin-top: 5px;">يمكنك اختيار عدة صور في المرة الواحدة</small>
                </div>
                <button type="submit" class="btn-add-card">إضافة الشعارات</button>
            </form>
            
            <!-- Replace All Logos Form -->
            <details style="margin-bottom: 20px;">
                <summary style="cursor: pointer; padding: 10px; background: #fef3c7; border-radius: 6px; color: #92400e; font-weight: 500;">⚠️ استبدال جميع الشعارات</summary>
                <form action="/admin/partner-logos" method="POST" enctype="multipart/form-data" style="margin-top: 15px; padding: 15px; background: #fefce8; border-radius: 6px;">
                    <input type="hidden" name="operation" value="replace">
                    <div class="form-group">
                        <label>شعارات جديدة (سيتم حذف الشعارات الحالية):</label>
                        <input type="file" name="images" accept="image/*" multiple required style="padding: 15px; border: 2px dashed #dc2626; border-radius: 8px;">
                        <small style="color: #dc2626; font-size: 12px; display: block; margin-top: 5px;"><strong>تحذير:</strong> سيتم حذف جميع الشعارات الحالية واستبدالها بالجديدة</small>
                    </div>
                    <button type="submit" class="btn-add-card" style="background: linear-gradient(135deg, #dc2626 0%, #991b1b 100%);" onclick="return confirm('هل أنت متأكد من استبدال جميع الشعارات؟ هذا الإجراء لا يمكن التراجع عنه.')">استبدال جميع الشعارات</button>
                </form>
            </details>
            
            <!-- Current Logos Display -->
            <div class="section-title">الشعارات الحالية (<%= partnerLogos ? partnerLogos.length : 0 %>)</div>
            <% if (partnerLogos && partnerLogos.length > 0) { %>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; margin-top: 20px;">
                    <% partnerLogos.forEach(function(logo, index) { %>
                        <div style="position: relative; text-align: center; padding: 20px; border: 2px solid #e2e8f0; border-radius: 8px; background: white;">
                            <img src="<%= logo %>" alt="شعار الشريك <%= index + 1 %>" style="max-width: 100%; max-height: 100px; object-fit: contain;">
                            <div style="margin-top: 10px; font-size: 12px; color: #64748b;">شعار رقم <%= index + 1 %></div>
                            <button onclick="deletePartnerLogo(<%= index %>)" class="remove-btn" style="position: absolute; top: 5px; right: 5px; width: 25px; height: 25px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; padding: 0;">×</button>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div style="text-align: center; padding: 40px; color: #64748b; background: #f8fafc; border: 2px dashed #e2e8f0; border-radius: 8px;">
                    <div style="font-size: 48px; margin-bottom: 10px;">🏢</div>
                    <p style="margin: 0; font-size: 16px; font-weight: 500;">لا توجد شعارات شركاء</p>
                    <p style="margin: 5px 0 0 0; font-size: 14px;">أضف شعارات الشركاء لعرضها في الصفحة الرئيسية</p>
                </div>
            <% } %>
        </div>
        <% } %>

        <!-- Exclusive Gallery Cards Management -->
        <% if (!user.permissions || user.permissions.length === 0 || user.permissions.includes('full_admin_access') || user.permissions.includes('manage_exclusive_gallery')) { %>
        <div class="form-section">
            <div class="card-header">
                <div class="card-icon">⭐</div>
                <div class="card-title">إدارة العروض الحصرية (اختيار 3 باقات)</div>
            </div>
            
            <form action="/admin/exclusive-gallery" method="POST">
                <div class="section-title">اختر 3 باقات للعرض في قسم "عروض حصريه"</div>
                <div style="max-height: 400px; overflow-y: auto; border: 1px solid #e2e8f0; border-radius: 8px; padding: 20px; margin: 20px 0;">
                    <% if (cards && cards.length > 0) { %>
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 15px;">
                            <% cards.forEach(card => { %>
                                <label style="display: flex; align-items: center; padding: 15px; border: 2px solid #e2e8f0; border-radius: 8px; cursor: pointer; transition: all 0.3s ease;">
                                    <input type="checkbox" name="cardIds" value="<%= card._id %>" style="margin-left: 10px; transform: scale(1.2);">
                                    <div style="flex: 1;">
                                        <div style="font-weight: 600; color: #1E5470; margin-bottom: 5px;"><%= card.code %></div>
                                        <div style="font-size: 14px; color: #64748b; margin-bottom: 5px;"><%= card.title %></div>
                                        <div style="display: flex; gap: 10px; align-items: center;">
                                            <span class="status-badge <%= card.type === 'omrah' ? 'status-active' : card.type === 'internal_tour' ? 'status-pending' : 'status-partner' %>">
                                                <%= card.type === 'omrah' ? 'عمرة' : card.type === 'internal_tour' ? 'رحلة داخلية' : card.type === 'external_tour' ? 'رحلة خارجية' : card.type %>
                                            </span>
                                            <span style="font-size: 12px; color: #64748b;"><%= card.days %> أيام / <%= card.nights %> ليالي</span>
                                        </div>
                                    </div>
                                </label>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <div class="empty-state">
                            <p>لا توجد باقات متاحة للاختيار</p>
                        </div>
                    <% } %>
                </div>
                <div style="color: #dc2626; font-size: 14px; margin-bottom: 15px;">
                    <strong>تنبيه:</strong> يجب اختيار 3 باقات بالضبط للعرض في قسم العروض الحصرية
                </div>
                <button type="submit" class="btn-add-card">حفظ العروض الحصرية</button>
            </form>
        </div>
        <% } %>

        <!-- Hero Media Management (Images / Videos) -->
        <% if (!user.permissions || user.permissions.length === 0 || user.permissions.includes('full_admin_access') || user.permissions.includes('manage_hero_media')) { %>
        <div id="hero-media-management" class="form-section" style="border:2px solid #e2e8f0;">
            <div class="card-header">
                <div class="card-icon">🖼️</div>
                <div class="card-title">إدارة وسائط الهيرو (الصفحة الرئيسية)</div>
            </div>
            <p style="margin:-10px 0 20px 0; font-size:13px; color:#475569">أضف فيديو أو صور للواجهة. أول عنصر (أقل ترتيب) سيظهر كعنصر رئيسي، والبقية تُستخدم كصور جانبية ديكورية.</p>
            <form action="/admin/hero-media" method="POST" enctype="multipart/form-data" style="margin-bottom:25px;">
                <div class="form-grid">
                    <div class="form-group">
                        <label>نوع الوسائط:</label>
                        <select name="type" required>
                            <option value="">اختر</option>
                            <option value="image">صورة</option>
                            <option value="video">فيديو</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>رفع ملف (اختياري إذا وضعت رابط):</label>
                        <input type="file" name="file" accept="image/*,video/*">
                    </div>
                </div>
                <div class="form-grid">
                    <div class="form-group full-width">
                        <label>رابط خارجي (CDN/S3) إن وجد:</label>
                        <input type="text" name="url" placeholder="https://...">
                    </div>
                    <div class="form-group">
                        <label>الترتيب (0 = رئيسي):</label>
                        <input type="number" name="order" min="0" placeholder="0">
                    </div>
                </div>
                <button type="submit" class="btn-add-card">إضافة وسائط</button>
            </form>
            <div>
                <% if (heroMedia && heroMedia.length) { %>
                    <table class="data-table compact-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>معاينة</th>
                                <th>النوع</th>
                                <th>الرابط</th>
                                <th>الترتيب</th>
                                <th>الحالة</th>
                                <th>إجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% heroMedia.forEach((item, idx) => { %>
                                <tr>
                                    <td><%= idx + 1 %></td>
                                    <td style="max-width:140px;">
                                        <% if (item.type === 'image') { %>
                                            <img src="<%= item.url %>" style="width:120px;height:70px;object-fit:cover;border-radius:6px;" />
                                        <% } else { %>
                                            <video src="<%= item.url %>" style="width:120px;height:70px;object-fit:cover;border-radius:6px;" muted loop></video>
                                        <% } %>
                                    </td>
                                    <td><%= item.type === 'image' ? 'صورة' : 'فيديو' %></td>
                                    <td style="direction:ltr;font-size:11px;max-width:180px;overflow:hidden;text-overflow:ellipsis;">
                                        <%= item.url %>
                                    </td>
                                    <td>
                                        <input type="number" value="<%= item.order %>" style="width:70px;" onchange="updateHeroOrder('<%= item._id %>', this.value)" />
                                    </td>
                                    <td>
                                        <span class="status-badge <%= item.isActive ? 'status-active' : 'status-pending' %>">
                                            <%= item.isActive ? 'نشط' : 'معطل' %>
                                        </span>
                                    </td>
                                    <td class="action-buttons">
                                        <button class="edit-btn" onclick="toggleHeroMedia('<%= item._id %>')"><%= item.isActive ? 'تعطيل' : 'تفعيل' %></button>
                                        <button class="remove-btn" onclick="deleteHeroMedia('<%= item._id %>')">حذف</button>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } else { %>
                    <div class="empty-state">لا توجد وسائط مضافة بعد</div>
                <% } %>
            </div>
        </div>

        <!-- Contact Settings Management -->
        <% if (!user.permissions || user.permissions.length === 0 || user.permissions.includes('full_admin_access') || user.permissions.includes('manage_contact_settings')) { %>
        <div class="form-section">
            <div class="card-header">
                <div class="card-icon">📞</div>
                <div class="card-title">إعدادات التواصل العامة</div>
            </div>
            <form action="/admin/contact-settings" method="POST">
                <div class="form-grid">
                    <div class="form-group">
                        <label for="whatsappNumber">رقم الواتساب (يُستخدم في الأزرار والروابط):</label>
                        <input type="text" id="whatsappNumber" name="whatsappNumber" value="<%= (contactSettings && contactSettings.whatsappNumber) ? contactSettings.whatsappNumber : '' %>" placeholder="مثال: 01234567890" required>
                        <small style="color:#64748b;">يفضل بدون رموز، يمكن كتابة كود الدولة داخل الحقل (مثال: 201234567890).</small>
                    </div>
                    <div class="form-group">
                        <label for="phoneNumber">رقم الهاتف (للإتصال):</label>
                        <input type="text" id="phoneNumber" name="phoneNumber" value="<%= (contactSettings && contactSettings.phoneNumber) ? contactSettings.phoneNumber : '' %>" placeholder="مثال: 01234567890" required>
                    </div>
                    <div class="form-group">
                        <label for="email">البريد الإلكتروني:</label>
                        <input type="email" id="email" name="email" value="<%= (contactSettings && contactSettings.email) ? contactSettings.email : '' %>" placeholder="info@example.com" required>
                    </div>
                </div>
                <button type="submit" class="btn-add-card">حفظ إعدادات التواصل</button>
            </form>
        </div>

        <!-- Testimonials (Reviews) Management -->
        <div class="form-section">
            <div class="card-header">
                <div class="card-icon">⭐</div>
                <div class="card-title">إدارة آراء العملاء (التقييمات)</div>
            </div>
            <form action="/admin/testimonials/add" method="POST" style="margin-bottom:20px;">
                <div class="form-grid">
                    <div class="form-group">
                        <label>اسم العميل:</label>
                        <input type="text" name="name" placeholder="مثل: أحمد محمد" required>
                    </div>
                    <div class="form-group">
                        <label>التقييم:</label>
                        <select name="rating" required>
                            <option value="5">5</option>
                            <option value="4">4</option>
                            <option value="3">3</option>
                            <option value="2">2</option>
                            <option value="1">1</option>
                        </select>
                    </div>
                </div>
                <div class="form-group full-width">
                    <label>نص المراجعة:</label>
                    <textarea name="text" rows="3" placeholder="اكتب رأيك باختصار" required></textarea>
