            }
        }
        
        // Set minimum date for expiration to current date
        document.addEventListener('DOMContentLoaded', function() {
            const expirationInput = document.querySelector('input[name="expirationDate"]');
            if (expirationInput) {
                const now = new Date();
                now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
                expirationInput.min = now.toISOString().slice(0, 16);
            }

            // Date validation for card creation form
            const travelDateInput = document.getElementById('travel_date');
            const offerExpiryInput = document.getElementById('offer_expiry_date');
            
            function validateDates() {
                if (travelDateInput && offerExpiryInput && travelDateInput.value && offerExpiryInput.value) {
                    const travelDate = new Date(travelDateInput.value);
                    const expiryDate = new Date(offerExpiryInput.value);
                    
                    if (expiryDate >= travelDate) {
                        offerExpiryInput.setCustomValidity('تاريخ انتهاء العرض يجب أن يكون قبل تاريخ السفر');
                        offerExpiryInput.style.borderColor = '#ef4444';
                        return false;
                    } else {
                        offerExpiryInput.setCustomValidity('');
                        offerExpiryInput.style.borderColor = '#10b981';
                        return true;
                    }
                }
            }
            
            if (travelDateInput && offerExpiryInput) {
                travelDateInput.addEventListener('change', validateDates);
                offerExpiryInput.addEventListener('change', validateDates);
                
                // Set max date for expiry based on travel date
                travelDateInput.addEventListener('change', function() {
                    if (this.value) {
                        const travelDate = new Date(this.value);
                        travelDate.setDate(travelDate.getDate() - 1); // Set max to one day before travel
                        offerExpiryInput.max = travelDate.toISOString().split('T')[0];
                    }
                });
                
                // Set min date for travel based on expiry date
                offerExpiryInput.addEventListener('change', function() {
                    if (this.value) {
                        const expiryDate = new Date(this.value);
                        expiryDate.setDate(expiryDate.getDate() + 1); // Set min to one day after expiry
                        travelDateInput.min = expiryDate.toISOString().split('T')[0];
                    }
                });
            }

            // Feedback messages
            const params = new URLSearchParams(window.location.search);
            if (params.get('success') === 'hero-media-created') {
                alert('تمت إضافة وسائط الهيرو بنجاح');
                window.history.replaceState({}, document.title, window.location.pathname);
            } else if (params.get('error') === 'hero-media-failed') {
                alert('فشل في إضافة وسائط الهيرو');
                window.history.replaceState({}, document.title, window.location.pathname);
            } else if (params.get('success') === 'partner-logos-updated') {
                alert('تم تحديث شعارات الشركاء بنجاح');
                window.history.replaceState({}, document.title, window.location.pathname);
            } else if (params.get('error') === 'partner-logos-failed') {
                alert('فشل في تحديث شعارات الشركاء');
                window.history.replaceState({}, document.title, window.location.pathname);
            } else if (params.get('error') === 'partner-logos-validation') {
                alert('خطأ في التحقق من صحة البيانات');
                window.history.replaceState({}, document.title, window.location.pathname);
            } else if (params.get('error') === 'partner-logos-empty') {
                alert('يجب إضافة شعار واحد على الأقل');
                window.history.replaceState({}, document.title, window.location.pathname);
            }
        });
        
