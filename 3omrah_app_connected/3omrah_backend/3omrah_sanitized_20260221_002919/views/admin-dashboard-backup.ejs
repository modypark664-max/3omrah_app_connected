                    'external_tours_page_title': { label: 'عنوان صفحة الرحلات الخارجية', description: 'العنوان الذي يظهر في صفحة الرحلات الخارجية' },
                    'external_tours_page_description': { label: 'وصف صفحة الرحلات الخارجية', description: 'الوصف الذي يظهر أسفل العنوان في صفحة الرحلات الخارجية' },
                    'haj_tours_page_title': { label: 'عنوان صفحة رحلات الحج', description: 'العنوان الذي يظهر في صفحة رحلات الحج' },
                    'haj_tours_page_description': { label: 'وصف صفحة رحلات الحج', description: 'الوصف الذي يظهر أسفل العنوان في صفحة رحلات الحج' },
                    'ramadan_tours_page_title': { label: 'عنوان صفحة رحلات رمضان', description: 'العنوان الذي يظهر في صفحة رحلات رمضان' },
