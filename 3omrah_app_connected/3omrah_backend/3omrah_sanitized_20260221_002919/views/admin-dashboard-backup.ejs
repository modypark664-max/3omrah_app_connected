<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/imgs/logo.png">
    <link rel="shortcut icon" type="image/png" href="/imgs/logo.png">
    <link rel="apple-touch-icon" href="/imgs/logo.png">
    
    <title>لوحة التحكم الإدارية - منصة العمرة</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f8fafc;
            color: #1E5470;
        }
        
        .admin-header {
            background: linear-gradient(135deg, #1E5470 0%, #34729C 100%);
            color: white;
            padding: 20px 0;
            box-shadow: 0 4px 20px rgba(30, 84, 112, 0.3);
        }
        
        .header-content {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .logo-section {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .logo {
            font-size: 2rem;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
        }
        
        .admin-title {
            font-size: 1.5rem;
            font-weight: 600;
        }
        
        .admin-actions {
            display: flex;
            gap: 15px;
            align-items: center;
        }
        
        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 500;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s ease;
        }
        
        .btn-primary {
            background: rgba(255, 255, 255, 0.2);
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        
        .btn-primary:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
        }
        
        .admin-container {
            max-width: 1200px;
            margin: 30px auto;
            padding: 0 20px;
        }
        
        .dashboard-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 40px;
        }
        
        .dashboard-card {
            background: white;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(30, 84, 112, 0.1);
            border: 1px solid rgba(52, 114, 156, 0.1);
        }
        
        .card-header {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f1f5f9;
        }
        
        .card-icon {
            font-size: 2rem;
            color: #34729C;
        }
        
        .card-title {
            font-size: 1.3rem;
            font-weight: 600;
            color: #1E5470;
        }
        
        .tabs {
            display: flex;
            background: #f1f5f9;
            border-radius: 10px;
            padding: 5px;
            margin-bottom: 25px;
        }
        
        .tab {
            flex: 1;
            padding: 12px 20px;
            background: transparent;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 500;
            color: #64748b;
            transition: all 0.3s ease;
        }
        
        .tab:hover {
            background: rgba(52, 114, 156, 0.1);
            color: #1E5470;
        }
        
        .tab.active {
            background: white;
            color: #1E5470;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }
        
        .tab-content {
            display: none;
            animation: fadeIn 0.3s ease-in-out;
        }
        
        .tab-content.active {
            display: block;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: linear-gradient(135deg, #34729C 0%, #1E5470 100%);
            color: white;
            padding: 20px;
            border-radius: 12px;
            text-align: center;
        }
        
        .stat-number {
            font-size: 2rem;
            font-weight: bold;
            margin-bottom: 5px;
        }
        
        .stat-label {
            font-size: 0.9rem;
            opacity: 0.9;
        }
        
        .form-section {
            background: white;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(30, 84, 112, 0.1);
            margin-bottom: 30px;
        }
        
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        .form-group.full-width {
            grid-column: 1 / -1;
        }
        
        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #1E5470;
        }
        
        input, select, textarea {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e1e8ed;
            border-radius: 8px;
            font-size: 14px;
            transition: all 0.3s ease;
        }
        
        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: #34729C;
            box-shadow: 0 0 0 3px rgba(52, 114, 156, 0.1);
        }
        
        .btn-add-card {
            background: linear-gradient(135deg, #34729C 0%, #1E5470 100%);
            color: white;
            padding: 15px 30px;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(52, 114, 156, 0.3);
        }
        
        .btn-add-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(52, 114, 156, 0.4);
        }
        
        .data-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        }
        
        .data-table th {
            background: linear-gradient(135deg, #1E5470 0%, #34729C 100%);
            color: white;
            padding: 15px;
            font-weight: 600;
            text-align: right;
        }
        
        .data-table td {
            padding: 15px;
            border-bottom: 1px solid #f1f5f9;
            color: #334155;
        }
        
        .data-table tr:hover {
            background: #f8fafc;
        }
        
        .status-badge {
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }
        
        .status-active {
            background: #dcfce7;
            color: #166534;
        }
        
        .status-admin {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
            color: white;
        }
        
        .status-paid {
            background: linear-gradient(135deg, #059669 0%, #10b981 100%);
            color: white;
        }
        
        .status-pending {
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
            color: white;
        }
        
        .status-cancelled {
            background: linear-gradient(135deg, #6b7280 0%, #4b5563 100%);
            color: white;
        }
        
        .status-partner {
            background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
            color: white;
        }
        
        .status-verified {
            background: linear-gradient(135deg, #059669 0%, #10b981 100%);
            color: white;
        }
        
        .package-badge {
            padding: 4px 10px;
            border-radius: 15px;
            font-size: 11px;
            font-weight: 600;
            display: inline-block;
        }
        
        .package-basic {
            background: linear-gradient(135deg, #64748b 0%, #475569 100%);
            color: white;
        }
        
        .package-professional {
            background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
            color: white;
        }
        
        .package-premium {
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
            color: white;
        }
        
        .partner-info,
        .representative-info {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2px;
        }
        
        .company-name,
        .rep-name {
            font-weight: 600;
            font-size: 12px;
            color: #1E5470;
        }
        
        .phone-number,
        .username {
            font-size: 10px;
            color: #64748b;
        }
        
        .date-info {
            font-size: 11px;
            color: #64748b;
            text-align: center;
        }
        
        .partner-card {
            background: white;
            border: 2px solid #8b5cf6;
            border-radius: 12px;
            margin-bottom: 15px;
            box-shadow: 0 4px 15px rgba(139, 92, 246, 0.1);
            overflow: hidden;
        }
        
        .partner-card .card-header-row {
            background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
            border-bottom: 1px solid #8b5cf6;
        }
        
        .partner-card .company-name {
            font-size: 16px;
            font-weight: 700;
            color: #7c3aed;
        }
        
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #64748b;
            background: #f8fafc;
            border-radius: 12px;
            border: 2px dashed #e2e8f0;
        }
        
        .table-container {
            overflow-x: auto;
            margin: 20px 0;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        }
        
        .action-buttons {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
            min-width: 120px;
        }
        
        .action-buttons .edit-btn,
        .action-buttons .remove-btn {
            padding: 6px 12px;
            font-size: 11px;
            white-space: nowrap;
        }        .hotel-item {
            background: #f8fafc;
            border: 2px solid #e1e8ed;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 15px;
        }
        
        .hotel-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 15px;
            margin-bottom: 15px;
        }
        
        .housing-item {
            background: #f1f5f9;
            border: 2px solid #e1e8ed;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 10px;
        }
        
        .housing-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }
        
        .add-btn {
            background: #34729C;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 500;
            margin: 10px 0;
        }
        
        .remove-btn {
            background: #ef4444;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 12px;
            margin-left: 5px;
        }
        
        .edit-btn {
            background: #3b82f6;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 12px;
            margin-left: 5px;
        }
        
        .edit-btn:hover {
            background: #2563eb;
        }
        
        .remove-btn:hover {
            background: #dc2626;
        }
        
        .section-title {
            color: #1E5470;
            font-size: 1.1rem;
            font-weight: 600;
            margin: 20px 0 15px 0;
            padding-bottom: 8px;
            border-bottom: 2px solid #34729C;
        }
        
        .array-item {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 10px;
            background: #f8fafc;
            padding: 15px;
            border-radius: 8px;
            border: 1px solid #e2e8f0;
        }
        
        .array-input {
            flex: 1;
            margin: 0;
        }
        
        .array-textarea {
            flex: 1;
            margin: 0;
            min-height: 80px;
            resize: vertical;
        }
        
        .array-item .remove-btn {
            margin: 0;
            align-self: flex-start;
            margin-top: 2px;
        }
        
        @media (max-width: 768px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
            }
            
            .form-grid {
                grid-template-columns: 1fr;
            }
            
            .header-content {
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }
            
            .admin-actions {
                flex-wrap: wrap;
                justify-content: center;
            }
            
            .hotel-grid {
                grid-template-columns: 1fr;
            }
            
            /* Hide desktop table on mobile */
            .desktop-table-view {
                display: none;
            }
            
            /* Show mobile card view */
            .mobile-card-view {
                display: block;
            }
        }
        
        /* Desktop styles - hide mobile view */
        .mobile-card-view {
            display: none;
        }
        
        /* Compact table styles for desktop */
        .compact-table {
            font-size: 13px;
        }
        
        .compact-table th,
        .compact-table td {
            padding: 8px 6px;
            text-align: center;
            white-space: nowrap;
        }
        
        .compact-table th {
            font-size: 12px;
        }
        
        .reservation-info,
        .user-info,
        .amount-info {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2px;
        }
        
        .reservation-number,
        .username,
        .amount {
            font-weight: 600;
            font-size: 12px;
        }
        
        .reservation-date,
        .phone,
        .card-code {
            font-size: 10px;
            color: #64748b;
            white-space: nowrap;
        }
        
        .compact-actions {
            display: flex;
            gap: 2px;
            justify-content: center;
            flex-wrap: nowrap;
        }
        
        .small-btn {
            padding: 4px 6px;
            font-size: 10px;
            min-width: 24px;
            height: 24px;
            border-radius: 4px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        
        /* Mobile card styles */
        .reservation-card {
            background: white;
            border: 1px solid #e1e8ed;
            border-radius: 12px;
            margin-bottom: 15px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }
        
        .card-header-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px;
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            border-bottom: 1px solid #e1e8ed;
        }
        
        .card-header-row .reservation-number {
            font-size: 16px;
            font-weight: 600;
            color: #1E5470;
        }
        
        .card-body {
            padding: 15px;
        }
        
        .info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid #f1f5f9;
        }
        
        .info-row:last-child {
            border-bottom: none;
        }
        
        .info-row .label {
            font-weight: 600;
            color: #1E5470;
            font-size: 14px;
            min-width: 80px;
        }
        
        .info-row .value {
            color: #334155;
            font-size: 14px;
            text-align: left;
        }
        
        .card-actions {
            padding: 15px;
            background: #f8fafc;
            border-top: 1px solid #e1e8ed;
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }
        
        .mobile-action-btn {
            flex: 1;
            min-width: 100px;
            padding: 8px 12px;
            font-size: 12px;
            border-radius: 6px;
            border: none;
            cursor: pointer;
            font-weight: 500;
            transition: all 0.2s ease;
        }
        
        .mobile-action-btn.edit-btn {
            background: #3b82f6;
            color: white;
        }
        
        .mobile-action-btn.edit-btn:hover {
            background: #2563eb;
        }
        
        .mobile-action-btn.remove-btn {
            background: #ef4444;
            color: white;
        }
        
        .mobile-action-btn.remove-btn:hover {
            background: #dc2626;
        }
        
        /* Tablet responsive adjustments */
        @media (max-width: 1024px) and (min-width: 769px) {
            .compact-table {
                font-size: 12px;
            }
            
            .compact-table th,
            .compact-table td {
                padding: 6px 4px;
            }
            
            .reservation-number,
            .username,
            .amount {
                font-size: 11px;
            }
            
            .reservation-date,
            .phone,
            .card-code {
                font-size: 9px;
            }
            
            .small-btn {
                padding: 3px 5px;
                font-size: 9px;
                min-width: 20px;
                height: 20px;
            }
        }
        /* Inline edit form visibility */
        .inline-edit-form.active { display: block !important; }
        
        /* Card Order Management Styles - Improved UX */
        .order-management-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding: 15px;
            background: linear-gradient(135deg, #e0f2fe 0%, #f0f9ff 100%);
            border-radius: 10px;
            border: 1px solid #0ea5e9;
        }
        
        .cards-count {
            color: #0c4a6e;
            font-weight: 600;
            font-size: 1.1rem;
        }
        
        .bulk-actions {
            display: flex;
            gap: 10px;
            align-items: center;
        }
        
        .reset-order-btn {
            background: #f59e0b;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 12px;
            font-weight: 500;
            transition: all 0.3s ease;
        }
        
        .reset-order-btn:hover {
            background: #d97706;
            transform: translateY(-1px);
        }
        
        .order-cards-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 15px;
            max-height: 60vh;
            overflow-y: auto;
            padding: 15px;
            background: #fafbfc;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
        }
        
        .order-card-item {
            display: flex;
            flex-direction: column;
            gap: 10px;
            padding: 15px;
            background: white;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
            position: relative;
            height: fit-content;
        }
        
        .order-card-item:hover {
            border-color: #1e5470;
            box-shadow: 0 4px 15px rgba(30, 84, 112, 0.15);
            transform: translateY(-2px);
        }
        
        .card-header-order {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 10px;
        }
        
        .card-info {
            flex: 1;
            min-width: 0;
        }
        
        .card-code {
            font-weight: 700;
            color: #1e5470;
            font-size: 1.1rem;
            margin-bottom: 5px;
            word-break: break-word;
        }
        
        .card-type {
            display: inline-block;
            background: linear-gradient(135deg, #34729C 0%, #1E5470 100%);
            color: white;
            padding: 4px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
            margin-bottom: 5px;
        }
        
        .card-date {
            font-size: 12px;
            color: #64748b;
            margin: 0;
        }
        
        .current-order-badge {
            background: #f1f5f9;
            color: #1e5470;
            padding: 6px 10px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            border: 1px solid #e2e8f0;
            white-space: nowrap;
        }
        
        .order-controls {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px;
            background: #f8fafc;
            border-radius: 8px;
            margin-top: 5px;
        }
        
        .order-controls label {
            font-weight: 600;
            color: #1e5470;
            margin: 0;
            font-size: 13px;
        }
        
        .order-input {
            width: 60px;
            padding: 6px 8px;
            border: 2px solid #e2e8f0;
            border-radius: 6px;
            text-align: center;
            font-weight: 700;
            font-size: 14px;
            color: #1e5470;
            transition: all 0.3s ease;
        }
        
        .order-input:focus {
            outline: none;
            border-color: #1e5470;
            box-shadow: 0 0 0 3px rgba(30, 84, 112, 0.1);
            background: white;
        }
        
        .order-input.updating {
            background: #fef3c7;
            border-color: #f59e0b;
        }
        
        .order-input.success {
            background: #dcfce7;
            border-color: #16a34a;
        }
        
        /* Search and Filter for Order Management */
        .order-search-container {
            margin-bottom: 15px;
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
        }
        
        .order-search-input {
            flex: 1;
            min-width: 200px;
            padding: 10px 15px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            font-size: 14px;
            transition: border-color 0.3s ease;
        }
        
        .order-search-input:focus {
            outline: none;
            border-color: #1e5470;
            box-shadow: 0 0 0 3px rgba(30, 84, 112, 0.1);
        }
        
        .sort-select {
            padding: 10px 15px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            background: white;
            color: #1e5470;
            font-weight: 500;
            cursor: pointer;
        }
        
        /* Scrollbar styling for the container */
        .order-cards-container::-webkit-scrollbar {
            width: 8px;
        }
        
        .order-cards-container::-webkit-scrollbar-track {
            background: #f1f5f9;
            border-radius: 4px;
        }
        
        .order-cards-container::-webkit-scrollbar-thumb {
            background: #94a3b8;
            border-radius: 4px;
        }
        
        .order-cards-container::-webkit-scrollbar-thumb:hover {
            background: #64748b;
        }
        
        /* Animation for order updates */
        @keyframes orderUpdated {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }
        
        .order-card-item.order-updated {
            animation: orderUpdated 0.5s ease-in-out;
        }
        
        @media (max-width: 768px) {
            .order-cards-container {
                grid-template-columns: 1fr;
                max-height: 50vh;
                gap: 10px;
                padding: 10px;
            }
            
            .order-card-item {
                padding: 12px;
            }
            
            .card-header-order {
                flex-direction: column;
                gap: 8px;
            }
            
            .current-order-badge {
                align-self: flex-start;
            }
            
            .order-search-container {
                flex-direction: column;
            }
            
            .order-search-input {
                min-width: 100%;
            }
            
            .order-management-header {
                flex-direction: column;
                gap: 10px;
                text-align: center;
            }
        }
        
        @media (max-width: 1200px) and (min-width: 769px) {
            .order-cards-container {
                grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            }
        }
        
        /* Permission Management Modal Styles */
        .permissions-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 1000;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        
        .modal-content {
            background: white;
            border-radius: 15px;
            max-width: 800px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }
        
        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 25px;
            border-bottom: 1px solid #e2e8f0;
            background: linear-gradient(135deg, #1E5470 0%, #34729C 100%);
            color: white;
            border-radius: 15px 15px 0 0;
        }
        
        .modal-header h3 {
            margin: 0;
            font-size: 1.4rem;
            font-weight: 700;
        }
        
        .modal-close {
            background: transparent;
            border: none;
            color: white;
            font-size: 1.8rem;
            cursor: pointer;
            padding: 0;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            transition: background-color 0.3s ease;
        }
        
        .modal-close:hover {
            background: rgba(255, 255, 255, 0.2);
        }
        
        .modal-body {
            padding: 25px;
        }
        
        .user-info-section {
            background: #f8fafc;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 25px;
            border: 1px solid #e2e8f0;
        }
        
        .user-info-section h4 {
            margin: 0 0 10px 0;
            color: #1E5470;
            font-size: 1.2rem;
            font-weight: 700;
        }
        
        .user-info-section p {
            margin: 5px 0;
            color: #64748b;
            font-weight: 500;
        }
        
        .permissions-section h4 {
            color: #1E5470;
            font-size: 1.1rem;
            font-weight: 700;
            margin: 0 0 15px 0;
        }
        
        .bulk-actions-section {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        
        .permissions-container {
            max-height: 400px;
            overflow-y: auto;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 20px;
        }
        
        .permission-category {
            margin-bottom: 25px;
        }
        
        .category-title {
            color: #1E5470;
            font-weight: 700;
            font-size: 1rem;
            margin-bottom: 15px;
            padding: 10px;
            background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
            border-radius: 8px;
            border-left: 4px solid #1E5470;
        }
        
        .permissions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 12px;
            margin-left: 15px;
        }
        
        .permission-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 12px;
            border-radius: 6px;
            transition: background-color 0.2s ease;
        }
        
        .permission-item:hover {
            background: #f1f5f9;
        }
        
        .permission-item input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: #1E5470;
        }
        
        .permission-item label {
            cursor: pointer;
            font-weight: 500;
            color: #374151;
            margin: 0;
            flex: 1;
        }
        
        .modal-footer {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            padding: 20px 25px;
            border-top: 1px solid #e2e8f0;
            background: #f8fafc;
            border-radius: 0 0 15px 15px;
        }
        
        .modal-footer .btn {
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .modal-footer .btn-primary {
            background: linear-gradient(135deg, #1E5470 0%, #34729C 100%);
            color: white;
        }
        
        .modal-footer .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(30, 84, 112, 0.3);
        }
        
        .modal-footer .btn-secondary {
            background: #6b7280;
            color: white;
        }
        
        .modal-footer .btn-secondary:hover {
            background: #4b5563;
        }
        
        @media (max-width: 768px) {
            .modal-content {
                width: 95%;
                margin: 20px;
            }
            
            .permissions-grid {
                grid-template-columns: 1fr;
            }
            
            .modal-header {
                padding: 15px 20px;
            }
            
            .modal-body {
                padding: 20px;
            }
            
            .bulk-actions-section {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <header class="admin-header">
        <div class="header-content">
            <div class="logo-section">
                <div class="logo">🕋</div>
                <div class="admin-title">لوحة التحكم الإدارية</div>
            </div>
            <div class="admin-actions">
                <a href="/admin/access" class="btn btn-primary">لوحة التحكم المبسطة</a>
                <a href="/" class="btn btn-primary">العودة للموقع</a>
                <a href="/logout" class="btn btn-primary">تسجيل الخروج</a>
            </div>
        </div>
    </header>

    <div class="admin-container">
        <!-- Statistics Cards -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-number"><%= stats.totalCards %></div>
                <div class="stat-label">إجمالي البطاقات</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= stats.totalUsers %></div>
                <div class="stat-label">إجمالي المستخدمين</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= stats.totalReservations %></div>
                <div class="stat-label">إجمالي الحجوزات</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= stats.totalPartners || 0 %></div>
                <div class="stat-label">الشركاء المسجلون</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= stats.verifiedPartners || 0 %></div>
                <div class="stat-label">الشركاء المُفعلون</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= stats.activeUsers %></div>
                <div class="stat-label">المستخدمين النشطين</div>
            </div>
        </div>

        <!-- Main Dashboard Grid -->
        <div class="dashboard-grid">
            <!-- Card Management Section -->
            <% if (!user.permissions || user.permissions.length === 0 || user.permissions.includes('full_admin_access') || user.permissions.some(p => ['add_card', 'edit_card', 'delete_card', 'approve_card', 'view_all_cards'].includes(p))) { %>
            <div class="dashboard-card">
                <div class="card-header">
                    <div class="card-icon">🎫</div>
                    <div class="card-title">إدارة البطاقات</div>
                </div>
                
                <div class="tabs">
                    <% if (!user.permissions || user.permissions.length === 0 || user.permissions.includes('full_admin_access') || user.permissions.includes('add_card')) { %>
                        <button class="tab active" onclick="switchTab('add-card')">إضافة بطاقة</button>
                    <% } %>
                    <% if (!user.permissions || user.permissions.length === 0 || user.permissions.includes('full_admin_access') || user.permissions.some(p => ['view_all_cards', 'edit_card'].includes(p))) { %>
                        <button class="tab" onclick="switchTab('view-cards')">عرض البطاقات</button>
                    <% } %>
                    <% if (!user.permissions || user.permissions.length === 0 || user.permissions.includes('full_admin_access') || user.permissions.includes('approve_card')) { %>
                        <button class="tab" onclick="switchTab('partner-cards')">مراجعة بطاقات الشركاء</button>
                    <% } %>
                </div>
                
                <% if (!user.permissions || user.permissions.length === 0 || user.permissions.includes('full_admin_access') || user.permissions.includes('add_card')) { %>
                <div id="add-card" class="tab-content active">
                    <form id="cardForm" action="/admin/post_card" method="POST" enctype="multipart/form-data">
                        <div class="form-grid">
                            <div class="form-group">
                                <label>نوع الرحلة:</label>
                                <select name="type" required>
                                    <option value="">اختر النوع</option>
                                    <option value="omrah">عمرة</option>
                                    <option value="internal_tour">رحلة داخلية</option>
                                    <option value="external_tour">رحلة خارجية</option>
                                    <option value="7ag">رحلة حج</option>
                                    <option value="ramadan">رحلة رمضان</option>
                                </select>
                            </div>
                            
                            <div class="form-group">
                                <label>كود الرحلة:</label>
                                <input type="text" name="code" value="OMR001" required>
                            </div>
                            
                            <div class="form-group">
                                <label>نوع العرض:</label>
                                <select name="offer_type" id="offer_type">
                                    <option value="">اختر نوع العرض</option>
                                    <!-- Options will be populated by JavaScript based on trip type -->
                                </select>
                            </div>
                            
                            <div class="form-group">
                                <label>عدد الأيام:</label>
                                <input type="number" name="days" value="7" min="1" required>
                            </div>
                            
                            <div class="form-group">
                                <label>عدد الليالي:</label>
                                <input type="number" name="nights" value="6" min="0" required>
                            </div>
                            
                            <div class="form-group">
                                <label>تاريخ السفر:</label>
                                <input type="date" name="travel_date" id="travel_date" value="2025-12-15" required>
                            </div>
                            
                            <div class="form-group">
                                <label>تاريخ انتهاء العرض:</label>
                                <input type="date" name="offer_expiry_date" id="offer_expiry_date" value="2025-11-30" required>
                                <small style="color: #6b7280; font-size: 12px; margin-top: 5px; display: block;">
                                    يجب أن يكون تاريخ انتهاء العرض قبل تاريخ السفر
                                </small>
                            </div>
                            
                            <div class="form-group">
                                <label>مسار الذهاب:</label>
                                <input type="text" name="going_route" value="الرياض - مكة المكرمة" required>
                            </div>
                            
                            <div class="form-group">
                                <label>مسار العودة:</label>
                                <input type="text" name="returning_route" value="المدينة المنورة - الرياض" required>
                            </div>
                            
                            <div class="form-group full-width">
                                <label>شركة الطيران:</label>
                                <input type="text" name="plane_company" value="الخطوط السعودية" required>
                            </div>
                            
                            <div class="form-group full-width">
                                <label>الشركة المرتبطة بالباقة:</label>
                                <input type="text" name="company" placeholder="اسم الشركة (اختياري)" maxlength="100">
                            </div>
                        </div>
                        
                        <div class="section-title">الصور</div>
                        <div class="form-grid">
                            <div class="form-group">
                                <label>الصورة الرئيسية:</label>
                                <input type="file" name="thumbnail" accept="image/*" required>
                            </div>
                            
                            <div class="form-group">
                                <label>صور إضافية:</label>
                                <input type="file" name="images" accept="image/*" multiple>
                            </div>
                        </div>
                        
                        <div class="section-title">معلومات الفنادق</div>
                        <div id="hotels-container">
                            <div class="hotel-item">
                                <div class="hotel-grid">
                                    <div class="form-group">
                                        <label>عدد الليالي:</label>
                                        <input type="number" class="hotel-nights" value="3" min="1" required>
                                    </div>
                                    <div class="form-group">
                                        <label>اسم الفندق:</label>
                                        <input type="text" class="hotel-name" value="فندق الحرم المكي" required>
                                    </div>
                                    <div class="form-group">
                                        <label>نوع الفندق:</label>
                                        <select class="hotel-type" required>
                                            <option value="">اختر النوع</option>
                                            <option value="اقتصادي">اقتصادي</option>
                                            <option value="سياحي" selected>سياحي</option>
                                            <option value="VIP">VIP</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="form-grid">
                                    <div class="form-group">
                                        <label>الموقع:</label>
                                        <input type="text" class="hotel-location" value="مكة المكرمة - قريب من الحرم" required>
                                    </div>
                                    <div class="form-group">
                                        <label>يشمل الطعام:</label>
                                        <select class="hotel-food" required>
                                            <option value="">اختر</option>
                                            <option value="true" selected>نعم</option>
                                            <option value="false">لا</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <button type="button" class="add-btn" data-action="addHotel">إضافة فندق آخر</button>
                        
                        <div class="section-title">خيارات الغرف</div>
                        <div id="housing-container">
                            <div class="housing-item">
                                <div class="housing-grid">
                                    <div class="form-group">
                                        <label>نوع الغرفة:</label>
                                        <input type="text" class="room-type" value="غرفة مزدوجة" required>
                                    </div>
                                    <div class="form-group">
                                        <label>السعر:</label>
                                        <input type="number" class="room-price" value="2500" min="0" required>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <button type="button" class="add-btn" data-action="addHousing">إضافة خيار غرفة آخر</button>
                        
                        <div class="section-title">الخدمات المشمولة</div>
                        <div id="included-services-container">
                            <div class="array-item">
                                <input type="text" class="array-input" value="تذاكر الطيران ذهاب وإياب">
                            </div>
                        </div>
                        <button type="button" class="add-btn" data-action="addIncludedService">إضافة خدمة</button>
                        
                        <div class="section-title">الخدمات غير المشمولة</div>
                        <div id="not-included-services-container">
                            <div class="array-item">
                                <input type="text" class="array-input" value="الوجبات الشخصية خارج الفندق">
                            </div>
                        </div>
                        <button type="button" class="add-btn" data-action="addNotIncludedService">إضافة خدمة</button>
                        
                        <div class="section-title">الملاحظات</div>
                        <div id="notes-container">
                            <div class="array-item">
                                <textarea class="array-textarea">يرجى إحضار جواز سفر ساري المفعول لمدة 6 أشهر على الأقل</textarea>
                            </div>
                        </div>
                        <button type="button" class="add-btn" data-action="addNote">إضافة ملاحظة</button>
                        
                        <div class="section-title">قواعد الإلغاء</div>
                        <div id="cancelling-rules-container">
                            <div class="array-item">
                                <textarea class="array-textarea">يمكن إلغاء الحجز خلال 48 ساعة من تاريخ الحجز مع استرداد كامل</textarea>
                            </div>
                        </div>
                        <button type="button" class="add-btn" data-action="addCancellingRule">إضافة قاعدة</button>
                        
                        <input type="hidden" name="plane" id="plane">
                        
                        <button type="submit" class="btn-add-card">إضافة البطاقة</button>
                    </form>
                </div>
                <% } %>
                
                <% if (!user.permissions || user.permissions.length === 0 || user.permissions.includes('full_admin_access') || user.permissions.some(p => ['view_all_cards', 'edit_card'].includes(p))) { %>
                <div id="view-cards" class="tab-content">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>الكود</th>
                                <th>النوع</th>
                                <th>نوع العرض</th>
                                <th>الشركة</th>
                                <th>الأيام</th>
                                <th>الليالي</th>
                                <th>تاريخ السفر</th>
                                <th>انتهاء العرض</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% cards.forEach(card => { %>
                                <tr>
                                    <td><%= card.code %></td>
                                    <td>
                                        <% if (card.type === 'omrah') { %>عمرة<% } %>
                                        <% if (card.type === 'internal_tour') { %>رحلة داخلية<% } %>
                                        <% if (card.type === 'external_tour') { %>رحلة خارجية<% } %>
                                        <% if (card.type === '7ag') { %>رحلة حج<% } %>
                                        <% if (card.type === 'ramadan') { %>رحلة رمضان<% } %>
                                    </td>
                                    <td><%= card.offer_type || 'غير محدد' %></td>
                                    <td><%= card.company || 'غير محدد' %></td>
                                    <td><%= card.days %></td>
                                    <td><%= card.nights %></td>
                                    <td><%= new Date(card.travel_date).toLocaleDateString('ar-SA') %></td>
                                    <td><%= card.offer_expiry_date ? new Date(card.offer_expiry_date).toLocaleDateString('ar-SA') : 'غير محدد' %></td>
                                    <td>
                                        <button class="edit-btn" data-action="editCard" data-card-id="<%= card._id %>">تعديل</button>
                                        <button class="remove-btn" data-action="deleteCard" data-card-id="<%= card._id %>" data-card-code="<%= card.code %>">حذف</button>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                <% } %>
                
                <% if (!user.permissions || user.permissions.length === 0 || user.permissions.includes('full_admin_access') || user.permissions.includes('approve_card')) { %>
                <div id="partner-cards" class="tab-content">
                    <div class="section-title">بطاقات الشركاء المعلقة للمراجعة</div>
                    <% const partnerCards = cards.filter(card => card.createdBy === 'partner'); %>
                    <% const pendingCards = partnerCards.filter(card => !card.isApproved); %>
                    <% const approvedCards = partnerCards.filter(card => card.isApproved); %>
                    
                    <% if (pendingCards.length > 0) { %>
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>الكود</th>
                                    <th>الشريك</th>
                                    <th>النوع</th>
                                    <th>نوع العرض</th>
                                    <th>الأيام</th>
                                    <th>الليالي</th>
                                    <th>تاريخ السفر</th>
                                    <th>انتهاء العرض</th>
                                    <th>الحالة</th>
                                    <th>الإجراءات</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% pendingCards.forEach(card => { %>
                                    <tr>
                                        <td><%= card.code %></td>
                                        <td>
                                            <div class="partner-info">
                                                <div class="company-name"><%= card.partnerId?.companyName || card.partnerId?.username || 'غير محدد' %></div>
                                            </div>
                                        </td>
                                        <td>
                                            <% if (card.type === 'omrah') { %>عمرة<% } %>
                                            <% if (card.type === 'internal_tour') { %>رحلة داخلية<% } %>
                                            <% if (card.type === 'external_tour') { %>رحلة خارجية<% } %>
                                            <% if (card.type === '7ag') { %>رحلة حج<% } %>
                                            <% if (card.type === 'ramadan') { %>رحلة رمضان<% } %>
                                        </td>
                                        <td><%= card.offer_type || 'غير محدد' %></td>
                                        <td><%= card.days %></td>
                                        <td><%= card.nights %></td>
                                        <td><%= new Date(card.travel_date).toLocaleDateString('ar-SA') %></td>
                                        <td><%= card.offer_expiry_date ? new Date(card.offer_expiry_date).toLocaleDateString('ar-SA') : 'غير محدد' %></td>
                                        <td>
                                            <span class="status-badge status-pending">معلق للمراجعة</span>
                                        </td>
                                        <td>
                                            <div class="action-buttons">
                                                <button class="edit-btn" onclick="approvePartnerCard('<%= card._id %>', '<%= card.code %>')">موافقة</button>
                                                <button class="remove-btn" onclick="rejectPartnerCard('<%= card._id %>', '<%= card.code %>')">رفض</button>
                                                <button class="edit-btn" onclick="viewPartnerCard('<%= card._id %>')">معاينة</button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                    <div class="empty-state">
                        <div class="empty-icon">📋</div>
                        <h3>لا توجد بطاقات معلقة للمراجعة</h3>
                        <p>ستظهر هنا البطاقات التي أنشأها الشركاء وتحتاج لموافقتك</p>
                    </div>
                    <% } %>
                    
                    <% if (approvedCards.length > 0) { %>
                    <div class="section-title" style="margin-top: 30px;">البطاقات المعتمدة من الشركاء</div>
                    <div class="table-container">
