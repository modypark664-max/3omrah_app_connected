        <!-- Partner Banner Management -->
        <% if (!user.permissions || user.permissions.length === 0 || user.permissions.includes('full_admin_access') || user.permissions.includes('manage_banners')) { %>
        <div class="form-section">
            <div class="card-header">
                <div class="card-icon">🤝</div>
                <div class="card-title">إدارة اعلانات الشراكة</div>
            </div>
            
            <!-- Add New Banner Form -->
            <form id="partnerBannerForm" action="/admin/partner-banner" method="POST" enctype="multipart/form-data">
                <div class="form-grid">
                    <div class="form-group full-width">
                        <label>العنوان الرئيسي:</label>
                        <textarea name="title" rows="3" placeholder="مثل: نحن فخورون بكوننا شريكاً رسمياً لقطار الحرمين السريع" required></textarea>
                    </div>
                </div>
                
                <div class="form-grid">
                    <div class="form-group">
                        <label>نص الشعار:</label>
                        <input type="text" name="logoText" placeholder="مثل: قطار الحرمين السريع" required>
                    </div>
                    
                    <div class="form-group">
                        <label>النص الفرعي للشعار:</label>
                        <input type="text" name="logoSubtext" placeholder="مثل: HARAMIN HIGH SPEED RAILWAY" required>
                    </div>
                </div>
                
                <div class="form-grid">
                    <div class="form-group full-width">
                        <label>الصورة الخلفية للبانر (اختيارية):</label>
                        <input type="file" name="backgroundImage" accept="image/*" placeholder="اختر صورة خلفية للبانر">
                        <small style="color: #64748b; margin-top: 5px; display: block;">سيتم عرض الصورة كخلفية للبانر إذا تم تحديدها</small>
                    </div>
                </div>
                
                <div class="form-grid">
                    <div class="form-group">
                        <label>تاريخ الانتهاء:</label>
                        <input type="datetime-local" name="expirationDate" required>
                    </div>
                    
                    <div class="form-group">
                        <label>الأولوية (0-100):</label>
                        <input type="number" name="priority" min="0" max="100" value="0" placeholder="الأولوية (أعلى رقم = أولوية أكبر)">
                    </div>
                </div>
                
                <input type="hidden" name="isActive" value="true">
                <button type="submit" class="btn-add-card">إضافة شعار جديد</button>
            </form>
            
            <!-- Existing Banners List -->
            <% if (partnerBanners && partnerBanners.length > 0) { %>
            <div class="section-title">الشعارات الحالية</div>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>العنوان</th>
                        <th>نص الشعار</th>
                        <th>الصورة الخلفية</th>
                        <th>تاريخ الانتهاء</th>
                        <th>الأولوية</th>
                        <th>الحالة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    <% partnerBanners.forEach(banner => { %>
                    <tr>
                        <td><%= banner.title.substring(0, 50) %>...</td>
                        <td><%= banner.logoText %></td>
                        <td>
                            <% if (banner.backgroundImage) { %>
                                <img src="<%= banner.backgroundImage %>" alt="خلفية البانر" style="width: 60px; height: 40px; object-fit: cover; border-radius: 4px;">
                            <% } else { %>
                                <span style="color: #64748b; font-style: italic;">لا توجد صورة</span>
                            <% } %>
                        </td>
                        <td>
                            <% 
                            const expirationDate = new Date(banner.expirationDate);
                            const now = new Date();
                            const isExpired = expirationDate < now;
                            const timeUntilExpiry = Math.ceil((expirationDate - now) / (1000 * 60 * 60 * 24));
                            %>
                            <span class="<%= isExpired ? 'status-cancelled' : (timeUntilExpiry <= 7 ? 'status-pending' : 'status-active') %>">
                                <%= expirationDate.toLocaleDateString('ar-EG') %>
                                <% if (isExpired) { %>
                                    (منتهي)
                                <% } else if (timeUntilExpiry <= 7) { %>
                                    (<%= timeUntilExpiry %> أيام)
                                <% } %>
                            </span>
                        </td>
                        <td><%= banner.priority %></td>
                        <td>
                            <span class="status-badge <%= banner.isActive ? 'status-active' : 'status-cancelled' %>">
                                <%= banner.isActive ? 'مفعل' : 'غير مفعل' %>
                            </span>
                        </td>
                        <td>
                            <button class="edit-btn" onclick="toggleBanner('<%= banner._id %>')">
                                <%= banner.isActive ? 'إلغاء تفعيل' : 'تفعيل' %>
                            </button>
                            <button class="remove-btn" onclick="deleteBanner('<%= banner._id %>')">حذف</button>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
            <% } else { %>
            <div class="empty-state">
                <p>لا توجد شعارات شراكة حالياً</p>
            </div>
            <% } %>
        </div>
        <% } %>
        
        <!-- Section Content Management -->
        <% if (!user.permissions || user.permissions.length === 0 || user.permissions.includes('full_admin_access') || user.permissions.includes('manage_section_content')) { %>
        <div class="form-section">
            <div class="card-header">
                <span class="card-icon">📝</span>
                <h2 class="card-title">إدارة محتوى أقسام الصفحة الرئيسية</h2>
            </div>
            
            <div class="section-content-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 25px;">
                <% if (sectionContents && sectionContents.length > 0) { %>
                    <% sectionContents.forEach(section => { %>
                        <div class="section-card" style="background: white; border: 2px solid #e2e8f0; border-radius: 12px; padding: 20px; box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);">
                            <div class="section-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                                <h3 style="color: #1E5470; margin: 0; font-size: 1.1rem;">
                                    <% if (section.sectionType === 'omrah') { %>
                                        قسم باقات العمرة
                                    <% } else if (section.sectionType === 'internal_tours') { %>
                                        قسم الرحلات الداخلية
                                    <% } else if (section.sectionType === 'external_tours') { %>
                                        قسم الرحلات الخارجية
                                    <% } %>
                                </h3>
                                <span class="status-badge <%= section.isActive ? 'status-active' : 'status-cancelled' %>">
                                    <%= section.isActive ? 'نشط' : 'معطل' %>
                                </span>
                            </div>
                            
                            <form action="/admin/section-content/<%= section._id %>" method="POST" style="display: flex; flex-direction: column; gap: 15px;">
                                <div class="form-group">
                                    <label for="title-<%= section._id %>">عنوان القسم:</label>
                                    <input type="text" id="title-<%= section._id %>" name="title" value="<%= section.title %>" maxlength="200" required style="font-weight: 600; color: #1E5470;">
                                </div>
                                
                                <div class="form-group">
                                    <label for="description-<%= section._id %>">وصف القسم:</label>
                                    <textarea id="description-<%= section._id %>" name="description" rows="4" maxlength="500" required style="resize: vertical; min-height: 100px;"><%= section.description %></textarea>
                                    <small style="color: #64748b; font-size: 12px;">الحد الأقصى: 500 حرف</small>
                                </div>
                                
                                <div class="form-group" style="display: none;">
                                    <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                                        <input type="checkbox" name="isActive" value="true" <%= section.isActive ? 'checked' : '' %> style="width: auto;">
                                        تفعيل القسم
                                    </label>
                                </div>
                                
                                <button type="submit" class="btn-add-card" style="padding: 12px 20px; font-size: 14px;">
                                    حفظ التعديلات
                                </button>
                            </form>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="empty-state" style="grid-column: 1 / -1;">
                        <p>لا توجد أقسام محفوظة بعد</p>
                        <p style="font-size: 14px; margin-top: 10px;">سيتم إنشاء الأقسام الافتراضية تلقائياً عند تشغيل الخادم</p>
                    </div>
                <% } %>
            </div>
        </div>
        <% } %>
        
