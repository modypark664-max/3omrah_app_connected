                    'all_packages_page_title': { label: 'عنوان صفحة جميع الباقات', description: 'العنوان الذي يظهر كعنوان افتراضي لجميع الباقات' },
                    'all_packages_page_description': { label: 'وصف صفحة جميع الباقات', description: 'الوصف الافتراضي الذي يظهر لجميع الباقات' }
