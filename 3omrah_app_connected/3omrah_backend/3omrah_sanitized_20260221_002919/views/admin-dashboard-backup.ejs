            } catch (e) {
                console.error(e);
                alert('حدث خطأ أثناء التحديث');
            }
        }

        async function deleteHeroMedia(id) {
            if (!confirm('هل أنت متأكد من حذف هذا العنصر؟')) return;
            try {
                const res = await fetch(`/admin/hero-media/${id}`, { method: 'DELETE' });
                const data = await res.json();
                if (data.success) {
                    alert('تم الحذف');
                    location.reload();
                } else {
                    alert(data.message || 'فشل الحذف');
                }
            } catch (e) {
                console.error(e);
                alert('حدث خطأ أثناء الحذف');
            }
        }

        let heroOrderUpdateTimer;
        function updateHeroOrder(id, value) {
            clearTimeout(heroOrderUpdateTimer);
            heroOrderUpdateTimer = setTimeout(async () => {
                try {
                    const res = await fetch(`/admin/hero-media/order/${id}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ order: value })
                    });
                    const data = await res.json();
                    if (!data.success) {
                        alert(data.message || 'لم يتم حفظ الترتيب');
                    }
                } catch (e) {
                    console.error(e);
                    alert('خطأ أثناء حفظ الترتيب');
                }
            }, 400); // debounce
        }

        // Exclusive Gallery Cards Selection Management
        document.addEventListener('DOMContentLoaded', function() {
            const exclusiveForm = document.querySelector('form[action="/admin/exclusive-gallery"]');
            if (exclusiveForm) {
                const checkboxes = exclusiveForm.querySelectorAll('input[name="cardIds"]');
                const maxSelection = 3;
                
                checkboxes.forEach(checkbox => {
                    checkbox.addEventListener('change', function() {
                        const checkedBoxes = exclusiveForm.querySelectorAll('input[name="cardIds"]:checked');
                        
                        if (checkedBoxes.length > maxSelection) {
                            this.checked = false;
                            alert(`يمكنك اختيار ${maxSelection} باقات فقط للعروض الحصرية`);
                            return;
                        }
                        
                        // Update visual feedback
                        checkboxes.forEach(cb => {
                            const label = cb.closest('label');
                            if (cb.checked) {
                                label.style.borderColor = '#34729C';
                                label.style.backgroundColor = '#f0f9ff';
                            } else {
                                label.style.borderColor = '#e2e8f0';
                                label.style.backgroundColor = 'white';
                            }
                        });
                        
                        // Update submit button
                        const submitBtn = exclusiveForm.querySelector('button[type="submit"]');
                        if (checkedBoxes.length === maxSelection) {
                            submitBtn.style.background = 'linear-gradient(135deg, #059669 0%, #10b981 100%)';
                            submitBtn.textContent = `حفظ العروض الحصرية (${checkedBoxes.length}/3)`;
                        } else {
                            submitBtn.style.background = 'linear-gradient(135deg, #34729C 0%, #1E5470 100%)';
                            submitBtn.textContent = `اختر ${maxSelection - checkedBoxes.length} باقات أخرى (${checkedBoxes.length}/3)`;
                        }
                    });
                });
                
                // Prevent form submission if not exactly 5 selected
                exclusiveForm.addEventListener('submit', function(e) {
                    const checkedBoxes = this.querySelectorAll('input[name="cardIds"]:checked');
                    if (checkedBoxes.length !== maxSelection) {
                        e.preventDefault();
                        alert(`يجب اختيار ${maxSelection} باقات بالضبط للعروض الحصرية`);
                    }
                });
            }
        });

        // Partner Logos Management
        async function deletePartnerLogo(index) {
            if (!confirm('هل أنت متأكد من حذف هذا الشعار؟')) {
                return;
            }
            
            try {
                const response = await fetch(`/admin/partner-logos/${index}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });
                
                const result = await response.json();
                
                if (result.success) {
                    alert(result.message);
                    location.reload();
                } else {
                    alert('خطأ: ' + result.message);
                }
            } catch (error) {
                console.error('Error deleting partner logo:', error);
                alert('حدث خطأ أثناء حذف الشعار');
            }
        }
        
        // Make deletePartnerLogo available globally
        window.deletePartnerLogo = deletePartnerLogo;

        // User management functions
        async function viewUserDetails(userId) {
            try {
                const response = await fetch(`/admin/user/details/${userId}`);
                if (response.ok) {
                    // Redirect to user details page
                    window.location.href = `/admin/user/details/${userId}`;
                } else {
                    alert('حدث خطأ أثناء تحميل تفاصيل المستخدم');
                }
            } catch (error) {
                console.error('Error viewing user details:', error);
                alert('حدث خطأ أثناء تحميل تفاصيل المستخدم');
            }
        }

        async function deleteUser(userId, username) {
            if (!confirm(`هل أنت متأكد من حذف المستخدم "${username}"؟\n\nسيتم حذف جميع البيانات المرتبطة بهذا المستخدم نهائياً.`)) {
                return;
            }

            try {
                const response = await fetch(`/admin/user/delete/${userId}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                const result = await response.json();

                if (result.success) {
                    alert(result.message);
                    location.reload();
                } else {
                    alert('خطأ: ' + result.message);
                }
            } catch (error) {
                console.error('Error deleting user:', error);
                alert('حدث خطأ أثناء حذف المستخدم');
            }
        }

        // Make functions available globally
        window.viewUserDetails = viewUserDetails;
        window.deleteUser = deleteUser;

        // Card Order Management Functions
        function switchOrderTab(tabName) {
            // Hide all tab contents
            const tabContents = document.querySelectorAll('#omrah-order, #internal-order, #external-order, #hag-order, #ramadan-order');
            tabContents.forEach(content => {
                content.classList.remove('active');
            });
            
            // Remove active class from all tabs in the order section
            const orderTabs = document.querySelectorAll('.form-section .tabs .tab');
            orderTabs.forEach(tab => {
                if (tab.onclick && tab.onclick.toString().includes('switchOrderTab')) {
                    tab.classList.remove('active');
                }
            });
            
            // Show selected tab content
            document.getElementById(tabName).classList.add('active');
            
            // Add active class to clicked tab
            event.target.classList.add('active');
        }

        async function updateCardOrder(cardId, newOrder, inputElement) {
            try {
                const response = await fetch(`/admin/card/update-order/${cardId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ displayOrder: parseInt(newOrder) })
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(`HTTP error! status: ${response.status}, response: ${errorText}`);
                }

                const result = await response.json();

                if (result.success) {
                    // Show success message briefly
                    const input = inputElement;
                    const originalBg = input.style.backgroundColor;
                    input.style.backgroundColor = '#dcfce7';
                    input.style.borderColor = '#10b981';
                    
                    setTimeout(() => {
                        input.style.backgroundColor = originalBg;
                        input.style.borderColor = '#e2e8f0';
                    }, 1000);
                } else {
                    alert('خطأ: ' + (result.message || 'فشل في تحديث ترتيب البطاقة'));
                }
            } catch (error) {
                console.error('Error updating card order:', error);
                alert('حدث خطأ أثناء تحديث ترتيب البطاقة: ' + error.message);
            }
        }

        function filterCards(tabId, searchTerm) {
            const tabElement = document.getElementById(tabId);
            const cards = tabElement.querySelectorAll('.order-card-item');
            const searchLower = searchTerm.toLowerCase().trim();
            
            let visibleCount = 0;
            
            cards.forEach(card => {
                const code = card.getAttribute('data-card-code').toLowerCase();
                const type = card.getAttribute('data-card-type').toLowerCase();
                
                const isVisible = code.includes(searchLower) || type.includes(searchLower);
                
                if (isVisible) {
                    card.style.display = 'flex';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });
            
            // Update visible count
            const countElement = tabElement.querySelector('.cards-count');
            if (countElement) {
                countElement.textContent = visibleCount;
            }
            
            // Show no results message if needed
            const container = tabElement.querySelector('.order-cards-container');
            let noResultsMsg = tabElement.querySelector('.no-results-message');
            
            if (visibleCount === 0 && searchTerm.trim() !== '') {
                if (!noResultsMsg) {
                    noResultsMsg = document.createElement('div');
                    noResultsMsg.className = 'no-results-message';
                    noResultsMsg.style.cssText = `
                        text-align: center;
                        padding: 40px 20px;
                        color: #64748b;
                        font-style: italic;
                        background: #f8fafc;
                        border-radius: 12px;
                        margin-top: 20px;
                    `;
                    noResultsMsg.textContent = 'لم يتم العثور على بطاقات مطابقة للبحث';
                    container.parentNode.appendChild(noResultsMsg);
                }
                noResultsMsg.style.display = 'block';
            } else {
                if (noResultsMsg) {
                    noResultsMsg.style.display = 'none';
                }
            }
        }

        // Make order functions available globally
        window.switchOrderTab = switchOrderTab;
        window.updateCardOrder = updateCardOrder;
        window.filterCards = filterCards;
        
        // ================= User Permission Management =================
        let currentUserId = null;
        let availablePermissions = [];
        
        // Load available permissions from the server
        async function loadAvailablePermissions() {
            try {
                const response = await fetch('/admin/permissions/available');
                if (response.ok) {
                    availablePermissions = await response.json();
                    return availablePermissions;
                } else {
                    throw new Error('Failed to load permissions');
                }
            } catch (error) {
                console.error('Error loading permissions:', error);
                alert('حدث خطأ في تحميل الصلاحيات');
                return [];
            }
        }
        
        // Open permission management modal
        async function manageUserPermissions(userId, username) {
            currentUserId = userId;
            
            // Load permissions if not already loaded
            if (availablePermissions.length === 0) {
                await loadAvailablePermissions();
            }
            
            // Load user data and current permissions
            try {
                const response = await fetch(`/admin/user/${userId}/permissions`);
                if (!response.ok) {
                    throw new Error('Failed to load user permissions');
                }
                
                const data = await response.json();
                const user = data.user;
                
                // Update modal with user info
                document.getElementById('selectedUserName').textContent = user.username;
                document.getElementById('selectedUserPhone').textContent = user.phoneNumber;
                document.getElementById('selectedUserRole').textContent = 
                    user.role === 'admin' ? 'مدير' : 
                    user.role === 'partner' ? 'شريك' : 'مستخدم';
                
                // Render permissions checkboxes
                renderPermissions(user.permissions || []);
                
                // Show modal
                document.getElementById('permissionsModal').style.display = 'flex';
                
            } catch (error) {
                console.error('Error loading user permissions:', error);
                alert('حدث خطأ في تحميل صلاحيات المستخدم');
            }
        }
        
        // Render permissions grouped by category
        function renderPermissions(userPermissions) {
            const container = document.getElementById('permissionsContainer');
            container.innerHTML = '';
            
            // Group permissions by category
            const grouped = availablePermissions.reduce((groups, permission) => {
                const category = permission.category;
                if (!groups[category]) {
                    groups[category] = [];
                }
                groups[category].push(permission);
                return groups;
            }, {});
            
            // Render each category
            Object.keys(grouped).forEach(category => {
                const categoryDiv = document.createElement('div');
                categoryDiv.className = 'permission-category';
                
                const categoryTitle = document.createElement('div');
                categoryTitle.className = 'category-title';
                categoryTitle.textContent = category;
                categoryDiv.appendChild(categoryTitle);
                
                const permissionsGrid = document.createElement('div');
                permissionsGrid.className = 'permissions-grid';
                
                grouped[category].forEach(permission => {
                    const permissionItem = document.createElement('div');
                    permissionItem.className = 'permission-item';
                    
                    const checkbox = document.createElement('input');
                    checkbox.type = 'checkbox';
                    checkbox.id = `perm_${permission.key}`;
                    checkbox.value = permission.key;
                    checkbox.checked = userPermissions.includes(permission.key);
                    
                    const label = document.createElement('label');
                    label.htmlFor = `perm_${permission.key}`;
                    label.textContent = permission.label;
                    
                    permissionItem.appendChild(checkbox);
                    permissionItem.appendChild(label);
                    permissionsGrid.appendChild(permissionItem);
                });
                
                categoryDiv.appendChild(permissionsGrid);
                container.appendChild(categoryDiv);
            });
        }
        
        // Select all permissions
        function selectAllPermissions() {
            const checkboxes = document.querySelectorAll('#permissionsContainer input[type="checkbox"]');
            checkboxes.forEach(checkbox => {
                checkbox.checked = true;
            });
        }
        
        // Deselect all permissions
        function deselectAllPermissions() {
            const checkboxes = document.querySelectorAll('#permissionsContainer input[type="checkbox"]');
            checkboxes.forEach(checkbox => {
                checkbox.checked = false;
            });
        }
        
        // Save user permissions
        async function saveUserPermissions() {
            if (!currentUserId) return;
            
            const checkboxes = document.querySelectorAll('#permissionsContainer input[type="checkbox"]:checked');
            const selectedPermissions = Array.from(checkboxes).map(cb => cb.value);
            
            try {
                const response = await fetch(`/admin/user/${currentUserId}/permissions`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ permissions: selectedPermissions })
                });
                
                if (response.ok) {
                    const result = await response.json();
                    alert('تم حفظ الصلاحيات بنجاح');
                    closePermissionsModal();
                    // Optionally refresh the page to show updated permissions
                    window.location.reload();
                } else {
                    const error = await response.json();
                    alert('حدث خطأ: ' + (error.error || 'فشل في حفظ الصلاحيات'));
                }
            } catch (error) {
                console.error('Error saving permissions:', error);
                alert('حدث خطأ أثناء حفظ الصلاحيات');
            }
        }
        
        // Close permission management modal
        function closePermissionsModal() {
            document.getElementById('permissionsModal').style.display = 'none';
            currentUserId = null;
        }
        
        // Close modal when clicking outside
        document.addEventListener('click', function(event) {
            const modal = document.getElementById('permissionsModal');
            if (event.target === modal) {
                closePermissionsModal();
            }
        });
        
        // Make permission functions available globally
        window.manageUserPermissions = manageUserPermissions;
        window.selectAllPermissions = selectAllPermissions;
        window.deselectAllPermissions = deselectAllPermissions;
        window.saveUserPermissions = saveUserPermissions;
        window.closePermissionsModal = closePermissionsModal;
        
        // Load permissions on page load
        document.addEventListener('DOMContentLoaded', function() {
            loadAvailablePermissions();
            
            // Initialize tab visibility based on permissions
            initializeTabVisibility();
        });
        
        // Initialize tab visibility and set first available tab as active
        function initializeTabVisibility() {
            // Initialize tabs based on available permissions for all dashboard cards
            const dashboardCards = document.querySelectorAll('.dashboard-card');
            
            dashboardCards.forEach((card, cardIndex) => {
                // Skip if card is hidden
                if (card.style.display === 'none' || card.classList.contains('d-none')) {
                    return;
                }
                
                const tabsContainer = card.querySelector('.tabs');
                if (!tabsContainer) return;
                
                const tabs = tabsContainer.querySelectorAll('.tab');
                const tabContents = card.querySelectorAll('.tab-content .tab-pane, .tab-content > div');
                
                if (tabs.length === 0) return;
                
                // Find first visible tab and content
                let firstVisibleTab = null;
                let firstVisibleTabContent = null;
                
                tabs.forEach(tab => {
                    // Get target from onclick attribute
                    const onclickAttr = tab.getAttribute('onclick');
                    let targetId = null;
                    
                    if (onclickAttr) {
                        const match = onclickAttr.match(/'([^']+)'/);
                        if (match) targetId = match[1];
                    }
                    
                    if (targetId) {
                        const tabContent = document.getElementById(targetId);
                        if (tabContent && tabContent.offsetParent !== null) {
                            if (!firstVisibleTab) {
                                firstVisibleTab = tab;
                                firstVisibleTabContent = tabContent;
                            }
                        }
                    }
                });
                
                // Activate first visible tab if found
                if (firstVisibleTab && firstVisibleTabContent) {
                    // Clear all active states in this card
                    tabs.forEach(tab => tab.classList.remove('active'));
                    tabContents.forEach(content => {
                        content.classList.remove('show', 'active');
                    });
                    
                    // Set first visible as active
                    firstVisibleTab.classList.add('active');
                    firstVisibleTabContent.classList.add('show', 'active');
                }
            });
        }
        
        // Call initialization when page loads
        document.addEventListener('DOMContentLoaded', function() {
            initializeTabVisibility();
        });
        
        // Also call it immediately in case DOM is already loaded
        initializeTabVisibility();
    </script>
</body>
</html>
