    <script>
        // Universal tab switching function
        function switchToTab(tabId) {
            // Hide all tab content
            const allTabContents = document.querySelectorAll('.tab-content > .tab-pane');
            allTabContents.forEach(content => {
                content.classList.remove('show', 'active');
            });
            
            // Remove active class from all tabs
            const allTabLinks = document.querySelectorAll('.nav-tabs .nav-link');
            allTabLinks.forEach(tab => {
                tab.classList.remove('active');
                tab.setAttribute('aria-selected', 'false');
            });
            
            // Show target tab content
            const targetContent = document.getElementById(tabId);
            if (targetContent) {
                targetContent.classList.add('show', 'active');
            }
            
            // Activate corresponding tab link
            const targetTab = document.querySelector(`[data-bs-target="#${tabId}"], [href="#${tabId}"]`);
            if (targetTab) {
                targetTab.classList.add('active');
                targetTab.setAttribute('aria-selected', 'true');
            }
        }

        // Dynamic offer type options based on trip type
        const typeSelect = document.querySelector('select[name="type"]');
        const offerTypeSelect = document.querySelector('select[name="offer_type"]');
        
        const offerTypeOptions = {
            'omrah': [
                { value: 'اقتصادي', text: 'اقتصادي' },
                { value: 'مميز', text: 'مميز' },
                { value: 'فاخر', text: 'فاخر' }
            ],
            '7ag': [
                { value: 'اقتصادي', text: 'اقتصادي' },
                { value: 'مميز', text: 'مميز' },
                { value: 'فاخر', text: 'فاخر' }
            ],
            'ramadan': [
                { value: 'اقتصادي', text: 'اقتصادي' },
                { value: 'مميز', text: 'مميز' },
                { value: 'فاخر', text: 'فاخر' }
            ],
            // Updated per request
            'external_tour': [
                { value: 'رحلات بتاشيره', text: 'رحلات بتاشيره' },
                { value: 'رحلات بدون تاشيره', text: 'رحلات بدون تاشيره' },
                { value: 'رحلات شهر العسل', text: 'رحلات شهر العسل' }
            ],
            'internal_tour': [
                { value: 'رحله يوم الواحد', text: 'رحله يوم الواحد' },
                { value: 'رحلات شهر العسل', text: 'رحلات شهر العسل' },
                { value: 'رحلات سياحيه', text: 'رحلات سياحيه' }
            ]
        };
        
        function updateOfferTypeOptions() {
            const selectedType = typeSelect.value;
            const options = offerTypeOptions[selectedType] || [];
            
            // Clear current options except the first one
            offerTypeSelect.innerHTML = '<option value="">اختر نوع العرض</option>';
            
            // Add new options
            options.forEach(option => {
                const optionElement = document.createElement('option');
                optionElement.value = option.value;
                optionElement.textContent = option.text;
                offerTypeSelect.appendChild(optionElement);
            });
            
            // Select default "مميز" if available
            if (options.some(opt => opt.value === 'مميز')) {
                offerTypeSelect.value = 'مميز';
            }
        }
        
        if (typeSelect && offerTypeSelect) {
            typeSelect.addEventListener('change', updateOfferTypeOptions);
            // Initialize on page load
            updateOfferTypeOptions();
        }
        
        // Banner management functions
        async function toggleBanner(bannerId) {
            try {
                const response = await fetch(`/admin/partner-banner/toggle/${bannerId}`, {
                    method: 'POST',
