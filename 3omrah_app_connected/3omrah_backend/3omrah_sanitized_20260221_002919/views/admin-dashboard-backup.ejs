                } else {
                    alert('خطأ: ' + result.message);
                }
            } catch (error) {
                console.error('Error toggling banner:', error);
                alert('حدث خطأ أثناء تعديل حالة البانر');
            }
        }
        
        async function deleteBanner(bannerId) {
            if (!confirm('هل أنت متأكد من حذف هذا البانر؟')) {
