<script id="user-data" type="application/json"><%- JSON.stringify(user || null).replace(/<\//g, '<\\/') %></script>

<script>
// Define user variable for card-interactions.js
const userDataNode = document.getElementById('user-data');
const user = userDataNode ? JSON.parse(userDataNode.textContent || 'null') : null;

document.addEventListener('DOMContentLoaded', function() {
  const filterForm = document.getElementById('filterForm');
  const filterInputs = filterForm.querySelectorAll('select, input');
  
  // Auto-submit form when filters change
  filterInputs.forEach(input => {
    input.addEventListener('change', function() {
      // Small delay to allow for multiple quick changes
      clearTimeout(this.submitTimeout);
      this.submitTimeout = setTimeout(() => {
        filterForm.submit();
      }, 500);
    });
  });
  
  // Prevent auto-submit for text inputs while typing
  const textInputs = filterForm.querySelectorAll('input[type="number"]');
  textInputs.forEach(input => {
    input.addEventListener('input', function() {
      clearTimeout(this.submitTimeout);
    });
  });

  // Wire offer-type chooser buttons
  const chooserButtons = document.querySelectorAll('.offer-type-card');
  chooserButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      if (!filterForm) return;
      const select = document.getElementById('offer_type');
      const showAllInput = document.getElementById('show_all');
      if (!select) return;
      const val = btn.getAttribute('data-offer-type');
      // __ALL__ clears the filter and sets a flag to show all results
      if (val === '__ALL__') {
        select.value = '';
        if (showAllInput) showAllInput.value = '1';
      } else {
        select.value = val;
        if (showAllInput) showAllInput.value = '';
      }
      filterForm.submit();
    });
  });
});
</script>

