<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تفاصيل المستخدم - <%= targetUser.username %></title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f8fafc;
            color: #1E5470;
        }
        
        .admin-header {
            background: linear-gradient(135deg, #1E5470 0%, #34729C 100%);
            color: white;
            padding: 20px 0;
            box-shadow: 0 4px 20px rgba(30, 84, 112, 0.3);
        }
        
        .header-content {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .header-title {
            font-size: 1.5rem;
            font-weight: 600;
        }
        
        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 500;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s ease;
        }
        
        .btn-secondary {
            background: rgba(255, 255, 255, 0.2);
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        
        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
        }
        
        .admin-container {
            max-width: 1200px;
            margin: 30px auto;
            padding: 0 20px;
        }
        
        .user-info-card {
            background: white;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(30, 84, 112, 0.1);
            border: 1px solid rgba(52, 114, 156, 0.1);
            margin-bottom: 30px;
        }
        
        .card-header {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f1f5f9;
        }
        
        .card-icon {
            font-size: 2rem;
            color: #34729C;
        }
        
        .card-title {
            font-size: 1.3rem;
            font-weight: 600;
            color: #1E5470;
        }
        
        .user-details-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .detail-item {
            background: #f8fafc;
            padding: 15px;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
        }
        
        .detail-label {
            font-weight: 600;
            color: #64748b;
            margin-bottom: 5px;
            font-size: 14px;
        }
        
        .detail-value {
            color: #1E5470;
            font-weight: 500;
        }
        
        .status-badge {
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }
        
        .status-admin {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
            color: white;
        }
        
        .status-partner {
            background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
            color: white;
        }
        
        .status-active {
            background: #dcfce7;
            color: #166534;
        }
        
        .status-verified {
            background: linear-gradient(135deg, #059669 0%, #10b981 100%);
            color: white;
        }
        
        .status-pending {
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
            color: white;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: linear-gradient(135deg, #34729C 0%, #1E5470 100%);
            color: white;
            padding: 20px;
            border-radius: 12px;
            text-align: center;
        }
        
        .stat-number {
            font-size: 2rem;
            font-weight: bold;
            margin-bottom: 5px;
        }
        
        .stat-label {
            font-size: 0.9rem;
            opacity: 0.9;
        }
        
        .data-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        }
        
        .data-table th {
            background: linear-gradient(135deg, #1E5470 0%, #34729C 100%);
            color: white;
            padding: 15px;
            font-weight: 600;
            text-align: right;
        }
        
        .data-table td {
            padding: 15px;
            border-bottom: 1px solid #f1f5f9;
            color: #334155;
        }
        
        .data-table tr:hover {
            background: #f8fafc;
        }
        
        .status-paid {
            background: linear-gradient(135deg, #059669 0%, #10b981 100%);
            color: white;
        }
        
        .status-cancelled {
            background: linear-gradient(135deg, #6b7280 0%, #4b5563 100%);
            color: white;
        }
        
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #64748b;
            background: #f8fafc;
            border-radius: 12px;
            border: 2px dashed #e2e8f0;
        }
        
        .tabs {
            display: flex;
            background: #f1f5f9;
            border-radius: 10px;
            padding: 5px;
            margin-bottom: 25px;
        }
        
        .tab {
            flex: 1;
            padding: 12px 20px;
            background: transparent;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 500;
            color: #64748b;
            transition: all 0.3s ease;
        }
        
        .tab:hover {
            background: rgba(52, 114, 156, 0.1);
            color: #1E5470;
        }
        
        .tab.active {
            background: white;
            color: #1E5470;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }
        
        .tab-content {
            display: none;
            animation: fadeIn 0.3s ease-in-out;
        }
        
        .tab-content.active {
            display: block;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        @media (max-width: 768px) {
            .user-details-grid {
                grid-template-columns: 1fr;
            }
            
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .header-content {
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }
        }
    </style>
</head>
<body>
    <header class="admin-header">
        <div class="header-content">
            <div class="header-title">تفاصيل المستخدم - <%= targetUser.username %></div>
            <a href="/admin/dashboard" class="btn btn-secondary">العودة إلى لوحة التحكم</a>
        </div>
    </header>

    <div class="admin-container">
        <!-- User Information Card -->
        <div class="user-info-card">
            <div class="card-header">
                <div class="card-icon">👤</div>
                <div class="card-title">معلومات المستخدم الأساسية</div>
            </div>
            
            <div class="user-details-grid">
                <div class="detail-item">
                    <div class="detail-label">اسم المستخدم</div>
                    <div class="detail-value"><%= targetUser.username %></div>
                </div>
                
                <div class="detail-item">
                    <div class="detail-label">رقم الهاتف</div>
                    <div class="detail-value"><%= targetUser.phoneNumber || targetUser.phone_number || 'غير متوفر' %></div>
                </div>
                
                <div class="detail-item">
                    <div class="detail-label">الدور</div>
                    <div class="detail-value">
                        <span class="status-badge <%= targetUser.role === 'admin' ? 'status-admin' : targetUser.role === 'partner' ? 'status-partner' : 'status-active' %>">
                            <%= targetUser.role === 'admin' ? 'مدير' : targetUser.role === 'partner' ? 'شريك' : 'مستخدم' %>
                        </span>
                    </div>
                </div>
                
                <div class="detail-item">
                    <div class="detail-label">تاريخ التسجيل</div>
                    <div class="detail-value"><%= targetUser.createdAt ? new Date(targetUser.createdAt).toLocaleDateString('ar-SA') : 'غير متوفر' %></div>
                </div>
                
                <% if (targetUser.role === 'partner') { %>
                    <div class="detail-item">
                        <div class="detail-label">اسم الشركة</div>
                        <div class="detail-value"><%= targetUser.companyName || 'غير محدد' %></div>
                    </div>
                    
                    <div class="detail-item">
                        <div class="detail-label">كود الشركة</div>
                        <div class="detail-value"><%= targetUser.companyCode || 'غير محدد' %></div>
                    </div>
                    
                    <div class="detail-item">
                        <div class="detail-label">ممثل الشركة</div>
                        <div class="detail-value"><%= targetUser.companyRepresentative || 'غير محدد' %></div>
                    </div>
                    
                    <div class="detail-item">
                        <div class="detail-label">حالة التفعيل</div>
                        <div class="detail-value">
                            <span class="status-badge <%= targetUser.isVerified ? 'status-verified' : 'status-pending' %>">
                                <%= targetUser.isVerified ? 'مُفعل' : 'معلق' %>
                            </span>
                        </div>
                    </div>
                    
                    <div class="detail-item">
                        <div class="detail-label">باقة الشريك</div>
                        <div class="detail-value"><%= targetUser.partnerPackage === 'basic' ? 'أساسية' : targetUser.partnerPackage === 'professional' ? 'احترافية' : targetUser.partnerPackage === 'premium' ? 'مميزة' : 'غير محدد' %></div>
                    </div>
                    
                    <div class="detail-item">
                        <div class="detail-label">الفروع</div>
                        <div class="detail-value"><%= targetUser.branches || 'غير محدد' %></div>
                    </div>
                    
                    <div class="detail-item">
                        <div class="detail-label">العنوان الأول</div>
                        <div class="detail-value"><%= targetUser.address1 || 'غير محدد' %></div>
                    </div>
                    
                    <div class="detail-item">
                        <div class="detail-label">العنوان الثاني</div>
                        <div class="detail-value"><%= targetUser.address2 || 'غير محدد' %></div>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Statistics -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-number"><%= stats.totalReservations %></div>
                <div class="stat-label">إجمالي الحجوزات</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= stats.paidReservations %></div>
                <div class="stat-label">الحجوزات المدفوعة</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= stats.pendingReservations %></div>
                <div class="stat-label">الحجوزات المعلقة</div>
            </div>
            <div class="stat-card">
                <div class="stat-number"><%= stats.totalSpent.toLocaleString() %> جنيه</div>
                <div class="stat-label">إجمالي الإنفاق</div>
            </div>
            <% if (targetUser.role === 'partner') { %>
                <div class="stat-card">
                    <div class="stat-number"><%= stats.totalCards %></div>
                    <div class="stat-label">إجمالي الباقات</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number"><%= stats.approvedCards %></div>
                    <div class="stat-label">الباقات المعتمدة</div>
                </div>
            <% } %>
        </div>

        <!-- Tabs for detailed data -->
        <div class="user-info-card">
            <div class="tabs">
                <button class="tab active" onclick="switchTab('reservations')">الحجوزات</button>
                <% if (targetUser.role === 'partner') { %>
                    <button class="tab" onclick="switchTab('cards')">الباقات المنشورة</button>
                <% } %>
            </div>
            
            <!-- Reservations Tab -->
            <div id="reservations" class="tab-content active">
                <% if (userReservations.length > 0) { %>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>رقم الحجز</th>
                                <th>كود الباقة</th>
                                <th>نوع الرحلة</th>
                                <th>حالة الدفع</th>
                                <th>المبلغ الإجمالي</th>
                                <th>تاريخ الحجز</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% userReservations.forEach(reservation => { %>
                                <tr>
                                    <td><%= reservation.reservationNumber || 'غير متوفر' %></td>
                                    <td><%= reservation.card ? reservation.card.code : 'محذوفة' %></td>
                                    <td><%= reservation.card ? (reservation.card.type === 'omrah' ? 'عُمرة' : reservation.card.type === 'external_tour' ? 'رحلة خارجية' : 'رحلة داخلية') : 'غير متوفر' %></td>
                                    <td>
                                        <span class="status-badge <%= reservation.paymentStatus === 'paid' ? 'status-paid' : reservation.paymentStatus === 'pending' ? 'status-pending' : 'status-cancelled' %>">
                                            <%= reservation.paymentStatus === 'paid' ? 'مدفوع' : reservation.paymentStatus === 'pending' ? 'معلق' : 'ملغي' %>
                                        </span>
                                    </td>
                                    <td><%= reservation.totalAmount ? reservation.totalAmount.toLocaleString() + ' جنيه' : 'غير محدد' %></td>
                                    <td><%= reservation.createdAt ? new Date(reservation.createdAt).toLocaleDateString('ar-SA') : 'غير متوفر' %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } else { %>
                    <div class="empty-state">
                        لا توجد حجوزات لهذا المستخدم
                    </div>
                <% } %>
            </div>
            
            <!-- Partner Cards Tab -->
            <% if (targetUser.role === 'partner') { %>
                <div id="cards" class="tab-content">
                    <% if (userCards.length > 0) { %>
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>كود الباقة</th>
                                    <th>نوع الرحلة</th>
                                    <th>تاريخ السفر</th>
                                    <th>المدة</th>
                                    <th>السعر</th>
                                    <th>حالة الاعتماد</th>
                                    <th>تاريخ النشر</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% userCards.forEach(card => { %>
                                    <tr>
                                        <td><%= card.code %></td>
                                        <td><%= card.type === 'omrah' ? 'عُمرة' : card.type === 'external_tour' ? 'رحلة خارجية' : 'رحلة داخلية' %></td>
                                        <td><%= card.travel_date ? new Date(card.travel_date).toLocaleDateString('ar-SA') : 'غير محدد' %></td>
                                        <td><%= card.days %> أيام / <%= card.nights %> ليالي</td>
                                        <td><%= card.rate ? card.rate.toLocaleString() + ' جنيه' : 'غير محدد' %></td>
                                        <td>
                                            <span class="status-badge <%= card.isApproved ? 'status-verified' : 'status-pending' %>">
                                                <%= card.isApproved ? 'معتمد' : 'معلق' %>
                                            </span>
                                        </td>
                                        <td><%= card.createdAt ? new Date(card.createdAt).toLocaleDateString('ar-SA') : 'غير متوفر' %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <div class="empty-state">
                            لم ينشر هذا الشريك أي باقات بعد
                        </div>
                    <% } %>
                </div>
            <% } %>
        </div>
    </div>

    <script>
        function switchTab(tabName) {
            // Hide all tab contents
            const tabContents = document.querySelectorAll('.tab-content');
            tabContents.forEach(content => {
                content.classList.remove('active');
            });
            
            // Remove active class from all tabs
            const tabs = document.querySelectorAll('.tab');
            tabs.forEach(tab => {
                tab.classList.remove('active');
            });
            
            // Show selected tab content
            document.getElementById(tabName).classList.add('active');
            
            // Add active class to clicked tab
            event.target.classList.add('active');
        }
    </script>
</body>
</html>