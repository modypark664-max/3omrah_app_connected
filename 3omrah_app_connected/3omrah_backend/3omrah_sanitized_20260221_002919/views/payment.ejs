<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Alexandria:wght@100..900&family=Cairo:wght@200..1000&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Tajawal:wght@200;300;400;500;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/home.css">
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/imgs/logo.png">
    <link rel="shortcut icon" type="image/png" href="/imgs/logo.png">
    <link rel="apple-touch-icon" href="/imgs/logo.png">
    
    <title><%= title || 'إتمام الدفع' %></title>
</head>
<body>
    <section id="header-hero" class="header-hero-section">
        <%- include('navbar') %>
    </section>

    <section class="payment-section">
        <div class="container">
            <div class="payment-container">
                <div class="payment-header">
                    <h1>إتمام عملية الدفع</h1>
                    <div class="reservation-info">
                        <h2>رقم الحجز: <span class="reservation-number"><%= reservation.reservationNumber %></span></h2>
                        <p class="booking-status">حالة الحجز: <span class="status-pending">في انتظار الدفع</span></p>
                    </div>
                </div>

                <div class="payment-details">
                    <div class="booking-summary">
                        <h3>ملخص الحجز</h3>
                        <div class="summary-grid">
                            <div class="summary-item">
                                <span class="label">اسم العميل:</span>
                                <span class="value"><%= reservation.username %></span>
                            </div>
                            <div class="summary-item">
                                <span class="label">رقم الهاتف:</span>
                                <span class="value"><%= reservation.phoneNumber %></span>
                            </div>
                            <div class="summary-item">
                                <span class="label">كود الرحلة:</span>
                                <span class="value"><%= reservation.card.code %></span>
                            </div>
                            <div class="summary-item">
                                <span class="label">نوع الرحلة:</span>
                                <span class="value">
                                    <% if (reservation.card.type === 'omrah') { %>عمرة<% } 
                                       else if (reservation.card.type === 'internal_tour') { %>رحلة داخلية<% } 
                                       else { %>رحلة خارجية<% } %>
                                </span>
                            </div>
                            <div class="summary-item">
                                <span class="label">مدة الرحلة:</span>
                                <span class="value"><%= reservation.card.days %> أيام / <%= reservation.card.nights %> ليالي</span>
                            </div>
                            <div class="summary-item">
                                <span class="label">عدد الأشخاص:</span>
                                <span class="value"><%= reservation.people_count %> شخص</span>
                            </div>
                            <div class="summary-item total-amount">
                                <span class="label">إجمالي المبلغ:</span>
                                <span class="value total-price"><%= reservation.totalAmount.toLocaleString() %> 
                                    <% if (reservation.card.type === 'omrah') { %>جنيه <% } else { %>جنيه مصري<% } %>
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="whatsapp-confirmation">
                        <h3 class="confirmation-title">تأكيد الحجز عبر واتساب</h3>
                        <div class="whatsapp-info">
                            <div class="info-card">
                                <h4>لتأكيد حجزك، تواصل معنا الآن عبر واتساب</h4>
                                <p>سيتم إرسال رسالة تحتوي على جميع تفاصيل حجزك لتأكيد الحجز والاتفاق على طريقة الدفع</p>
                            </div>
                            
                            <div class="reservation-summary">
                                <h5>ملخص الحجز:</h5>
                                <ul>
                                    <li><strong>رقم الحجز:</strong> <%= reservation.reservationNumber %></li>
                                    <li><strong>اسم العميل:</strong> <%= reservation.username %></li>
                                    <li><strong>رقم الهاتف:</strong> <%= reservation.phoneNumber %></li>
                                    <li><strong>كود الرحلة:</strong> <%= reservation.card.code %></li>
                                    <li><strong>نوع الرحلة:</strong> 
                                        <% if (reservation.card.type === 'omrah') { %>عمرة<% } 
                                           else if (reservation.card.type === 'internal_tour') { %>رحلة داخلية<% } 
                                           else if (reservation.card.type === 'external_tour') { %>رحلة خارجية<% } 
                                           else if (reservation.card.type === '7ag') { %>رحلة حج<% } 
                                           else { %>رحلة رمضان<% } %>
                                    </li>
                                    <li><strong>مدة الرحلة:</strong> <%= reservation.card.days %> أيام / <%= reservation.card.nights %> ليالي</li>
                                    <li><strong>عدد الأشخاص:</strong> <%= reservation.people_count %> شخص</li>
                                    <li><strong>نوع الغرفة:</strong> <%= reservation.roomType %></li>
                                    <% if (reservation.note && reservation.note.trim()) { %>
                                    <li><strong>ملاحظات:</strong> <%= reservation.note %></li>
                                    <% } %>
                                    <li class="total-line"><strong>إجمالي المبلغ:</strong> <%= reservation.totalAmount.toLocaleString() %> جنيه</li>
                                </ul>
                            </div>

                            <div class="whatsapp-button-container">
                                <a href="#" id="whatsappButton" class="whatsapp-btn">
                                    <div class="whatsapp-icon">
                                        <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor">
                                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
                                        </svg>
                                    </div>
                                    <div class="button-text">
                                        <span class="main-text">لتفاصيل الدفع</span>
                                        <span class="sub-text">اضغط للتواصل وإرسال تفاصيل الحجز</span>
                                    </div>
                                </a>
                            </div>

                            <div class="important-note">
                                <h4>ملاحظة هامة:</h4>
                                <p>بعد الضغط على الزر أعلاه، ستفتح محادثة واتساب تحتوي على جميع تفاصيل حجزك. سيقوم فريق خدمة العملاء بالرد عليك خلال دقائق لتأكيد الحجز ومناقشة طرق الدفع المتاحة.</p>
                            </div>

                            <div class="back-to-home">
                                <a href="/" class="back-home-btn">العودة للصفحة الرئيسية</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <style>
        * {
            direction: rtl;
            text-align: right;
        }

        .header-section {
            background: linear-gradient(180deg, #1e5470 29.81%, #5c8397 60.1%, #d3f0f7 100%);
            padding: 20px 0;
            min-height: 120px;
        }

        .payment-section {
            padding: 40px 0;
            background: #f8fafc;
            min-height: calc(100vh - 120px);
            direction: rtl;
        }

        .payment-container {
            max-width: 900px;
            margin: 0 auto;
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            direction: rtl;
        }

        .payment-header {
            background: linear-gradient(135deg, #1E5470 0%, #34729C 100%);
            color: white;
            padding: 40px;
            text-align: center;
            direction: rtl;
        }

        .payment-header h1 {
            margin: 0 0 20px 0;
            font-size: 2.5rem;
            font-weight: 700;
            font-family: var(--font-tajawal), 'Arial', sans-serif;
            text-align: center;
        }

        .reservation-info h2 {
            margin: 0 0 10px 0;
            font-size: 1.5rem;
            font-weight: 600;
            text-align: center;
            direction: rtl;
        }

        .reservation-number {
            color: #FFD700;
            font-weight: 900;
        }

        .booking-status {
            margin: 0;
            font-size: 1.1rem;
            text-align: center;
        }

        .status-pending {
            background: #f59e0b;
            color: white;
            padding: 5px 15px;
            border-radius: 20px;
            font-weight: 600;
        }

        .payment-details {
            padding: 40px;
            direction: rtl;
        }

        .booking-summary {
            background: #f8fafc;
            padding: 30px;
            border-radius: 15px;
            margin-bottom: 30px;
            direction: rtl;
        }

        .booking-summary h3 {
            margin: 0 0 25px 0;
            color: #1E5470;
            font-size: 1.5rem;
            font-weight: 700;
            text-align: center;
            font-family: var(--font-tajawal), 'Arial', sans-serif;
        }

        .summary-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            direction: rtl;
        }

        .summary-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 0;
            border-bottom: 1px solid #e2e8f0;
            direction: rtl;
            text-align: right;
        }

        .summary-item.total-amount {
            grid-column: 1 / -1;
            background: linear-gradient(135deg, #1E5470 0%, #34729C 100%);
            color: white;
            padding: 20px;
            border-radius: 10px;
            border: none;
            margin-top: 20px;
            text-align: center;
        }

        .summary-item .label {
            font-weight: 600;
            color: #64748b;
            margin-left: 10px;
            font-family: var(--font-tajawal), 'Arial', sans-serif;
        }

        .summary-item .value {
            font-weight: 700;
            color: #1E5470;
            font-family: var(--font-tajawal), 'Arial', sans-serif;
        }

        .total-amount .label,
        .total-amount .value {
            color: white;
        }

        .total-price {
            font-size: 1.5rem;
            color: #FFD700 !important;
        }

        .vodafone-payment {
            background: white;
            border: 2px solid #e60000;
            border-radius: 15px;
            padding: 30px;
            direction: rtl;
        }

        .payment-logo {
            text-align: center;
            margin-bottom: 20px;
        }

        .vodafone-logo {
            height: 80px;
            object-fit: contain;
        }

        .vodafone-payment h3 {
            text-align: center;
            color: #e60000;
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 30px;
            font-family: var(--font-tajawal), 'Arial', sans-serif;
        }

        .payment-instructions h4 {
            color: #1E5470;
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 20px;
            text-align: right;
            font-family: var(--font-tajawal), 'Arial', sans-serif;
        }

        .instructions-list {
            list-style: decimal;
            padding-right: 20px;
            padding-left: 0;
            color: #334155;
            line-height: 1.8;
            direction: rtl;
            text-align: right;
            font-family: var(--font-tajawal), 'Arial', sans-serif;
        }

        .instructions-list li {
            margin-bottom: 15px;
            font-size: 1.1rem;
            text-align: right;
            direction: rtl;
        }

        .payment-number {
            background: #f1f5f9;
            padding: 20px;
            border-radius: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 15px 0;
            border: 2px dashed #34729C;
            direction: rtl;
        }

        .payment-number .number {
            font-size: 1.5rem;
            font-weight: 900;
            color: #1E5470;
            font-family: 'Courier New', monospace;
            direction: ltr;
        }

        .copy-btn {
            background: #34729C;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s ease;
            font-family: var(--font-tajawal), 'Arial', sans-serif;
        }

        .copy-btn:hover {
            background: #1E5470;
            transform: translateY(-2px);
        }

        .important-note {
            background: #fef3c7;
            border: 1px solid #f59e0b;
            border-radius: 10px;
            padding: 20px;
            margin: 30px 0;
            direction: rtl;
            text-align: right;
        }

        .important-note h4 {
            color: #92400e;
            margin: 0 0 10px 0;
            font-weight: 700;
            text-align: right;
            font-family: var(--font-tajawal), 'Arial', sans-serif;
        }

        .important-note p {
            color: #92400e;
            margin: 0;
            line-height: 1.6;
            text-align: right;
            font-family: var(--font-tajawal), 'Arial', sans-serif;
        }

        .payment-actions {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin-top: 30px;
            direction: rtl;
        }

        .contact-info {
            background: #e0f2fe;
            border: 2px solid #0284c7;
            border-radius: 15px;
            padding: 25px;
            text-align: center;
            direction: rtl;
        }

        .contact-info h4 {
            color: #0284c7;
            font-size: 1.3rem;
            font-weight: 700;
            margin: 0 0 15px 0;
            font-family: var(--font-tajawal), 'Arial', sans-serif;
        }

        .contact-info p {
            color: #075985;
            font-size: 1.1rem;
            margin: 10px 0;
            font-family: var(--font-tajawal), 'Arial', sans-serif;
        }

        .contact-number {
            background: #bae6fd;
            padding: 20px;
            border-radius: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 20px 0;
            border: 2px dashed #0284c7;
            direction: rtl;
        }

        .contact-number .number {
            font-size: 1.5rem;
            font-weight: 900;
            color: #0c4a6e;
            font-family: 'Courier New', monospace;
            direction: ltr;
        }

        .contact-note {
            background: #fef3c7;
            border: 1px solid #f59e0b;
            border-radius: 8px;
            padding: 15px;
            color: #92400e !important;
            font-weight: 600;
            margin: 15px 0 0 0;
        }

        .confirm-payment-btn {
            background: linear-gradient(135deg, #059669 0%, #10b981 100%);
            color: white;
            border: none;
            padding: 18px 40px;
            border-radius: 12px;
            font-size: 1.2rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: center;
            font-family: var(--font-tajawal), 'Arial', sans-serif;
        }

        .confirm-payment-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(5, 150, 105, 0.4);
        }

        .back-home-btn {
            background: #6b7280;
            color: white;
            padding: 15px 30px;
            border-radius: 10px;
            text-decoration: none;
            text-align: center;
            font-weight: 600;
            transition: all 0.3s ease;
            font-family: var(--font-tajawal), 'Arial', sans-serif;
        }

        .back-home-btn:hover {
            background: #4b5563;
            transform: translateY(-2px);
        }

        @media (max-width: 768px) {
            .payment-container {
                margin: 20px;
                border-radius: 15px;
            }

            .payment-header {
                padding: 30px 20px;
            }

            .payment-header h1 {
                font-size: 2rem;
            }

            .payment-details {
                padding: 30px 20px;
            }

            .booking-summary {
                padding: 20px;
            }

            .summary-grid {
                grid-template-columns: 1fr;
                gap: 10px;
            }

            .vodafone-payment {
                padding: 20px;
            }

            .payment-number {
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }

            .payment-number .number {
                font-size: 1.2rem;
            }

            .instructions-list {
                padding-right: 15px;
            }

            .contact-number {
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }

            .contact-number .number {
                font-size: 1.2rem;
            }

            .contact-info {
                padding: 20px;
            }
        }
    </style>

    <script>
        // Create WhatsApp message with reservation details
        document.addEventListener('DOMContentLoaded', function() {
            const whatsappButton = document.getElementById('whatsappButton');
            const whatsappNumber = '<%= whatsapp %>'; // This comes from the global context
            
            // Reservation details for WhatsApp message
            const reservationDetails = {
                reservationNumber: '<%= reservation.reservationNumber %>',
                username: '<%= reservation.username %>',
                phoneNumber: '<%= reservation.phoneNumber %>',
                cardCode: '<%= reservation.card.code %>',
                cardType: '<% if (reservation.card.type === "omrah") { %>عمرة<% } else if (reservation.card.type === "internal_tour") { %>رحلة داخلية<% } else if (reservation.card.type === "external_tour") { %>رحلة خارجية<% } else if (reservation.card.type === "7ag") { %>رحلة حج<% } else { %>رحلة رمضان<% } %>',
                days: '<%= reservation.card.days %>',
                nights: '<%= reservation.card.nights %>',
                peopleCount: '<%= reservation.people_count %>',
                roomType: '<%= reservation.roomType %>',
                totalAmount: '<%= reservation.totalAmount.toLocaleString() %>',
                note: '<%= reservation.note ? reservation.note : "" %>'
            };
            
            // Create WhatsApp message
            let message = `السلام عليكم ورحمة الله وبركاته\n\n`;
            message += `أرغب في تأكيد الحجز التالي:\n\n`;
            message += `🎫 *رقم الحجز:* ${reservationDetails.reservationNumber}\n`;
            message += `👤 *اسم العميل:* ${reservationDetails.username}\n`;
            message += `📞 *رقم الهاتف:* ${reservationDetails.phoneNumber}\n`;
            message += `🎯 *كود الرحلة:* ${reservationDetails.cardCode}\n`;
            message += `🕌 *نوع الرحلة:* ${reservationDetails.cardType}\n`;
            message += `📅 *مدة الرحلة:* ${reservationDetails.days} أيام / ${reservationDetails.nights} ليالي\n`;
            message += `👥 *عدد الأشخاص:* ${reservationDetails.peopleCount} شخص\n`;
            message += `🏨 *نوع الغرفة:* ${reservationDetails.roomType}\n`;
            
            if (reservationDetails.note && reservationDetails.note.trim()) {
                message += `📝 *ملاحظات:* ${reservationDetails.note}\n`;
            }
            
            message += `💰 *إجمالي المبلغ:* ${reservationDetails.totalAmount} جنيه\n\n`;
            message += `أرجو تأكيد الحجز ومناقشة طرق الدفع المتاحة.\n`;
            message += `شكراً لكم.`;
            
            // Encode message for URL
            const encodedMessage = encodeURIComponent(message);
            
            // Create WhatsApp URL
            const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodedMessage}`;
            
            // Set the href attribute
            whatsappButton.href = whatsappUrl;
            
            // Add click tracking if needed
            whatsappButton.addEventListener('click', function() {
                console.log('WhatsApp button clicked for reservation:', reservationDetails.reservationNumber);
            });
        });
        
        // Copy to clipboard function (if still needed)
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(function() {
                // Show success message
                const btn = event.target;
                const originalText = btn.textContent;
                btn.textContent = 'تم النسخ!';
                btn.style.background = '#059669';
                
                setTimeout(function() {
                    btn.textContent = originalText;
                    btn.style.background = '#34729C';
                }, 2000);
            }).catch(function() {
                // Fallback for older browsers
                const textArea = document.createElement('textarea');
                textArea.value = text;
                document.body.appendChild(textArea);
                textArea.select();
                document.execCommand('copy');
                document.body.removeChild(textArea);
                
                const btn = event.target;
                const originalText = btn.textContent;
                btn.textContent = 'تم النسخ!';
                btn.style.background = '#059669';
                
                setTimeout(function() {
                    btn.textContent = originalText;
                    btn.style.background = '#34729C';
                }, 2000);
            });
        }
    </script>
    <style>
