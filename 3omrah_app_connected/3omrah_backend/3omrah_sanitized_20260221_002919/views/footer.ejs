      width: 200px;
    }
  }

  .footer-logo-text {
    font-family: var(--font-kufam);
    font-weight: 700;
    font-size: 32px;
    color: var(--color-primary);
  }
  .footer-description {
    font-family: var(--font-nunito);
    font-weight: 600;
    font-size: 18px;
    line-height: 1.36;
    color: var(--color-accent);
    text-align: right !important;
  }
  .footer-links {
    display: flex;
    gap: 80px;
  }
  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .footer-column h4 {
    font-family: var(--font-tajawal);
    font-weight: 700;
    font-size: 24px;
    margin-bottom: 10px;
  }
  .footer-column ul {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-column a {
